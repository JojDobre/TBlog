# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json.bak
.npm/

# =============================================================================
# Environment & secrets — NIKDY necommitovať
# =============================================================================
.env
.env.local
.env.*.local
.env.production
.env.development.local

# =============================================================================
# Uploads — runtime obsah, nepatrí do gitu
# Štruktúru priečinkov držíme cez .gitkeep
# =============================================================================
uploads/originals/*
uploads/thumbnails/*
uploads/videos/*
!uploads/originals/.gitkeep
!uploads/thumbnails/.gitkeep
!uploads/videos/.gitkeep

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# DB dumps
# =============================================================================
*.sql
*.dump
!backend/migrations/*.sql

# =============================================================================
# IDE
# =============================================================================
# VS Code: ignorujeme všetko OKREM doporučených rozšírení a settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# Build / coverage
# =============================================================================
dist/
build/
coverage/
.nyc_output/

# =============================================================================
# Iné
# =============================================================================
*.swp
*.swo
*~
.cache/
