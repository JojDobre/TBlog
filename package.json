{
  "name": "bytezone",
  "version": "0.1.0",
  "private": true,
  "description": "Tech blog s recenziami a rebríčkami. Express + MariaDB + EJS.",
  "main": "backend/src/server.js",
  "scripts": {
    "dev": "nodemon backend/src/server.js",
    "start": "node backend/src/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mariadb",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:verify": "node backend/scripts/verify-db.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "migrate:make": "knex migrate:make",
    "seed": "knex seed:run",
    "seed:make": "knex seed:make",
    "setup:admin": "node backend/scripts/setup-admin.js",
    "lint": "eslint backend/src",
    "format": "prettier --write \"backend/src/**/*.js\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "connect-session-knex": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "csrf-csrf": "^3.0.6",
    "dompurify": "^3.2.2",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "jsdom": "^25.0.1",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.5",
    "node-cron": "^3.0.3",
    "sharp": "^0.33.5",
    "slugify": "^1.6.6",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "eslint": "^9.16.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.4.2"
  }
}
