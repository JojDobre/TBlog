<div class="stat-overview" style="grid-template-columns:1fr 1fr 1fr">
  <div><span class="ov-num"><%= s.seoTotal %></span><span class="ov-l">celkom pub.</span></div>
  <div><span class="ov-num" style="color:var(--accent)"><%= s.seoWithTitle %></span><span class="ov-l">s SEO titulkom</span></div>
  <div><span class="ov-num" style="color:var(--accent)"><%= s.seoWithDesc %></span><span class="ov-l">s meta desc.</span></div>
</div>
<% if (s.seoTotal > 0) { %>
<div style="margin-top:8px;height:6px;border-radius:3px;background:var(--border);overflow:hidden">
  <div style="height:100%;width:<%= Math.round(s.seoWithDesc / s.seoTotal * 100) %>%;background:var(--accent);border-radius:3px"></div>
</div>
<div style="font-size:11px;color:var(--text-subtle);margin-top:4px"><%= Math.round(s.seoWithDesc / s.seoTotal * 100) %>% článkov má kompletné SEO</div>
<% } %>
