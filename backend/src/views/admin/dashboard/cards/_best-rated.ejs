<% if (s.bestRated.length === 0) { %>
<div class="stat-empty">Žiadne hodnotené recenzie.</div>
<% } else { %>
<div class="stat-overview" style="grid-template-columns:1fr">
  <% s.bestRated.slice(0,3).forEach(a => { %>
  <div style="display:flex;justify-content:space-between;align-items:center">
    <span class="ov-l" style="font-size:12px"><%= a.title %></span>
    <span class="ov-num" style="font-size:16px;color:var(--accent)"><%= a.score %></span>
  </div>
  <% }) %>
</div>
<% } %>
