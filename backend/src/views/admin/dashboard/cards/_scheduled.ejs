<% if (s.scheduled.length === 0) { %>
<div class="stat-empty">Žiadne naplánované články.</div>
<% } else { %>
<ul class="stat-list">
  <% s.scheduled.forEach(a => { %>
  <li>
    <a href="/admin/articles/<%= a.id %>/edit" class="li-t"><%= a.title %></a>
    <span class="li-m"><%= a.author || '—' %> · <%= a.scheduled_at ? new Date(a.scheduled_at).toLocaleDateString('sk-SK') : '—' %></span>
  </li>
  <% }) %>
</ul>
<% } %>
