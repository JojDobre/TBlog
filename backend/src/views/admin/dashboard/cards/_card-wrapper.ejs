<%# Card wrapper with S/M/L size toggle %>
<article class="astats-card astats-<%= cardSize %>" data-card-id="<%= cardId %>" data-card-group="<%= cardGroup %>" data-card-size="<%= cardSize %>">
  <header class="astats-card-head">
    <span class="astats-card-icon"><i class="bi <%= cardIcon %>"></i></span>
    <h3><%= cardTitle %></h3>
    <span class="astats-card-group"><%= cardGroup %></span>
    <div class="astats-card-actions">
      <div class="astats-size-toggle">
        <% ['S','M','L'].forEach(function(s) { %>
        <button class="<%= cardSize === s ? 'active' : '' %>" data-size="<%= s %>"><%= s %></button>
        <% }) %>
      </div>
      <button class="astats-height-toggle" title="Dvojitá výška"><i class="bi bi-arrows-expand"></i></button>
      <button class="astats-card-act astats-card-hide" title="Skryť kartu"><i class="bi bi-eye-slash"></i></button>
      <!-- <button class="astats-card-act" title="Viac"><i class="bi bi-three-dots"></i></button> -->
    </div>
  </header>
  <div class="astats-card-body">
    <%- include(cardBody) %>
  </div>
</article>
