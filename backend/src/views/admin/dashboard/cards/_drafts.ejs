<% if (s.drafts.length === 0) { %>
<div class="stat-empty">Žiadne rozpracované články.</div>
<% } else { %>
<ul class="stat-list">
  <% s.drafts.forEach(a => { %>
  <li>
    <a href="/admin/articles/<%= a.id %>/edit" class="li-t"><%= a.title %></a>
    <span class="li-m"><%= a.author || '—' %> · <%= new Date(a.updated_at).toLocaleDateString('sk-SK') %></span>
  </li>
  <% }) %>
</ul>
<% } %>
