<ul class="stat-list">
  <% s.recentlyEdited.forEach(a => { %>
  <li>
    <a href="/admin/articles/<%= a.id %>/edit" class="li-t"><%= a.title %></a>
    <span class="li-m"><%= a.author || '—' %> · <%= new Date(a.updated_at).toLocaleString('sk-SK') %> · <span class="bz-status-pill bz-pill-<%= a.status === 'published' ? 'pub' : 'draft' %>"><%= a.status %></span></span>
  </li>
  <% }) %>
</ul>
