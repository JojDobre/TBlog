<% if (s.recentlyDeleted.length === 0) { %>
<div class="stat-empty">Žiadne zmazané komentáre.</div>
<% } else { %>
<ul class="stat-list">
  <% s.recentlyDeleted.forEach(c => { %>
  <li>
    <span class="li-t" style="font-size:12px"><%= (c.content || '').slice(0, 80) %><%= (c.content || '').length > 80 ? '…' : '' %></span>
    <span class="li-m"><%= c.user_name || '—' %> · <%= c.article_title %></span>
  </li>
  <% }) %>
</ul>
<% } %>
