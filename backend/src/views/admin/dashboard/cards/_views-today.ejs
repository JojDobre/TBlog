<div class="stat-big">
  <span class="big-n">62.4k</span>
  <span class="big-l">pozretí dnes</span>
  <% var _v=[3.2,4.1,5.6,7.2,8.4,9.1,11.2,13.6,15.8,18.4,22.1,25.8],_w=100,_h=30,_mx=Math.max.apply(null,_v),_mn=Math.min.apply(null,_v),_s=_mx-_mn||1,_p=_v.map(function(v,i){return((i/(_v.length-1))*_w)+','+(_h-((v-_mn)/_s)*(_h-4)-2)}).join(' '); %>
  <svg class="stat-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
    <polyline points="<%=_p%>" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linejoin="round" stroke-linecap="round"/>
    <polyline points="0,30 <%=_p%> 100,30" fill="var(--accent)" opacity="0.12"/>
  </svg>
</div>
