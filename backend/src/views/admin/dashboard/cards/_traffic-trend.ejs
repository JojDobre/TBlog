<% if (s.trafficTrend.length === 0) { %>
<div class="stat-empty">Nedostatok dát.</div>
<% } else { %>
<%
  var last7 = s.trafficTrend.slice(-7);
  var prev7 = s.trafficTrend.slice(-14, -7);
  var sum7 = last7.reduce(function(a,b){return a+b.views},0);
  var sumP7 = prev7.reduce(function(a,b){return a+b.views},0);
  var change = sumP7 > 0 ? Math.round(((sum7-sumP7)/sumP7)*100) : 0;
%>
<div class="stat-overview" style="grid-template-columns:1fr 1fr">
  <div><span class="ov-num"><%= sum7 %></span><span class="ov-l">posledných 7d</span></div>
  <div><span class="ov-num" style="color:<%= change >= 0 ? 'var(--accent)' : 'oklch(0.7 0.18 25)' %>"><%= change >= 0 ? '+' : '' %><%= change %>%</span><span class="ov-l">vs. predchádzajúcich 7d</span></div>
</div>
<% } %>
