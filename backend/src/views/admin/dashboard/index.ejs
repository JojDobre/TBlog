<!doctype html>
<html lang="sk" data-bs-theme="dark">

<head>
  <%- include('../partials/head', { title: 'Dashboard' }) %>
  <link rel="stylesheet" href="/admin/static/css/admin-stats.css" />
</head>

<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>
  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Dashboard' }) %>
    <main class="bz-content">
      <div class="bz-dash-wrap bz-stats-scope">

        <%# ===== HEADER ===== %>
        <div class="bz-dash-header">
          <div>
            <span class="bz-eyebrow">
              <% const days=['Nedeľa','Pondelok','Utorok','Streda','Štvrtok','Piatok','Sobota']; const months=['januára','februára','marca','apríla','mája','júna','júla','augusta','septembra','októbra','novembra','decembra']; const now=new Date(); %>
              <%= days[now.getDay()] %> · <%= now.getDate() %>. <%= months[now.getMonth()] %> <%= now.getFullYear() %>
            </span>
            <h1 class="bz-dash-title">Ahoj<% if (typeof user !== 'undefined' && user && user.nickname) { %>, <%= user.nickname %><% } %> 👋</h1>
          </div>
          <div class="bz-dash-header-actions">
            <a href="/admin/articles/new" class="bz-btn bz-btn-sm" style="background:var(--accent);color:var(--accent-fg)"><i class="bi bi-plus-lg"></i> Nový článok</a>
            <a href="/admin/stats" class="bz-btn bz-btn-sm"><i class="bi bi-graph-up"></i> Štatistiky</a>
          </div>
        </div>

        <%# ===== KPI ROW ===== %>
        <div class="dash-kpi-row">
          <div class="dash-kpi" style="--kpi-color: oklch(0.72 0.17 155)">
            <div class="dash-kpi-icon"><i class="bi bi-file-earmark-text"></i></div>
            <div class="dash-kpi-data">
              <span class="dash-kpi-num"><%= stats.articles %></span>
              <span class="dash-kpi-label">Článkov</span>
            </div>
          </div>
          <div class="dash-kpi" style="--kpi-color: oklch(0.65 0.19 260)">
            <div class="dash-kpi-icon"><i class="bi bi-eye"></i></div>
            <div class="dash-kpi-data">
              <span class="dash-kpi-num"><%= fmt(stats.visits24h) %></span>
              <span class="dash-kpi-label">Návštevy · 24h</span>
            </div>
          </div>
          <div class="dash-kpi" style="--kpi-color: oklch(0.7 0.15 60)">
            <div class="dash-kpi-icon"><i class="bi bi-chat-dots"></i></div>
            <div class="dash-kpi-data">
              <span class="dash-kpi-num"><%= stats.comments %></span>
              <span class="dash-kpi-label">Komentárov</span>
            </div>
          </div>
          <div class="dash-kpi" style="--kpi-color: oklch(0.65 0.2 330)">
            <div class="dash-kpi-icon"><i class="bi bi-images"></i></div>
            <div class="dash-kpi-data">
              <span class="dash-kpi-num"><%= stats.media %></span>
              <span class="dash-kpi-label">Médií</span>
            </div>
          </div>
        </div>

        <%# ===== QUICK ACTIONS ===== %>
        <div class="dash-actions-bar">
          <a href="/admin/articles/new" class="dash-action-btn"><i class="bi bi-plus-lg"></i> Nový článok</a>
          <a href="/admin/media" class="dash-action-btn"><i class="bi bi-images"></i> Médiá</a>
          <a href="/admin/comments" class="dash-action-btn"><i class="bi bi-chat-dots"></i> Komentáre</a>
          <a href="/admin/templates" class="dash-action-btn"><i class="bi bi-file-earmark-text"></i> Šablóny</a>
          <a href="/admin/settings" class="dash-action-btn"><i class="bi bi-gear"></i> Nastavenia</a>
          <a href="/admin/stats" class="dash-action-btn"><i class="bi bi-graph-up"></i> Štatistiky</a>
        </div>

        <%# ===== MAIN GRID ===== %>
        <div class="dash-grid">

          <%# --- 30D CHART --- %>
          <div class="dash-card dash-card-wide">
            <div class="dash-card-head">
              <h3><i class="bi bi-graph-up" style="color:var(--accent);opacity:0.7"></i> Návštevnosť · 30 dní</h3>
              <div class="dash-card-badge"><%= fmt(s.views30d) %> celkom
                <% if (s.viewsGrowth !== 0) { %>
                <span style="color:<%= s.viewsGrowth >= 0 ? 'var(--r-great)' : 'var(--r-bad)' %>; margin-left:6px"><%= s.viewsGrowth >= 0 ? '↑' : '↓' %> <%= Math.abs(s.viewsGrowth) %>%</span>
                <% } %>
              </div>
            </div>
            <div class="dash-card-body" style="padding:8px 12px 4px">
              <% if (s.viewsDaily && s.viewsDaily.length > 1) {
                var maxV = Math.max.apply(null, s.viewsDaily.map(function(d){return d.views})) || 1;
                var chartDays = s.viewsDaily.map(function(d){
                  var dt = new Date(d.day);
                  return { views: d.views, label: dt.getDate() + '.' + (dt.getMonth()+1) + '.' };
                });
                var pts = chartDays.map(function(d,i){ var x=(i/(chartDays.length-1))*760+20; var y=110-((d.views/maxV)*95)+5; return {x:x,y:y}; });
              %>
              <svg viewBox="0 0 800 135" style="width:100%;height:130px;display:block" id="dash-chart-svg">
                <defs>
                  <linearGradient id="cg" x1="0" x2="0" y1="0" y2="1">
                    <stop offset="0%" stop-color="oklch(0.72 0.17 155)" stop-opacity="0.3" />
                    <stop offset="100%" stop-color="oklch(0.72 0.17 155)" stop-opacity="0" />
                  </linearGradient>
                </defs>
                <path d="M<%= pts.map(function(p){return p.x+','+p.y}).join(' L') %> L<%= pts[pts.length-1].x %>,120 L<%= pts[0].x %>,120 Z" fill="url(#cg)" />
                <path d="M<%= pts.map(function(p){return p.x+','+p.y}).join(' L') %>" fill="none" stroke="oklch(0.72 0.17 155)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                <% var step=Math.max(1,Math.floor(chartDays.length/7)); chartDays.forEach(function(d,i){ if(i%step===0||i===chartDays.length-1){ %>
                <text x="<%= pts[i].x %>" y="132" font-size="9" font-family="IBM Plex Mono,monospace" fill="oklch(0.48 0.01 240)" text-anchor="middle"><%= d.label %></text>
                <% }}) %>
                <% chartDays.forEach(function(d,i){ %>
                <circle class="dash-chart-dot" cx="<%= pts[i].x %>" cy="<%= pts[i].y %>" r="12" fill="transparent" data-views="<%= d.views %>" data-label="<%= d.label %>" />
                <circle class="dash-chart-dot-vis" cx="<%= pts[i].x %>" cy="<%= pts[i].y %>" r="0" fill="oklch(0.72 0.17 155)" />
                <% }) %>
              </svg>
              <div class="dash-chart-tooltip" id="dash-chart-tip" style="display:none"></div>
              <% } else { %>
              <div style="text-align:center;padding:40px 0;color:var(--text-subtle)">Nedostatok dát</div>
              <% } %>
            </div>
          </div>

          <%# --- TODAY STATS --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-sun" style="color:oklch(0.7 0.15 60);opacity:0.7"></i> Dnes</h3>
            </div>
            <div class="dash-card-body">
              <div class="dash-today-grid">
                <div><span class="dash-today-num"><%= fmt(s.viewsToday) %></span><span class="dash-today-label">pozretí</span></div>
                <div><span class="dash-today-num"><%= fmt(s.uniqueToday) %></span><span class="dash-today-label">unikátnych</span></div>
                <div><span class="dash-today-num"><%= s.onlineUsers %></span><span class="dash-today-label">online teraz</span></div>
                <div><span class="dash-today-num"><%= fmt(s.viewsYesterday) %></span><span class="dash-today-label">včera</span></div>
              </div>
            </div>
          </div>

          <%# --- DEVICES --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-phone" style="color:oklch(0.65 0.19 260);opacity:0.7"></i> Zariadenia</h3>
            </div>
            <div class="dash-card-body">
              <div class="dash-devices">
                <div class="dash-dev-bar">
                  <div class="dash-dev-fill" style="width:<%= s.devices.desktop %>%;background:oklch(0.65 0.19 260)"></div>
                </div>
                <div class="dash-dev-row"><span>🖥 Desktop</span><strong><%= s.devices.desktop %>%</strong></div>
                <div class="dash-dev-bar">
                  <div class="dash-dev-fill" style="width:<%= s.devices.mobile %>%;background:oklch(0.72 0.17 155)"></div>
                </div>
                <div class="dash-dev-row"><span>📱 Mobil</span><strong><%= s.devices.mobile %>%</strong></div>
                <div class="dash-dev-bar">
                  <div class="dash-dev-fill" style="width:<%= s.devices.tablet %>%;background:oklch(0.7 0.15 60)"></div>
                </div>
                <div class="dash-dev-row"><span>📟 Tablet</span><strong><%= s.devices.tablet %>%</strong></div>
              </div>
            </div>
          </div>

          <%# --- RECENT ARTICLES --- %>
          <div class="dash-card dash-card-wide">
            <div class="dash-card-head">
              <h3><i class="bi bi-newspaper" style="color:var(--accent);opacity:0.7"></i> Posledné články</h3>
              <a href="/admin/articles" class="dash-card-link">Všetky →</a>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.recentlyPublished && s.recentlyPublished.length) { s.recentlyPublished.forEach(function(a,i){ %>
              <a href="/admin/articles/<%= a.id %>/edit" class="dash-article-row">
                <span class="dash-article-num"><%= i+1 %></span>
                <div class="dash-article-info">
                  <strong><%= a.title %></strong>
                  <span><%= a.author || '—' %> · <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %></span>
                </div>
                <span class="dash-article-views"><%= fmt(a.view_count || 0) %> <i class="bi bi-eye"></i></span>
              </a>
              <% }); } else { %>
              <div style="padding:20px;text-align:center;color:var(--text-subtle)">Žiadne publikované články</div>
              <% } %>
            </div>
          </div>

          <%# --- DRAFTS --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-pencil" style="color:oklch(0.7 0.15 60);opacity:0.7"></i> Drafty</h3>
              <span class="dash-card-badge"><%= s.drafts.length %></span>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.drafts.length) { s.drafts.slice(0,5).forEach(function(d){ %>
              <a href="/admin/articles/<%= d.id %>/edit" class="dash-mini-row">
                <span><%= d.title %></span>
                <span class="dash-mini-meta"><%= d.updated_at ? new Date(d.updated_at).toLocaleDateString('sk-SK') : '' %></span>
              </a>
              <% }); } else { %>
              <div style="padding:16px;text-align:center;color:var(--text-subtle)">Žiadne drafty 🎉</div>
              <% } %>
            </div>
          </div>

          <%# --- SCHEDULED --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-calendar-event" style="color:oklch(0.65 0.2 330);opacity:0.7"></i> Naplánované</h3>
              <span class="dash-card-badge"><%= s.scheduled.length %></span>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.scheduled.length) { s.scheduled.slice(0,5).forEach(function(a){ %>
              <a href="/admin/articles/<%= a.id %>/edit" class="dash-mini-row">
                <span><%= a.title %></span>
                <span class="dash-mini-meta"><%= a.scheduled_at ? new Date(a.scheduled_at).toLocaleDateString('sk-SK') : '' %></span>
              </a>
              <% }); } else { %>
              <div style="padding:16px;text-align:center;color:var(--text-subtle)">Nič naplánované</div>
              <% } %>
            </div>
          </div>

          <%# --- TOP TODAY --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-fire" style="color:oklch(0.62 0.21 25);opacity:0.7"></i> Najčítanejšie dnes</h3>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.topToday && s.topToday.length) { s.topToday.forEach(function(a,i){ %>
              <div class="dash-mini-row">
                <span class="dash-rank"><%= i+1 %></span>
                <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= a.title %></span>
                <strong style="color:var(--accent);font-size:12px"><%= a.views %></strong>
              </div>
              <% }); } else { %>
              <div style="padding:16px;text-align:center;color:var(--text-subtle)">Žiadne návštevy dnes</div>
              <% } %>
            </div>
          </div>

          <%# --- SEO HEALTH --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-search" style="color:oklch(0.72 0.17 155);opacity:0.7"></i> SEO zdravie</h3>
            </div>
            <div class="dash-card-body">
              <% var seoPct = s.seoTotal > 0 ? Math.round((s.seoWithTitle / s.seoTotal) * 100) : 0; var descPct = s.seoTotal > 0 ? Math.round((s.seoWithDesc / s.seoTotal) * 100) : 0; %>
              <div class="dash-seo-row">
                <span>SEO titulky</span>
                <div class="dash-seo-bar">
                  <div class="dash-seo-fill" style="width:<%= seoPct %>%"></div>
                </div>
                <strong><%= seoPct %>%</strong>
              </div>
              <div class="dash-seo-row">
                <span>Meta popisy</span>
                <div class="dash-seo-bar">
                  <div class="dash-seo-fill" style="width:<%= descPct %>%"></div>
                </div>
                <strong><%= descPct %>%</strong>
              </div>
              <div style="margin-top:10px;font-size:11px;color:var(--text-subtle)">
                <% if (s.noImage.length) { %><span style="color:var(--r-bad)"><%= s.noImage.length %> bez obrázka</span> · <% } %>
                <% if (s.noTags.length) { %><span style="color:var(--r-mid)"><%= s.noTags.length %> bez tagov</span> · <% } %>
                <% if (s.noCategory.length) { %><span style="color:var(--r-mid)"><%= s.noCategory.length %> bez kategórie</span><% } %>
              </div>
            </div>
          </div>

          <%# --- SERVER --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-cpu" style="color:oklch(0.65 0.19 260);opacity:0.7"></i> Systém</h3>
            </div>
            <div class="dash-card-body">
              <div class="dash-sys">
                <div class="dash-sys-row"><span>Uptime</span><span class="dash-sys-val" style="color:var(--r-great)"><%= s.serverUptime %>h</span></div>
                <div class="dash-sys-row"><span>Pamäť</span><span class="dash-sys-val"><%= s.serverMemory %> MB</span></div>
                <div class="dash-sys-row"><span>Node.js</span><span class="dash-sys-val"><%= s.nodeVersion %></span></div>
                <div class="dash-sys-row"><span>Sessions</span><span class="dash-sys-val"><%= s.activeSessions %></span></div>
                <div class="dash-sys-row"><span>Úložisko</span><span class="dash-sys-val"><%= s.uploadStorage %></span></div>
              </div>
            </div>
          </div>

          <%# --- TOP PAGES --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-bar-chart" style="color:oklch(0.65 0.2 330);opacity:0.7"></i> Top stránky · 30d</h3>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.topPages && s.topPages.length) { s.topPages.slice(0,5).forEach(function(p,i){ %>
              <div class="dash-mini-row">
                <span class="dash-rank" style="background:oklch(0.65 0.2 330 / 0.12);color:oklch(0.65 0.2 330)"><%= i+1 %></span>
                <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:var(--font-mono);font-size:12px"><%= p.path %></span>
                <strong style="color:var(--accent);font-size:12px"><%= fmt(p.views) %></strong>
              </div>
              <% }); } else { %>
              <div style="padding:16px;text-align:center;color:var(--text-subtle)">Žiadne dáta</div>
              <% } %>
            </div>
          </div>

          <%# --- COMMENTS --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-chat-dots" style="color:oklch(0.7 0.15 60);opacity:0.7"></i> Komentáre</h3>
              <a href="/admin/comments" class="dash-card-link">Spravovať →</a>
            </div>
            <div class="dash-card-body">
              <div class="dash-today-grid">
                <div><span class="dash-today-num"><%= s.newComments24h %></span><span class="dash-today-label">za 24h</span></div>
                <div><span class="dash-today-num"><%= s.newCommentsWeek %></span><span class="dash-today-label">za 7 dní</span></div>
              </div>
            </div>
          </div>

          <%# --- BEST TIME --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-clock" style="color:oklch(0.72 0.17 155);opacity:0.7"></i> Najlepší čas</h3>
            </div>
            <div class="dash-card-body">
              <div class="dash-today-grid">
                <div>
                  <span class="dash-today-num"><%= s.bestHourVal !== null ? s.bestHourVal + ':00' : '—' %></span>
                  <span class="dash-today-label">najlepšia hodina</span>
                </div>
                <div>
                  <span class="dash-today-num" style="font-size:20px"><%= s.bestDayName %></span>
                  <span class="dash-today-label">najlepší deň</span>
                </div>
              </div>
            </div>
          </div>

          <%# --- REFERRERS --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-box-arrow-in-right" style="color:oklch(0.7 0.15 60);opacity:0.7"></i> Odkiaľ prichádzajú</h3>
            </div>
            <div class="dash-card-body dash-card-body-flush">
              <% if (s.topReferrers && s.topReferrers.length) { s.topReferrers.forEach(function(r,i){ %>
              <div class="dash-mini-row">
                <span class="dash-rank" style="background:oklch(0.7 0.15 60 / 0.12);color:oklch(0.7 0.15 60)"><%= i+1 %></span>
                <span style="flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:12px"><%= r.domain %></span>
                <strong style="color:var(--accent);font-size:12px"><%= fmt(r.cnt) %></strong>
              </div>
              <% }); } else { %>
              <div style="padding:16px;text-align:center;color:var(--text-subtle)">Väčšina návštev je priamych</div>
              <% } %>
            </div>
          </div>

          <%# --- TOP TAGS --- %>
          <div class="dash-card">
            <div class="dash-card-head">
              <h3><i class="bi bi-tags" style="color:oklch(0.65 0.19 260);opacity:0.7"></i> Top tagy</h3>
            </div>
            <div class="dash-card-body">
              <div style="display:flex;flex-wrap:wrap;gap:6px">
                <% if (s.topTags && s.topTags.length) { s.topTags.slice(0,10).forEach(function(t){ %>
                <span class="dash-tag">#<%= t.name %> <small><%= t.cnt %></small></span>
                <% }); } %>
              </div>
            </div>
          </div>

        </div>
      </div>
    </main>
  </div>
  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-dashboard-chart.js" defer></script>
</body>

</html>
