<!doctype html>
<html lang="sk" data-bs-theme="dark">

<head>
  <%- include('../partials/head', { title: 'Štatistiky' }) %>
  <link rel="stylesheet" href="/admin/static/css/admin-stats.css" />
</head>

<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: '/admin/stats' }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Štatistiky' }) %>

    <main class="bz-content bz-stats-scope">
      <div class="bz-dash-wrap">
        <%# Toolbar %>
        <div class="astats-toolbar">
          <div class="astats-toolbar-inner">
            <div>
              <span class="bz-eyebrow">Admin · Štatistiky</span>
              <h1 class="astats-title">Štatistický dashboard</h1>
              <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle)">
                karty · vlastné rozloženie
              </span>
            </div>
            <div class="astats-tools">
              <button class="bz-btn bz-btn-sm"><i class="bi bi-arrow-clockwise"></i> Obnoviť</button>
            </div>
          </div>

          <%# Category filters %>
          <%
          var groups = [
            { key: 'all', label: 'Všetko' },
            { key: 'obsah', label: 'Obsah', count: 16 },
            { key: 'recenzie', label: 'Recenzie', count: 8 },
            { key: 'komunita', label: 'Komunita', count: 13 },
            { key: 'navstevnost', label: 'Návštevnosť', count: 22 },
            { key: 'seo', label: 'SEO', count: 6 },
            { key: 'monetizacia', label: 'Monetizácia', count: 5 },
            { key: 'socialne', label: 'Sociálne siete', count: 4 },
            { key: 'bezpecnost', label: 'Bezpečnosť', count: 7 },
            { key: 'redakcia', label: 'Redakcia', count: 4 },
            { key: 'pokrocile', label: 'Pokročilé', count: 10 },
          ];
        %>
          <div class="astats-filters">
            <% groups.forEach(function(g) { %>
            <button class="astats-filter<%= g.key === 'all' ? ' active' : '' %>" data-filter="<%= g.key %>">
              <%= g.label %>
              <% if (g.count) { %>
              <span class="astats-filter-count"><%= g.count %></span>
              <% } %>
            </button>
            <% }) %>
          </div>
        </div>



        <%# Card grid %>
        <div class="astats-grid-wrap">
          <div class="astats-grid">

            <%# ===== OBSAH ===== %>
