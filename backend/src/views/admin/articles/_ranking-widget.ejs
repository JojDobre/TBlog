<%#
  Ranking widget — sidebar karta v editore článku
  Vloží sa do col-lg-4 v admin/articles/edit.ejs

  Premenné:
    articleRankings  — pole objektov z DB (ranking_items pre tento článok)
    csrfToken, isNew, article
%>
<div class="bz-art-side-card" id="ranking-widget">
  <div class="bz-art-side-head">
    <i class="bi bi-trophy" style="color:oklch(0.74 0.16 60)"></i> Rebríčky
  </div>
  <div class="bz-art-side-body">

    <% if (!isNew) { %>
      <input type="hidden" name="ranking_json" id="rw-json"
             value='<%- JSON.stringify(articleRankings || []).replace(/</g, "\\u003c").replace(/\x27/g, "&#39;") %>'>

      <!-- Existujúce rebríčky -->
      <div id="rw-entries"></div>

      <div id="rw-empty" style="display:none; font-family:var(--art-mono); font-size:11px; color:var(--art-text-subtle); text-align:center; padding:8px 0">
        Článok nie je v žiadnom rebríčku.
      </div>

      <!-- Pridať do rebríčka -->
      <div style="padding-top:10px; border-top:1px solid var(--art-border)">
        <label class="bz-art-field-label">Pridať do rebríčka</label>
        <div style="display:flex; gap:6px">
          <select class="form-select form-select-sm" id="rw-add-select">
            <option value="">— Vyber rebríček —</option>
          </select>
          <button type="button" class="bz-art-btn bz-art-btn-sm" id="rw-add-btn" disabled>
            <i class="bi bi-plus"></i>
          </button>
        </div>
      </div>
    <% } else { %>
      <p style="font-size:12px; color:var(--art-text-subtle); margin:0">
        Najprv ulož článok, potom ho budeš môcť pridať do rebríčka.
      </p>
    <% } %>

  </div>
</div>
