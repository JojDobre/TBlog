<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Články' }) %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Články' }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <%
          const successFlags = [
            [flash.created,  'Článok bol vytvorený.'],
            [flash.updated,  'Článok bol upravený.'],
            [flash.trashed,  'Článok presunutý do koša.'],
            [flash.restored, 'Článok obnovený.'],
            [flash.deleted,  'Článok permanentne zmazaný.'],
          ];
        %>
        <% successFlags.forEach(f => { if (f[0]) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i>
            <%= f[1] %>
            <button class="bz-art-alert-close" onclick="this.closest('.bz-art-alert').remove()" aria-label="Zatvoriť">×</button>
          </div>
        <% }}) %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <%= flash.err %>
            <button class="bz-art-alert-close" onclick="this.closest('.bz-art-alert').remove()" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Články</h1>
            <p class="bz-art-header-sub">Klasické články a recenzie · správa obsahu</p>
          </div>
          <a href="/admin/articles/new" class="bz-art-btn bz-art-btn-accent">
            <i class="bi bi-plus-lg"></i> Nový článok
          </a>
        </div>

        <!-- Status tabs -->
        <nav class="bz-art-status-tabs">
          <% tabs.forEach(t => { %>
            <a class="bz-art-status-tab <%= activeTab === t.key ? 'active' : '' %>"
               href="/admin/articles?tab=<%= t.key %><%= query.q ? '&q=' + encodeURIComponent(query.q) : '' %>">
              <%= t.label %>
              <span class="bz-art-status-tab-badge"><%= counts[t.key] || 0 %></span>
            </a>
          <% }) %>
        </nav>

        <!-- Search -->
        <form method="GET" action="/admin/articles" class="bz-art-search">
          <input type="hidden" name="tab" value="<%= activeTab %>">
          <div class="bz-art-search-wrap">
            <i class="bi bi-search bz-art-search-icon"></i>
            <input type="text" name="q" class="bz-art-search-input"
                   placeholder="Hľadať podľa názvu…" value="<%= query.q || '' %>"
                   autocomplete="off">
          </div>
          <button type="submit" class="bz-art-btn bz-art-btn-sm">Hľadať</button>
          <% if (query.q) { %>
            <a href="/admin/articles?tab=<%= activeTab %>" class="bz-art-btn bz-art-btn-sm bz-art-btn-ghost">
              <i class="bi bi-x-lg"></i> Vyčistiť
            </a>
          <% } %>
        </form>

        <!-- Content -->
        <% if (articles.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-file-earmark-text bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">
              <% if (query.q) { %>Žiadne články nezodpovedajú hľadaniu „<%= query.q %>".
              <% } else if (activeTab === 'trash') { %>Kôš je prázdny.
              <% } else if (activeTab === 'scheduled') { %>Žiadne naplánované články.
              <% } else if (activeTab === 'archived') { %>Žiadne archivované články.
              <% } else { %>Žiadne články zatiaľ. <a href="/admin/articles/new" style="color:var(--art-accent)">Vytvor prvý</a>.<% } %>
            </p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th>Názov</th>
                  <th style="width:100px">Typ</th>
                  <th style="width:120px">Stav</th>
                  <th style="width:160px">Čas</th>
                  <th style="width:130px">Autor</th>
                  <th style="width:140px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% articles.forEach(a => {
                  const statusMap = {
                    draft:     { cls: 'bz-art-badge-draft',     icon: 'pencil',        label: 'Draft' },
                    scheduled: { cls: 'bz-art-badge-scheduled', icon: 'clock',         label: 'Naplánovaný' },
                    published: { cls: 'bz-art-badge-published', icon: 'check-circle',  label: 'Publikovaný' },
                    archived:  { cls: 'bz-art-badge-archived',  icon: 'archive',       label: 'Archivovaný' },
                    trash:     { cls: 'bz-art-badge-trash',     icon: 'trash',         label: 'V koši' },
                  };
                  const sm = statusMap[a.status] || { cls: 'bz-art-badge-draft', icon: 'question', label: a.status };

                  let timeLabel = '—', timeHint = '';
                  if (a.status === 'scheduled' && a.scheduled_at) {
                    timeLabel = new Date(a.scheduled_at).toLocaleString('sk-SK');
                    timeHint = 'Naplánované';
                  } else if (a.status === 'published' && a.published_at) {
                    timeLabel = new Date(a.published_at).toLocaleDateString('sk-SK');
                    timeHint = 'Publikované';
                  } else if (a.updated_at) {
                    timeLabel = new Date(a.updated_at).toLocaleDateString('sk-SK');
                    timeHint = 'Upravené';
                  }
                %>
                <tr>
                  <td>
                    <a href="/admin/articles/<%= a.id %>/edit" class="bz-art-title-link">
                      <%= a.title %>
                      <% if (a.is_featured) { %><i class="bi bi-star-fill bz-art-featured-star" title="Featured"></i><% } %>
                    </a>
                    <span class="bz-art-slug-cell"><%= a.slug %></span>
                  </td>
                  <td>
                    <% if (a.type === 'review') { %>
                      <span class="bz-art-badge bz-art-badge-review"><i class="bi bi-star"></i> Recenzia</span>
                    <% } else { %>
                      <span class="bz-art-badge bz-art-badge-article"><i class="bi bi-file-text"></i> Článok</span>
                    <% } %>
                  </td>
                  <td>
                    <span class="bz-art-badge <%= sm.cls %>">
                      <i class="bi bi-<%= sm.icon %>"></i> <%= sm.label %>
                    </span>
                  </td>
                  <td>
                    <% if (timeHint) { %><span class="bz-art-time-label"><%= timeHint %></span><% } %>
                    <span class="bz-art-time-val"><%= timeLabel %></span>
                  </td>
                  <td style="font-size:13px; color:var(--art-text-muted)"><%= a.author_nickname || '—' %></td>
                  <td>
                    <div class="bz-art-row-actions">
                      <a href="/admin/articles/<%= a.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <% if (a.status === 'trash') { %>
                        <form method="POST" action="/admin/articles/<%= a.id %>/restore" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm" title="Obnoviť" style="color:oklch(.72 .16 150)">
                            <i class="bi bi-arrow-counterclockwise"></i>
                          </button>
                        </form>
                        <form method="POST" action="/admin/articles/<%= a.id %>/delete" class="d-inline"
                              data-confirm="Naozaj PERMANENTNE zmazať článok &quot;<%= a.title %>&quot;? Toto sa nedá vrátiť späť.">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Permanentne zmazať">
                            <i class="bi bi-x-lg"></i>
                          </button>
                        </form>
                      <% } else { %>
                        <form method="POST" action="/admin/articles/<%= a.id %>/trash" class="d-inline"
                              data-confirm="Presunúť článok &quot;<%= a.title %>&quot; do koša?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Do koša">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (p) => {
                const params = new URLSearchParams();
                params.set('tab', activeTab);
                if (query.q) params.set('q', query.q);
                if (p > 1) params.set('page', p);
                return '/admin/articles?' + params.toString();
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const showSet = new Set([1, tot, cur-1, cur, cur+1, cur-2, cur+2]);
              const pages = [...showSet].filter(p => p >= 1 && p <= tot).sort((a,b) => a-b);
            %>
            <div class="bz-art-pagination">
              <a class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>"
                 href="<%= cur > 1 ? buildHref(cur-1) : '#' %>">‹</a>
              <% pages.forEach((p, idx) => {
                if (idx > 0 && pages[idx-1] < p - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a class="bz-art-page-btn <%= p === cur ? 'active' : '' %>"
                   href="<%= buildHref(p) %>"><%= p %></a>
              <% }) %>
              <a class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>"
                 href="<%= cur < tot ? buildHref(cur+1) : '#' %>">›</a>
            </div>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
