<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Články' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% const successFlags = [
          [flash.created,  'Článok bol vytvorený.'],
          [flash.updated,  'Článok bol upravený.'],
          [flash.trashed,  'Článok presunutý do koša.'],
          [flash.restored, 'Článok obnovený.'],
          [flash.deleted,  'Článok permanentne zmazaný.'],
        ]; %>
        <% successFlags.forEach(f => { if (f[0]) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i><%= f[1] %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% }}) %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <div>
            <h1 class="h3 mb-1">Články</h1>
            <p class="text-muted mb-0 small">Klasické články a recenzie.</p>
          </div>
          <a href="/admin/articles/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nový článok
          </a>
        </div>

        <ul class="nav nav-tabs mb-3 flex-wrap">
          <% tabs.forEach(t => { %>
            <li class="nav-item">
              <a class="nav-link <%= activeTab === t.key ? 'active' : '' %>"
                 href="/admin/articles?tab=<%= t.key %><%= query.q ? '&q=' + encodeURIComponent(query.q) : '' %>">
                <%= t.label %>
                <span class="badge text-bg-light ms-1"><%= counts[t.key] || 0 %></span>
              </a>
            </li>
          <% }) %>
        </ul>

        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body">
            <form method="GET" action="/admin/articles" class="row g-2 align-items-center">
              <input type="hidden" name="tab" value="<%= activeTab %>">
              <div class="col-12 col-md">
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-search"></i></span>
                  <input type="text" name="q" class="form-control"
                         placeholder="Hľadať podľa názvu..." value="<%= query.q || '' %>">
                </div>
              </div>
              <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Hľadať</button>
                <% if (query.q) { %>
                  <a href="/admin/articles?tab=<%= activeTab %>" class="btn btn-outline-secondary">Vyčistiť</a>
                <% } %>
              </div>
            </form>
          </div>
        </div>

        <% if (articles.length === 0) { %>
          <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
              <i class="bi bi-file-earmark-text fs-1 d-block mb-2 text-body-tertiary"></i>
              <% if (query.q) { %>Žiadne články nezodpovedajú hľadaniu.
              <% } else if (activeTab === 'trash') { %>Kôš je prázdny.
              <% } else if (activeTab === 'scheduled') { %>Žiadne naplánované články.
              <% } else if (activeTab === 'archived') { %>Žiadne archivované články.
              <% } else { %>Žiadne články zatiaľ. Vytvor prvý cez tlačidlo vyššie.<% } %>
            </div>
          </div>
        <% } else { %>
          <div class="card border-0 shadow-sm">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Názov</th>
                    <th style="width: 90px;">Typ</th>
                    <th style="width: 130px;">Stav</th>
                    <th style="width: 170px;">Čas</th>
                    <th style="width: 140px;">Autor</th>
                    <th class="text-end" style="width: 200px;">Akcie</th>
                  </tr>
                </thead>
                <tbody>
                  <% articles.forEach(a => {
                    const statusMeta = {
                      draft:     { cls: 'text-bg-secondary', label: 'Draft',         icon: 'pencil' },
                      scheduled: { cls: 'text-bg-warning',   label: 'Naplánovaný',   icon: 'clock' },
                      published: { cls: 'text-bg-success',   label: 'Publikovaný',   icon: 'check-circle' },
                      archived:  { cls: 'text-bg-dark',      label: 'Archivovaný',   icon: 'archive' },
                      trash:     { cls: 'text-bg-danger',    label: 'V koši',        icon: 'trash' },
                    }[a.status] || { cls: 'text-bg-light', label: a.status, icon: 'question' };

                    let timeLabel = '—';
                    let timeHint = '';
                    if (a.status === 'scheduled' && a.scheduled_at) {
                      const d = new Date(a.scheduled_at);
                      timeLabel = d.toLocaleString('sk-SK');
                      timeHint = 'Naplánované';
                    } else if (a.status === 'published' && a.published_at) {
                      timeLabel = new Date(a.published_at).toLocaleDateString('sk-SK');
                      timeHint = 'Publikované';
                    } else if (a.updated_at) {
                      timeLabel = new Date(a.updated_at).toLocaleDateString('sk-SK');
                      timeHint = 'Upravené';
                    }
                  %>
                    <tr>
                      <td>
                        <a href="/admin/articles/<%= a.id %>/edit" class="text-decoration-none">
                          <strong><%= a.title %></strong>
                        </a>
                        <% if (a.is_featured) { %>
                          <i class="bi bi-star-fill text-warning ms-1" title="Featured"></i>
                        <% } %>
                        <div class="small text-muted"><code><%= a.slug %></code></div>
                      </td>
                      <td>
                        <% if (a.type === 'review') { %>
                          <span class="badge text-bg-info"><i class="bi bi-star me-1"></i>Recenzia</span>
                        <% } else { %>
                          <span class="badge text-bg-light">Článok</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="badge <%= statusMeta.cls %>">
                          <i class="bi bi-<%= statusMeta.icon %> me-1"></i><%= statusMeta.label %>
                        </span>
                      </td>
                      <td class="small text-muted">
                        <% if (timeHint) { %>
                          <div class="text-body-tertiary" style="font-size:0.7rem;text-transform:uppercase;letter-spacing:.04em;">
                            <%= timeHint %>
                          </div>
                        <% } %>
                        <%= timeLabel %>
                      </td>
                      <td class="small text-muted"><%= a.author_nickname || '—' %></td>
                      <td class="text-end">
                        <a href="/admin/articles/<%= a.id %>/edit"
                           class="btn btn-sm btn-outline-secondary" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <% if (a.status === 'trash') { %>
                          <form method="POST" action="/admin/articles/<%= a.id %>/restore" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-success" title="Obnoviť">
                              <i class="bi bi-arrow-counterclockwise"></i>
                            </button>
                          </form>
                          <form method="POST" action="/admin/articles/<%= a.id %>/delete" class="d-inline"
                                data-confirm="Naozaj PERMANENTNE zmazať článok &quot;<%= a.title %>&quot;? Toto sa nedá vrátiť späť.">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Permanentne zmazať">
                              <i class="bi bi-x-lg"></i>
                            </button>
                          </form>
                        <% } else { %>
                          <form method="POST" action="/admin/articles/<%= a.id %>/trash" class="d-inline"
                                data-confirm="Presunúť článok &quot;<%= a.title %>&quot; do koša?">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Do koša">
                              <i class="bi bi-trash"></i>
                            </button>
                          </form>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <nav class="mt-3">
              <ul class="pagination justify-content-center mb-0">
                <%
                  const buildHref = (p) => {
                    const params = new URLSearchParams();
                    params.set('tab', activeTab);
                    if (query.q) params.set('q', query.q);
                    if (p > 1) params.set('page', p);
                    return '/admin/articles?' + params.toString();
                  };
                  const cur = pagination.page; const tot = pagination.totalPages;
                  const show = new Set([1, tot, cur-1, cur, cur+1, cur-2, cur+2]);
                  const pages = [...show].filter(p => p >= 1 && p <= tot).sort((a,b) => a-b);
                %>
                <li class="page-item <%= cur <= 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur > 1 ? buildHref(cur-1) : '#' %>">‹</a>
                </li>
                <% pages.forEach((p, idx) => {
                  if (idx > 0 && pages[idx-1] < p - 1) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% } %>
                  <li class="page-item <%= p === cur ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildHref(p) %>"><%= p %></a>
                  </li>
                <% }) %>
                <li class="page-item <%= cur >= tot ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur < tot ? buildHref(cur+1) : '#' %>">›</a>
                </li>
              </ul>
            </nav>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
