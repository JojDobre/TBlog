<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Prihlásenie' }) %>
</head>
<body class="bz-auth-body">
  <main class="bz-auth-wrap">
    <div class="bz-auth-card">
      <div class="bz-auth-header">
        <i class="bi bi-hdd-stack bz-auth-logo"></i>
        <h1 class="h4 mb-0">Bytezone Admin</h1>
        <p class="text-muted small mt-1 mb-0">Prihlásenie do administrácie</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger" role="alert">
          <i class="bi bi-exclamation-triangle me-2"></i><%= error %>
        </div>
      <% } %>

      <% if (typeof info !== 'undefined' && info) { %>
        <div class="alert alert-info" role="alert">
          <i class="bi bi-info-circle me-2"></i><%= info %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login" autocomplete="on" novalidate>
        <div class="mb-3">
          <label for="nickname" class="form-label">Nickname</label>
          <input
            type="text"
            class="form-control"
            id="nickname"
            name="nickname"
            required
            autocomplete="username"
            autofocus
          />
        </div>
        <div class="mb-3">
          <label for="password" class="form-label">Heslo</label>
          <input
            type="password"
            class="form-control"
            id="password"
            name="password"
            required
            autocomplete="current-password"
          />
        </div>
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-box-arrow-in-right me-1"></i>
          Prihlásiť sa
        </button>
      </form>

      <div class="bz-auth-footer">
        <a href="/admin/forgot" class="text-muted small">Zabudnuté heslo?</a>
      </div>
    </div>

    <p class="text-muted small text-center mt-4">
      <a href="/" class="text-decoration-none">← Späť na web</a>
    </p>
  </main>

  <%- include('../partials/scripts') %>
</body>
</html>
