<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Zabudnuté heslo' }) %>
</head>
<body class="bz-auth-body">
  <main class="bz-auth-wrap">
    <div class="bz-auth-card" style="background:oklch(0.21 0.007 240); border:1px solid oklch(0.28 0.008 240); box-shadow:0 10px 40px oklch(0 0 0/0.4)">
      <div class="bz-auth-header">
        <div style="width:44px; height:44px; border-radius:12px; background:oklch(0.72 0.17 155); display:flex; align-items:center; justify-content:center; margin:0 auto 10px">
          <i class="bi bi-key" style="font-size:20px; color:oklch(0.14 0.04 155)"></i>
        </div>
        <h1 style="font-family:'Inter Tight',system-ui,sans-serif; font-size:20px; font-weight:800; letter-spacing:-0.03em; color:oklch(0.95 0.005 240); margin:0">Zabudnuté heslo</h1>
        <p style="font-family:'IBM Plex Mono',monospace; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:oklch(0.48 0.01 240); margin:6px 0 0">
          <% if (step === 'identify') { %>
            Identifikácia účtu
          <% } else { %>
            Bezpečnostná otázka
          <% } %>
        </p>
      </div>

      <% if (error) { %>
        <div class="bz-art-alert bz-art-alert-error" style="margin-bottom:16px">
          <i class="bi bi-exclamation-triangle-fill"></i> <%= error %>
        </div>
      <% } %>

      <% if (info) { %>
        <div class="bz-art-alert bz-art-alert-success" style="margin-bottom:16px">
          <i class="bi bi-info-circle-fill"></i> <%= info %>
        </div>
      <% } %>

      <% if (step === 'identify') { %>
        <form method="POST" action="/admin/forgot" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div style="margin-bottom:14px">
            <label for="nickname" class="bz-art-field-label">Nickname</label>
            <input
              type="text"
              class="form-control"
              id="nickname"
              name="nickname"
              value="<%= nickname %>"
              required
              autofocus
              maxlength="64"
              style="background:oklch(0.16 0.005 240); border-color:oklch(0.3 0.008 240); color:oklch(0.95 0.005 240)"
            />
            <span class="bz-art-hint" style="margin-top:4px">Po zadaní sa ti zobrazí tvoja bezpečnostná otázka.</span>
          </div>

          <button type="submit" class="bz-art-btn bz-art-btn-accent" style="width:100%; background:oklch(0.72 0.17 155); justify-content:center; padding:10px 16px; font-size:14px">
            Pokračovať <i class="bi bi-arrow-right"></i>
          </button>
        </form>

      <% } else if (step === 'reset') { %>
        <div style="background:oklch(0.16 0.005 240); border:1px solid oklch(0.28 0.008 240); border-radius:var(--art-r-md,10px); padding:10px 14px; margin-bottom:14px">
          <span style="font-family:'IBM Plex Mono',monospace; font-size:10px; text-transform:uppercase; letter-spacing:0.06em; color:oklch(0.48 0.01 240); display:block; margin-bottom:2px">Účet:</span>
          <strong style="font-size:14px; color:oklch(0.95 0.005 240)"><%= nickname %></strong>
        </div>

        <div style="margin-bottom:14px">
          <label class="bz-art-field-label">Bezpečnostná otázka</label>
          <p style="background:oklch(0.16 0.005 240); border:1px solid oklch(0.28 0.008 240); border-radius:var(--art-r-md,10px); padding:10px 14px; margin:0; font-size:13px; color:oklch(0.88 0.006 240)"><%= question %></p>
        </div>

        <form method="POST" action="/admin/forgot" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div style="margin-bottom:14px">
            <label for="answer" class="bz-art-field-label">Tvoja odpoveď</label>
            <input
              type="text"
              class="form-control"
              id="answer"
              name="answer"
              required
              autofocus
              autocomplete="off"
              style="background:oklch(0.16 0.005 240); border-color:oklch(0.3 0.008 240); color:oklch(0.95 0.005 240)"
            />
            <span class="bz-art-hint" style="margin-top:4px">Odpoveď nie je citlivá na veľkosť písmen ani medzery.</span>
          </div>

          <div style="height:1px; background:oklch(0.28 0.008 240); margin:18px 0"></div>

          <div style="margin-bottom:14px">
            <label for="password" class="bz-art-field-label">Nové heslo</label>
            <input
              type="password"
              class="form-control"
              id="password"
              name="password"
              required
              minlength="<%= minPasswordLength %>"
              maxlength="200"
              autocomplete="new-password"
              style="background:oklch(0.16 0.005 240); border-color:oklch(0.3 0.008 240); color:oklch(0.95 0.005 240)"
            />
            <span class="bz-art-hint" style="margin-top:4px">Minimálne <%= minPasswordLength %> znakov.</span>
          </div>

          <div style="margin-bottom:18px">
            <label for="password2" class="bz-art-field-label">Nové heslo (znova)</label>
            <input
              type="password"
              class="form-control"
              id="password2"
              name="password2"
              required
              minlength="<%= minPasswordLength %>"
              maxlength="200"
              autocomplete="new-password"
              style="background:oklch(0.16 0.005 240); border-color:oklch(0.3 0.008 240); color:oklch(0.95 0.005 240)"
            />
          </div>

          <button type="submit" class="bz-art-btn bz-art-btn-accent" style="width:100%; justify-content:center; padding:10px 16px; font-size:14px">
            <i class="bi bi-check-lg"></i> Zmeniť heslo
          </button>
        </form>

        <div style="text-align:center; margin-top:14px">
          <a href="/admin/forgot" style="font-size:12px; color:oklch(0.55 0.01 240); text-decoration:none">← Začať odznova</a>
        </div>
      <% } %>

      <div style="margin-top:18px; text-align:center; border-top:1px solid oklch(0.28 0.008 240); padding-top:14px">
        <a href="/admin/login" style="font-size:12px; color:oklch(0.55 0.01 240); text-decoration:none">← Späť na prihlásenie</a>
      </div>
    </div>

    <p style="text-align:center; margin-top:20px">
      <a href="/" style="font-size:12px; color:oklch(0.5 0.01 240); text-decoration:none">← Späť na web</a>
    </p>
  </main>

  <%- include('../partials/scripts') %>
</body>
</html>
