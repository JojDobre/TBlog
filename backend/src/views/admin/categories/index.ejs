<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Kategórie' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Kategória bola vytvorená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Kategória bola upravená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Kategória bola zmazaná.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Kategórie</h1>
            <p class="bz-art-header-sub">Hierarchická štruktúra produktových oblastí (napr. Telefóny → Android → Samsung).</p>
          </div>
          <a href="/admin/categories/new" class="bz-art-btn bz-art-btn-accent">
            <i class="bi bi-plus-lg"></i> Nová kategória
          </a>
        </div>

        <% if (tree.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-diagram-3 bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">Žiadne kategórie. Vytvor prvú cez tlačidlo vyššie.</p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th>Názov</th>
                  <th>Slug / cesta</th>
                  <th style="width:110px; text-align:center">Podkategórie</th>
                  <th style="width:90px; text-align:center">Články</th>
                  <th style="width:80px; text-align:center">Poradie</th>
                  <th style="width:200px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% tree.forEach(c => { %>
                  <tr>
                    <td>
                      <span class="bz-cat-row" style="--bz-cat-depth: <%= c.depth %>;">
                        <% if (c.depth > 0) { %>
                          <span class="bz-cat-tree-marker" aria-hidden="true">└─</span>
                        <% } %>
                        <strong style="color:var(--art-text); font-size:13.5px"><%= c.name %></strong>
                      </span>
                    </td>
                    <td>
                      <span class="bz-art-slug-cell"><%= c.path %></span>
                    </td>
                    <td style="text-align:center">
                      <% if (c.child_count > 0) { %>
                        <span class="bz-art-badge bz-art-badge-review"><%= c.child_count %></span>
                      <% } else { %>
                        <span style="color:var(--art-text-subtle)">—</span>
                      <% } %>
                    </td>
                    <td style="text-align:center">
                      <span class="bz-art-badge bz-art-badge-article"><%= c.article_count %></span>
                    </td>
                    <td style="text-align:center">
                      <span class="bz-art-badge bz-art-badge-article"><%= c.display_order %></span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions">
                        <a href="/admin/categories/new?parent=<%= c.id %>" class="bz-art-btn bz-art-btn-sm" title="Pridať podkategóriu">
                          <i class="bi bi-plus"></i>
                        </a>
                        <a href="/admin/categories/<%= c.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/admin/categories/<%= c.id %>/delete" class="d-inline"
                              data-confirm="Naozaj zmazať kategóriu &quot;<%= c.name %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať"
                                  <%= (c.child_count > 0 || c.article_count > 0) ? 'disabled' : '' %>>
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

        <p class="bz-art-hint" style="margin-top:14px">
          <i class="bi bi-info-circle"></i>
          Mazanie je zablokované, ak má kategória podkategórie alebo články. Bez limitu hĺbky;
          úplná cesta (path) má v DB max 500 znakov.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
