<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Kategórie' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% if (flash.created) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Kategória bola vytvorená.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Kategória bola upravená.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Kategória bola zmazaná.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <div>
            <h1 class="h3 mb-1">Kategórie</h1>
            <p class="text-muted mb-0 small">
              Hierarchická štruktúra produktových oblastí (napr. Telefóny → Android → Samsung).
            </p>
          </div>
          <a href="/admin/categories/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nová kategória
          </a>
        </div>

        <% if (tree.length === 0) { %>
          <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
              <i class="bi bi-diagram-3 fs-1 d-block mb-2 text-body-tertiary"></i>
              Žiadne kategórie. Vytvor prvú cez tlačidlo vyššie.
            </div>
          </div>
        <% } else { %>
          <div class="card border-0 shadow-sm">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Názov</th>
                    <th>Slug / cesta</th>
                    <th class="text-center" style="width: 110px;">Podkategórie</th>
                    <th class="text-center" style="width: 90px;">Články</th>
                    <th class="text-center" style="width: 80px;">Poradie</th>
                    <th class="text-end" style="width: 200px;">Akcie</th>
                  </tr>
                </thead>
                <tbody>
                  <% tree.forEach(c => { %>
                    <tr>
                      <td>
                        <span class="bz-cat-row" style="--bz-cat-depth: <%= c.depth %>;">
                          <% if (c.depth > 0) { %>
                            <span class="bz-cat-tree-marker" aria-hidden="true">└─</span>
                          <% } %>
                          <strong><%= c.name %></strong>
                        </span>
                      </td>
                      <td>
                        <code class="small text-muted"><%= c.path %></code>
                      </td>
                      <td class="text-center">
                        <% if (c.child_count > 0) { %>
                          <span class="badge text-bg-info"><%= c.child_count %></span>
                        <% } else { %>
                          <span class="text-body-tertiary">—</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <span class="badge text-bg-secondary"><%= c.article_count %></span>
                      </td>
                      <td class="text-center">
                        <span class="badge text-bg-light"><%= c.display_order %></span>
                      </td>
                      <td class="text-end">
                        <a
                          href="/admin/categories/new?parent=<%= c.id %>"
                          class="btn btn-sm btn-outline-primary"
                          title="Pridať podkategóriu"
                        >
                          <i class="bi bi-plus"></i>
                        </a>
                        <a
                          href="/admin/categories/<%= c.id %>/edit"
                          class="btn btn-sm btn-outline-secondary"
                          title="Upraviť"
                        >
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form
                          method="POST"
                          action="/admin/categories/<%= c.id %>/delete"
                          class="d-inline"
                          data-confirm="Naozaj zmazať kategóriu &quot;<%= c.name %>&quot;?"
                        >
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button
                            type="submit"
                            class="btn btn-sm btn-outline-danger"
                            title="Zmazať"
                            <%= (c.child_count > 0 || c.article_count > 0) ? 'disabled' : '' %>
                          >
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>

        <p class="text-muted small mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i>
          Mazanie je zablokované, ak má kategória podkategórie alebo články. Bez limitu hĺbky;
          úplná cesta (path) má v DB max 500 znakov.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
