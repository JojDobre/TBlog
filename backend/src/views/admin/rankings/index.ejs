<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Rebríčky' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Rebríčky' }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rebríček bol vytvorený.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rebríček bol upravený.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rebríček bol zmazaný.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Rebríčky</h1>
            <p class="bz-art-header-sub">Správa rebríčkov produktov</p>
          </div>
          <a href="/admin/rankings/new" class="bz-art-btn bz-art-btn-accent">
            <i class="bi bi-plus-lg"></i> Nový rebríček
          </a>
        </div>

        <% if (rankings.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-trophy bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">Žiadne rebríčky. Vytvor prvý cez tlačidlo vyššie.</p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th>Názov</th>
                  <th style="width:100px">Stav</th>
                  <th style="width:100px; text-align:center">Položky</th>
                  <th style="width:120px">Radenie</th>
                  <th style="width:160px">Vytvorený</th>
                  <th style="width:160px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% rankings.forEach(r => { %>
                  <tr>
                    <td>
                      <a href="/admin/rankings/<%= r.id %>/edit" class="bz-art-title-link">
                        <i class="bi bi-trophy" style="color:oklch(0.74 0.16 60); margin-right:6px;"></i>
                        <%= r.name %>
                      </a>
                      <span class="bz-art-slug-cell"><%= r.slug %></span>
                    </td>
                    <td>
                      <% if (r.status === 'active') { %>
                        <span class="bz-art-badge bz-art-badge-published">
                          <i class="bi bi-check-circle"></i> Aktívny
                        </span>
                      <% } else { %>
                        <span class="bz-art-badge bz-art-badge-archived">
                          <i class="bi bi-archive"></i> Archivovaný
                        </span>
                      <% } %>
                    </td>
                    <td style="text-align:center">
                      <span class="bz-art-badge bz-art-badge-article"><%= r.item_count %></span>
                    </td>
                    <td>
                      <% if (r.admin_override) { %>
                        <span class="bz-art-meta-text"><i class="bi bi-hand-index me-1"></i>Ručné</span>
                      <% } else { %>
                        <span class="bz-art-meta-text"><i class="bi bi-sort-numeric-down me-1"></i>Podľa skóre</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="bz-art-meta-text">
                        <%= new Date(r.created_at).toLocaleDateString('sk-SK') %>
                      </span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions">
                        <a href="/admin/rankings/<%= r.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/admin/rankings/<%= r.id %>/delete" class="d-inline"
                              data-confirm="Naozaj zmazať rebríček &quot;<%= r.name %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
