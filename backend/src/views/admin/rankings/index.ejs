<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Rebríčky' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Rebríčky' }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% if (flash.created) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rebríček bol vytvorený.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rebríček bol upravený.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rebríček bol zmazaný.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="d-flex align-items-center justify-content-between mb-4">
          <div>
            <h1 class="h3 mb-1">Rebríčky</h1>
            <p class="text-muted mb-0">Správa rebríčkov produktov</p>
          </div>
          <a href="/admin/rankings/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nový rebríček
          </a>
        </div>

        <% if (rankings.length === 0) { %>
          <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
              <i class="bi bi-trophy fs-1 d-block mb-2 text-body-tertiary"></i>
              Žiadne rebríčky. Vytvor prvý cez tlačidlo vyššie.
            </div>
          </div>
        <% } else { %>
          <div class="card border-0 shadow-sm">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Názov</th>
                    <th style="width:100px">Stav</th>
                    <th class="text-center" style="width:100px">Položky</th>
                    <th style="width:120px">Radenie</th>
                    <th style="width:160px">Vytvorený</th>
                    <th class="text-end" style="width:160px">Akcie</th>
                  </tr>
                </thead>
                <tbody>
                  <% rankings.forEach(r => { %>
                    <tr>
                      <td>
                        <a href="/admin/rankings/<%= r.id %>/edit" class="fw-semibold text-decoration-none">
                          <i class="bi bi-trophy me-1 text-warning"></i>
                          <%= r.name %>
                        </a>
                        <br>
                        <code class="small text-muted"><%= r.slug %></code>
                      </td>
                      <td>
                        <% if (r.status === 'active') { %>
                          <span class="badge text-bg-success">Aktívny</span>
                        <% } else { %>
                          <span class="badge text-bg-secondary">Archivovaný</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <span class="badge text-bg-info"><%= r.item_count %></span>
                      </td>
                      <td>
                        <% if (r.admin_override) { %>
                          <span class="small text-muted"><i class="bi bi-hand-index me-1"></i>Ručné</span>
                        <% } else { %>
                          <span class="small text-muted"><i class="bi bi-sort-numeric-down me-1"></i>Podľa skóre</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="small text-muted">
                          <%= new Date(r.created_at).toLocaleDateString('sk-SK') %>
                        </span>
                      </td>
                      <td class="text-end">
                        <a href="/admin/rankings/<%= r.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/admin/rankings/<%= r.id %>/delete" class="d-inline"
                              data-confirm="Naozaj zmazať rebríček &quot;<%= r.name %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
