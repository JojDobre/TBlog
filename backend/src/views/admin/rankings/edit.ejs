<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: pageTitle }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div
  class="bz-main"
  id="ranking-edit-root"
  data-ranking-id="<%= ranking.id %>"
  data-csrf="<%= csrfToken %>">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <nav aria-label="breadcrumb" class="mb-3">
          <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/rankings">Rebríčky</a></li>
            <li class="breadcrumb-item active"><%= isNew ? 'Nový' : ranking.name %></li>
          </ol>
        </nav>

        <% if (typeof flash !== 'undefined' && flash && flash.created) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rebríček vytvorený. Teraz pridaj kritériá.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (typeof flash !== 'undefined' && flash && flash.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Zmeny uložené.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (Object.keys(errors).length > 0) { %>
          <div class="alert alert-danger" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>Skontroluj chyby vo formulári.
          </div>
        <% } %>

        <!-- ============================================================
             RANKING FORM
             ============================================================ -->
        <form method="POST"
              action="<%= isNew ? '/admin/rankings' : ('/admin/rankings/' + ranking.id) %>"
              novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">

          <div class="row g-4">
            <!-- Left column — main fields -->
            <div class="col-lg-8">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                  <div class="mb-3">
                    <label for="name" class="form-label">Názov rebríčka <span class="text-danger">*</span></label>
                    <input type="text" class="form-control form-control-lg <%= errors.name ? 'is-invalid' : '' %>"
                           id="name" name="name" value="<%= ranking.name %>" maxlength="160" required>
                    <% if (errors.name) { %><div class="invalid-feedback"><%= errors.name %></div><% } %>
                  </div>

                  <div class="mb-3">
                    <label for="slug" class="form-label">Slug</label>
                    <input type="text" class="form-control" id="slug" name="slug"
                           value="<%= ranking.slug %>" maxlength="180"
                           placeholder="automaticky z názvu">
                    <div class="form-text">Ponechaj prázdne pre automatické vygenerovanie.</div>
                  </div>

                  <div class="mb-3">
                    <label for="description" class="form-label">Popis</label>
                    <textarea class="form-control" id="description" name="description"
                              rows="3" maxlength="5000"><%= ranking.description || '' %></textarea>
                  </div>
                </div>
              </div>

              <!-- SEO -->
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent">
                  <h6 class="mb-0"><i class="bi bi-search me-2"></i>SEO</h6>
                </div>
                <div class="card-body">
                  <div class="mb-3">
                    <label for="seo_title" class="form-label">SEO titulok</label>
                    <input type="text" class="form-control" id="seo_title" name="seo_title"
                           value="<%= ranking.seo_title || '' %>" maxlength="255">
                  </div>
                  <div class="mb-0">
                    <label for="seo_description" class="form-label">SEO popis</label>
                    <textarea class="form-control" id="seo_description" name="seo_description"
                              rows="2" maxlength="320"><%= ranking.seo_description || '' %></textarea>
                  </div>
                </div>
              </div>
            </div>

            <!-- Right column — settings -->
            <div class="col-lg-4">
              <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent">
                  <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Nastavenia</h6>
                </div>
                <div class="card-body">
                  <div class="mb-3">
                    <label for="status" class="form-label">Stav</label>
                    <select class="form-select" id="status" name="status">
                      <option value="active" <%= ranking.status === 'active' ? 'selected' : '' %>>Aktívny</option>
                      <option value="archived" <%= ranking.status === 'archived' ? 'selected' : '' %>>Archivovaný</option>
                    </select>
                  </div>

                  <div class="mb-3">
                    <label for="sort_direction" class="form-label">Smer zoradenia</label>
                    <select class="form-select" id="sort_direction" name="sort_direction">
                      <option value="desc" <%= ranking.sort_direction === 'desc' ? 'selected' : '' %>>Zostupne (najvyššie skóre hore)</option>
                      <option value="asc" <%= ranking.sort_direction === 'asc' ? 'selected' : '' %>>Vzostupne (najnižšie skóre hore)</option>
                    </select>
                  </div>

                  <div class="mb-3">
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" id="admin_override"
                             name="admin_override" value="1"
                             <%= ranking.admin_override ? 'checked' : '' %>>
                      <label class="form-check-label" for="admin_override">
                        Ručné poradie (drag & drop)
                      </label>
                    </div>
                    <div class="form-text">Ak zapnuté, poradie sa riadi ručne namiesto skóre.</div>
                  </div>

                  <div class="mb-0">
                    <label for="max_age_months" class="form-label">Max. vek článkov (mesiace)</label>
                    <input type="number" class="form-control <%= errors.max_age_months ? 'is-invalid' : '' %>"
                           id="max_age_months" name="max_age_months"
                           value="<%= ranking.max_age_months || '' %>" min="1" placeholder="bez limitu">
                    <% if (errors.max_age_months) { %><div class="invalid-feedback"><%= errors.max_age_months %></div><% } %>
                    <div class="form-text">Prázdne = zobrazujú sa všetky.</div>
                  </div>
                </div>
              </div>

              <!-- Actions -->
              <div class="d-grid gap-2">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check-lg me-1"></i>
                  <%= isNew ? 'Vytvoriť rebríček' : 'Uložiť zmeny' %>
                </button>
                <a href="/admin/rankings" class="btn btn-outline-secondary">Späť na zoznam</a>
              </div>
            </div>
          </div>
        </form>

        <% if (!isNew) { %>
        <!-- ============================================================
             CRITERIA SECTION
             ============================================================ -->
        <div class="card border-0 shadow-sm mt-4" id="criteria-section">
          <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
            <h6 class="mb-0"><i class="bi bi-sliders me-2"></i>Kritériá hodnotenia</h6>
            <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#criterionModal"
                    id="open-criterion-btn">
              <i class="bi bi-plus-lg me-1"></i>Pridať kritérium
            </button>
          </div>
          <div class="card-body p-0">
            <% if (criteria.length === 0) { %>
              <div class="text-center text-muted py-4">
                <i class="bi bi-sliders d-block fs-3 mb-2 text-body-tertiary"></i>
                Žiadne kritériá. Pridaj prvé cez tlačidlo vyššie.
              </div>
            <% } else { %>
              <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="criteria-table">
                  <thead class="table-light">
                    <tr>
                      <th style="width:40px"></th>
                      <th>Názov</th>
                      <th style="width:130px">Typ</th>
                      <th style="width:80px">Jednotka</th>
                      <th class="text-center" style="width:90px">Filtrovateľné</th>
                      <th class="text-center" style="width:90px">Celkové</th>
                      <th class="text-end" style="width:120px">Akcie</th>
                    </tr>
                  </thead>
                  <tbody id="criteria-tbody">
                    <% criteria.forEach((c, idx) => { %>
                      <tr data-criterion-id="<%= c.id %>">
                        <td class="text-center text-muted" style="cursor:grab" title="Pretiahni na preradenie">
                          <i class="bi bi-grip-vertical"></i>
                        </td>
                        <td class="fw-medium"><%= c.name %></td>
                        <td>
                          <span class="badge text-bg-light"><%= c.field_type %></span>
                        </td>
                        <td class="text-muted small"><%= c.unit || '—' %></td>
                        <td class="text-center">
                          <% if (c.is_filterable) { %>
                            <i class="bi bi-check-circle-fill text-success"></i>
                          <% } else { %>
                            <span class="text-body-tertiary">—</span>
                          <% } %>
                        </td>
                        <td class="text-center">
                          <% if (c.is_total) { %>
                            <i class="bi bi-star-fill text-warning"></i>
                          <% } else { %>
                            <span class="text-body-tertiary">—</span>
                          <% } %>
                        </td>
                        <td class="text-end">
                          <button
                            type="button"
                            class="btn btn-sm btn-outline-secondary btn-edit-criterion"
                            title="Upraviť"
                            data-criterion='<%- JSON.stringify(c) %>'>
                            <i class="bi bi-pencil"></i>
                          </button>
                          <button
                          type="button"
                          class="btn btn-sm btn-outline-danger btn-delete-criterion"
                          title="Zmazať"
                          data-id="<%= c.id %>"
                          data-name="<%= c.name %>">
                          <i class="bi bi-trash"></i>
                        </button>

                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>
            <% } %>
          </div>
        </div>

            <!-- ============================================================
             ITEMS SECTION — interaktívna správa položiek
             ============================================================ -->
        <div class="card border-0 shadow-sm mt-4">
          <div class="card-header bg-transparent d-flex align-items-center justify-content-between">
            <h6 class="mb-0">
              <i class="bi bi-list-ol me-2"></i>Položky v rebríčku
              (<%= typeof items !== 'undefined' ? items.length : 0 %>)
            </h6>
            <% if (criteria.length > 0) { %>
              <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addItemPanel">
                <i class="bi bi-plus-lg me-1"></i>Pridať položku
              </button>
            <% } else { %>
              <span class="text-muted small">Najprv pridaj kritériá</span>
            <% } %>
          </div>

          <% if (criteria.length > 0) { %>
          <!-- Add item panel (collapsible) -->
          <div class="collapse" id="addItemPanel">
            <div class="card-body border-bottom bg-light">
              <div id="add-item-form">

                <!-- Tabs: Článok / Vlastný produkt -->
                <ul class="nav nav-tabs nav-tabs-sm mb-3">
                  <li class="nav-item">
                    <button type="button" class="nav-link active" id="tab-item-article">
                      <i class="bi bi-file-earmark-text me-1"></i>Článok / Recenzia
                    </button>
                  </li>
                  <li class="nav-item">
                    <button type="button" class="nav-link" id="tab-item-custom">
                      <i class="bi bi-box-seam me-1"></i>Vlastný produkt
                    </button>
                  </li>
                </ul>

                <!-- Panel: vyhľadanie článku -->
                <div id="item-article-panel">
                  <input type="hidden" name="article_id" id="item-article-id" value="">
                  <div class="mb-3 position-relative">
                    <label class="form-label small">Vyhľadať článok</label>
                    <input type="text" class="form-control" id="item-article-search"
                           placeholder="Začni písať názov článku…" autocomplete="off">
                    <div id="item-search-results"
                         class="dropdown-menu w-100 shadow-sm"
                         style="display:none; position:absolute; z-index:10; max-height:260px; overflow-y:auto;">
                    </div>
                  </div>
                  <div id="item-selected-article" class="mb-3"></div>
                </div>

                <!-- Panel: vlastný produkt -->
                <div id="item-custom-panel" style="display:none">
                  <div class="row g-3 mb-3">
                    <div class="col-md-8">
                      <label class="form-label small">Názov produktu <span class="text-danger">*</span></label>
                      <input type="text" class="form-control" name="custom_name" maxlength="200" placeholder="napr. Samsung Galaxy S26 Ultra">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label small">Značka</label>
                      <input type="text" class="form-control" name="custom_brand" maxlength="100" placeholder="napr. Samsung">
                    </div>
                  </div>
                </div>

                <!-- Hodnoty kritérií -->
                <div class="row g-2 mb-3">
                  <% criteria.forEach(c => { %>
                    <div class="col-md-3 col-sm-4">
                      <label class="form-label small mb-1"><%= c.name %> <% if (c.unit) { %><span class="text-muted">(<%= c.unit %>)</span><% } %></label>
                      <input type="<%= ['score_1_10','decimal','integer','price'].includes(c.field_type) ? 'number' : 'text' %>"
                             class="form-control form-control-sm" name="crit_<%= c.id %>"
                             <% if (c.field_type === 'score_1_10') { %>min="1" max="10" step="0.1"<% } %>
                             <% if (c.field_type === 'decimal' || c.field_type === 'price') { %>step="0.01"<% } %>
                             placeholder="<%= c.field_type === 'score_1_10' ? '1–10' : '' %>">
                    </div>
                  <% }) %>
                </div>

                <div class="row g-2 mb-3">
                  <div class="col-md-3">
                    <label class="form-label small mb-1">Celkové skóre (override)</label>
                    <input type="number" class="form-control form-control-sm" name="override_score"
                           min="0" max="10" step="0.1" placeholder="auto priemer">
                  </div>
                </div>

                <div id="item-add-errors" class="alert alert-danger py-2 small" style="display:none"></div>
                <button type="button" class="btn btn-primary btn-sm" id="add-item-btn">
                  <i class="bi bi-plus-lg me-1"></i>Pridať do rebríčka
                </button>
              </div>
            </div>
          </div>
          <% } %>

          <!-- Items table -->
          <% if (typeof items !== 'undefined' && items.length > 0) { %>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th style="width:40px"></th>
                    <th style="width:50px">#</th>
                    <th>Produkt</th>
                    <th style="width:90px">Typ</th>
                    <th class="text-center" style="width:90px">Skóre</th>
                    <% criteria.forEach(c => { %>
                      <th class="text-center small" style="width:80px"><%= c.name %></th>
                    <% }) %>
                    <th class="text-end" style="width:110px">Akcie</th>
                  </tr>
                </thead>
                <tbody id="items-tbody">
                  <% items.forEach((item, idx) => { %>
                    <tr data-item-id="<%= item.id %>">
                      <td class="text-center text-muted" title="Pretiahni na preradenie">
                        <i class="bi bi-grip-vertical"></i>
                      </td>
                      <td class="fw-bold text-muted item-rank-num"><%= idx + 1 %></td>
                      <td>
                        <div class="fw-medium">
                          <% if (item.display_brand) { %>
                            <span class="text-muted small"><%= item.display_brand %></span>
                          <% } %>
                          <%= item.display_name || '(bez názvu)' %>
                        </div>
                        <% if (item.article_id) { %>
                          <a href="/admin/articles/<%= item.article_id %>/edit" class="small text-decoration-none">
                            <i class="bi bi-link-45deg"></i> Otvoriť článok
                          </a>
                        <% } else { %>
                          <span class="small text-muted"><i class="bi bi-box-seam"></i> Vlastný produkt</span>
                        <% } %>
                      </td>
                      <td>
                        <% if (item.article_id) { %>
                          <span class="badge text-bg-primary"><%= item.article_type === 'review' ? 'Recenzia' : 'Článok' %></span>
                        <% } else { %>
                          <span class="badge text-bg-secondary">Produkt</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <% if (item.computed_score !== null) { %>
                          <span class="badge fs-6 <%= item.computed_score >= 8 ? 'text-bg-success' : item.computed_score >= 6 ? 'text-bg-warning' : 'text-bg-danger' %>">
                            <%= item.computed_score.toFixed(1) %>
                          </span>
                          <% if (item.override_score !== null && item.override_score !== undefined) { %>
                            <br><span class="small text-muted">(ručné)</span>
                          <% } %>
                        <% } else { %>
                          <span class="text-body-tertiary">—</span>
                        <% } %>
                      </td>
                      <% criteria.forEach(c => {
                        const val = item.values.find(v => Number(v.criterion_id) === c.id);
                      %>
                        <td class="text-center small">
                          <% if (val && val.value_decimal !== null) { %>
                            <%= Number(val.value_decimal).toFixed(1) %>
                          <% } else if (val && val.value_text) { %>
                            <%= val.value_text %>
                          <% } else { %>
                            <span class="text-body-tertiary">—</span>
                          <% } %>
                        </td>
                      <% }) %>
                      <td class="text-end">
                        <button type="button" class="btn btn-sm btn-outline-secondary btn-edit-item" title="Upraviť"
                                data-item-id="<%= item.id %>"
                                data-custom-name="<%= item.custom_name || '' %>"
                                data-custom-brand="<%= item.custom_brand || '' %>"
                                data-override-score="<%= item.override_score != null ? item.override_score : '' %>"
                                <% criteria.forEach(c => {
                                  const val = item.values.find(v => Number(v.criterion_id) === c.id);
                                  const numVal = val && val.value_decimal != null ? Number(val.value_decimal) : '';
                                  const txtVal = val && val.value_text ? val.value_text : '';
                                %>data-crit<%= c.id %>="<%= numVal || txtVal %>"<% }) %>>
                          <i class="bi bi-pencil"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-danger btn-delete-item" title="Odobrať"
                                data-item-id="<%= item.id %>"
                                data-name="<%= (item.display_name || '').replace(/"/g, '&quot;') %>">
                          <i class="bi bi-trash"></i>
                        </button>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
          <% } else if (typeof items !== 'undefined' && items.length === 0 && criteria.length > 0) { %>
          <div class="card-body text-center text-muted py-4">
            <i class="bi bi-inbox d-block fs-3 mb-2 text-body-tertiary"></i>
            Žiadne položky. Pridaj prvú cez tlačidlo vyššie.
          </div>
          <% } %>
        </div>

        <!-- ============================================================
             EDIT ITEM MODAL
             ============================================================ -->
        <div class="modal fade" id="editItemModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Upraviť položku</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <div id="edit-item-form">
                  <input type="hidden" id="edit-item-id" value="">
                  <div class="row g-3 mb-3">
                    <div class="col-md-8">
                      <label class="form-label">Názov (vlastný produkt)</label>
                      <input type="text" class="form-control" id="edit-custom-name" name="custom_name" maxlength="200">
                    </div>
                    <div class="col-md-4">
                      <label class="form-label">Značka</label>
                      <input type="text" class="form-control" id="edit-custom-brand" name="custom_brand" maxlength="100">
                    </div>
                  </div>
                  <div class="row g-2 mb-3" id="edit-criteria-values">
                    <% criteria.forEach(c => { %>
                      <div class="col-md-4 col-6">
                        <label class="form-label small mb-1"><%= c.name %></label>
                        <input type="<%= ['score_1_10','decimal','integer','price'].includes(c.field_type) ? 'number' : 'text' %>"
                               class="form-control form-control-sm" name="crit_<%= c.id %>" data-edit-crit="<%= c.id %>"
                               <% if (c.field_type === 'score_1_10') { %>min="1" max="10" step="0.1"<% } %>
                               <% if (c.field_type === 'decimal' || c.field_type === 'price') { %>step="0.01"<% } %>>
                      </div>
                    <% }) %>
                  </div>
                  <div class="mb-0">
                    <label class="form-label small mb-1">Celkové skóre (override)</label>
                    <input type="number" class="form-control form-control-sm" id="edit-override-score"
                           name="override_score" min="0" max="10" step="0.1" placeholder="auto priemer" style="max-width:150px">
                  </div>
                </div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušiť</button>
                <button type="button" class="btn btn-primary" id="save-edit-item">
                  <i class="bi bi-check-lg me-1"></i>Uložiť
                </button>
              </div>
            </div>
          </div>
        </div>


        <!-- ============================================================
             CRITERION MODAL
             ============================================================ -->
        <div class="modal fade" id="criterionModal" tabindex="-1" aria-hidden="true">
          <div class="modal-dialog">
            <div class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title" id="criterionModalTitle">Pridať kritérium</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <input type="hidden" id="crit-id" value="">
                <div class="mb-3">
                  <label for="crit-name" class="form-label">Názov <span class="text-danger">*</span></label>
                  <input type="text" class="form-control" id="crit-name" maxlength="80" placeholder="napr. Displej, Batéria, Výkon…">
                </div>
                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="crit-field-type" class="form-label">Typ hodnoty</label>
                    <select class="form-select" id="crit-field-type">
                      <option value="score_1_10">Skóre 1–10</option>
                      <option value="decimal">Desatinné číslo</option>
                      <option value="integer">Celé číslo</option>
                      <option value="price">Cena</option>
                      <option value="date">Dátum</option>
                      <option value="text">Text</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label for="crit-unit" class="form-label">Jednotka</label>
                    <input type="text" class="form-control" id="crit-unit" maxlength="20" placeholder="napr. €, mAh, palcov">
                  </div>
                </div>
                <div class="mt-3 d-flex gap-4">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="crit-filterable">
                    <label class="form-check-label" for="crit-filterable">Filtrovateľné</label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="crit-total">
                    <label class="form-check-label" for="crit-total">Celkové skóre</label>
                  </div>
                </div>
                <div id="crit-errors" class="text-danger small mt-2" style="display:none"></div>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Zrušiť</button>
                <button type="button" class="btn btn-primary" id="crit-save-btn">
                  <i class="bi bi-check-lg me-1"></i>Uložiť
                </button>
              </div>
            </div>
          </div>
        </div>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>

  <% if (!isNew) { %>
    <script src="/admin/static/js/admin-ranking-edit.js" defer></script>
  <% } %>
</body>
</html>
