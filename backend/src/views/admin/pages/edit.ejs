<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: pageTitle }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (typeof flash !== 'undefined' && flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Stránka vytvorená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (typeof flash !== 'undefined' && flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Zmeny uložené.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (Object.keys(errors).length > 0) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> Skontroluj chyby vo formulári nižšie.
          </div>
        <% } %>

        <!-- Breadcrumb + actions -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; flex-wrap:wrap; gap:10px">
          <div class="bz-art-breadcrumb">
            <a href="/admin/dashboard">Admin</a>
            <span class="bz-art-breadcrumb-sep">›</span>
            <a href="/admin/pages">Stránky</a>
            <span class="bz-art-breadcrumb-sep">›</span>
            <span class="bz-art-breadcrumb-current"><%= isNew ? 'Nová' : pg.title %></span>
          </div>
          <div style="display:flex; gap:8px">
            <a href="/admin/pages" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-arrow-left"></i> Späť</a>
            <button type="submit" form="page-form" class="bz-art-btn bz-art-btn-sm bz-art-btn-accent">
              <i class="bi bi-check-lg"></i> <%= isNew ? 'Vytvoriť' : 'Uložiť zmeny' %>
            </button>
          </div>
        </div>

        <form id="page-form" method="POST"
              action="<%= isNew ? '/admin/pages' : '/admin/pages/' + pg.id %>"
              data-page-form>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="content_json" data-content-json
                 value="<%= JSON.stringify(content) %>">

          <div class="row g-4">
            <!-- LEFT COLUMN — content -->
            <div class="col-lg-8">

              <!-- Title + slug -->
              <div class="bz-art-hero" style="margin-bottom:20px">
                <div style="margin-bottom:14px">
                  <label for="title" class="bz-art-field-label">Názov stránky <span style="color:oklch(0.68 0.18 25)">*</span></label>
                  <input type="text" class="form-control <%= errors.title ? 'is-invalid' : '' %>"
                         id="title" name="title" value="<%= pg.title %>" maxlength="255" required autofocus
                         style="font-size:18px; font-weight:700">
                  <% if (errors.title) { %><div class="invalid-feedback"><%= errors.title %></div><% } %>
                </div>
                <div>
                  <label for="slug" class="bz-art-field-label">Slug</label>
                  <div class="bz-art-slug-row">
                    <span class="bz-art-slug-prefix">/</span>
                    <input type="text" class="bz-art-slug-inp <%= errors.slug ? 'is-invalid' : '' %>"
                           id="slug" name="slug" value="<%= pg.slug %>" maxlength="120"
                           placeholder="automaticky z názvu">
                  </div>
                  <% if (errors.slug) { %><span style="color:oklch(0.75 0.18 25); font-size:11px; margin-top:4px; display:block"><%= errors.slug %></span><% } %>
                  <span class="bz-art-hint" style="margin-top:4px">Ponechaj prázdne pre automatické vygenerovanie.</span>
                </div>
              </div>

              <!-- Block editor -->
              <div class="bz-art-content-card" style="margin-bottom:20px">
                <div class="bz-art-content-head">
                  <span class="bz-art-content-title"><i class="bi bi-layout-text-window-reverse me-2"></i>Obsah</span>
                  <% if (errors.content) { %>
                    <span style="font-size:12px; color:oklch(0.75 0.18 25)"><%= errors.content %></span>
                  <% } %>
                </div>
                <div class="bz-art-content-body">
                  <div data-blocks-container></div>
                  <div data-empty-state style="text-align:center; padding:28px 16px; color:var(--art-text-subtle); <%= content.length > 0 ? 'display:none' : '' %>">
                    <i class="bi bi-file-earmark-text" style="font-size:1.5rem; display:block; margin-bottom:8px"></i>
                    <span style="font-size:12px">Žiadny obsah. Pridaj bloky nižšie.</span>
                  </div>

                  <!-- Standard block buttons -->
                  <div class="bz-art-add-blocks" data-block-toolbar>
                    <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle); text-transform:uppercase; letter-spacing:0.06em; align-self:center; margin-right:4px">Základné:</span>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" data-add-block="paragraph">
                      <i class="bi bi-paragraph"></i> Odsek
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" data-add-block="heading">
                      <i class="bi bi-type-h2"></i> Nadpis
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" data-add-block="image">
                      <i class="bi bi-image"></i> Obrázok
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" data-add-block="divider">
                      <i class="bi bi-dash-lg"></i> Oddeľovač
                    </button>
                  </div>

                  <!-- Page-specific block buttons -->
                  <div style="display:flex; flex-wrap:wrap; gap:8px; margin-top:8px" data-block-toolbar-page>
                    <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle); text-transform:uppercase; letter-spacing:0.06em; align-self:center; margin-right:4px">Šablónové:</span>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_values">
                      <i class="bi bi-grid-3x3-gap"></i> Hodnoty
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_team">
                      <i class="bi bi-people"></i> Tím
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_contact_cta">
                      <i class="bi bi-megaphone"></i> CTA
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_contact_form">
                      <i class="bi bi-envelope"></i> Kontakt formulár
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_channels">
                      <i class="bi bi-signpost-2"></i> Kanály
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_office">
                      <i class="bi bi-geo-alt"></i> Kancelária
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_key_value">
                      <i class="bi bi-list-columns"></i> Kľúč-hodnota
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_rights">
                      <i class="bi bi-shield-check"></i> Práva
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_cookies">
                      <i class="bi bi-table"></i> Cookies
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_summary">
                      <i class="bi bi-chat-square-text"></i> TL;DR
                    </button>
                    <button type="button" class="bz-art-btn bz-art-btn-sm" style="border-color:oklch(0.6 0.18 240/0.4); color:oklch(0.72 0.18 240)" data-add-block="sp_legal_meta">
                      <i class="bi bi-card-list"></i> Právne info
                    </button>
                  </div>
                </div>
              </div>

              <!-- SEO -->
              <div class="bz-art-content-card" style="margin-bottom:20px">
                <div class="bz-art-content-head">
                  <span class="bz-art-content-title"><i class="bi bi-search me-2"></i>SEO</span>
                </div>
                <div class="bz-art-content-body">
                  <div style="margin-bottom:14px">
                    <label for="seo_title" class="bz-art-field-label">SEO Title</label>
                    <input type="text" class="form-control" id="seo_title" name="seo_title"
                           value="<%= pg.seo_title || '' %>" maxlength="255"
                           placeholder="Ak prázdne, použije sa názov stránky">
                    <span class="bz-art-hint" style="margin-top:4px">Odporúčaná dĺžka: 50–60 znakov.</span>
                  </div>
                  <div>
                    <label for="seo_description" class="bz-art-field-label">Meta description</label>
                    <textarea class="form-control" id="seo_description" name="seo_description"
                              rows="2" maxlength="320" placeholder="Krátky popis pre vyhľadávače…"><%= pg.seo_description || '' %></textarea>
                    <span class="bz-art-hint" style="margin-top:4px">Odporúčaná dĺžka: 120–160 znakov.</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- RIGHT COLUMN — settings -->
            <div class="col-lg-4 d-flex flex-column gap-3">

              <!-- Template -->
              <div class="bz-art-side-card">
                <div class="bz-art-side-head">
                  <i class="bi bi-layout-text-sidebar"></i> Šablóna
                </div>
                <div class="bz-art-side-body">
                  <select class="form-select" id="template" name="template" data-page-template>
                    <option value="default" <%= pg.template === 'default' ? 'selected' : '' %>>Prázdna stránka</option>
                    <option value="about" <%= pg.template === 'about' ? 'selected' : '' %>>O nás</option>
                    <option value="contact" <%= pg.template === 'contact' ? 'selected' : '' %>>Kontakt</option>
                    <option value="legal" <%= pg.template === 'legal' ? 'selected' : '' %>>Právny dokument</option>
                  </select>
                  <% if (!isNew) { %>
                    <span class="bz-art-hint" style="margin-top:6px">
                      <i class="bi bi-info-circle"></i> Zmena šablóny nezmení existujúci obsah.
                    </span>
                  <% } %>
                </div>
              </div>

              <!-- Status -->
              <div class="bz-art-side-card">
                <div class="bz-art-side-head">
                  <i class="bi bi-gear"></i> Nastavenia
                </div>
                <div class="bz-art-side-body">
                  <div style="margin-bottom:10px">
                    <label for="status" class="bz-art-field-label">Stav</label>
                    <select class="form-select" id="status" name="status">
                      <option value="draft" <%= pg.status === 'draft' ? 'selected' : '' %>>Koncept</option>
                      <option value="published" <%= pg.status === 'published' ? 'selected' : '' %>>Publikovaná</option>
                    </select>
                  </div>
                  <div style="margin-bottom:10px">
                    <label for="display_order" class="bz-art-field-label">Poradie zobrazenia</label>
                    <input type="number" class="form-control" id="display_order" name="display_order"
                           value="<%= pg.display_order %>" min="0">
                  </div>
                  <div class="form-check" style="margin-bottom:6px">
                    <input type="checkbox" class="form-check-input" id="show_in_header" name="show_in_header"
                           value="1" <%= pg.show_in_header ? 'checked' : '' %>>
                    <label class="form-check-label" for="show_in_header">Zobraziť v headeri</label>
                  </div>
                  <div class="form-check">
                    <input type="checkbox" class="form-check-input" id="show_in_footer" name="show_in_footer"
                           value="1" <%= pg.show_in_footer ? 'checked' : '' %>>
                    <label class="form-check-label" for="show_in_footer">Zobraziť vo footeri</label>
                  </div>
                </div>
              </div>

              <% if (!isNew) { %>
                <!-- Danger zone -->
                <div class="bz-art-side-card" style="border-color:oklch(0.62 0.21 25/0.35)">
                  <div class="bz-art-side-body">
                    <span class="bz-art-field-label" style="color:oklch(0.75 0.18 25); margin-bottom:8px">
                      <i class="bi bi-exclamation-triangle"></i> Nebezpečná zóna
                    </span>
                    <button type="button" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" style="width:100%; justify-content:center"
                            data-page-delete
                            data-delete-url="/admin/pages/<%= pg.id %>/delete"
                            data-csrf="<%= csrfToken %>"
                            data-confirm="Naozaj zmazať stránku &quot;<%= pg.title %>&quot;? Toto sa nedá vrátiť.">
                      <i class="bi bi-trash"></i> Zmazať stránku
                    </button>
                  </div>
                </div>
              <% } %>

            </div>
          </div>
        </form>

      </div>
    </main>
  </div>

  <!-- BLOCK TEMPLATES (hidden, used by admin-page-editor.js) -->

  <template data-block-template="paragraph">
    <div class="bz-block" data-block-type="paragraph">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-paragraph me-1"></i>Odsek</span>
        <div class="bz-block-actions"></div>
      </div>
      <textarea class="form-control" rows="4" data-field="text" placeholder="Text odseku…"></textarea>
    </div>
  </template>

  <template data-block-template="heading">
    <div class="bz-block" data-block-type="heading">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-type-h2 me-1"></i>Nadpis</span>
        <div class="bz-block-actions"></div>
      </div>
      <div style="display:flex; gap:8px">
        <select class="form-select form-select-sm" data-field="level" style="width:90px;">
          <option value="2">H2</option><option value="3">H3</option>
        </select>
        <input type="text" class="form-control" data-field="text" placeholder="Nadpis…" maxlength="255">
      </div>
    </div>
  </template>

  <template data-block-template="image">
    <div class="bz-block" data-block-type="image">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-image me-1"></i>Obrázok</span>
        <div class="bz-block-actions"></div>
      </div>
      <div class="row g-2">
        <div class="col-md-4">
          <div data-image-preview class="bz-image-preview"><span style="font-size:12px; color:var(--art-text-subtle)">(žiadny)</span></div>
        </div>
        <div class="col-md-8">
          <div class="input-group input-group-sm mb-2">
            <span class="input-group-text">Media ID</span>
            <input type="number" class="form-control" data-field="media_id" min="1" placeholder="napr. 7">
            <a href="/admin/media" target="_blank" class="bz-art-btn bz-art-btn-sm" style="border-radius:0 var(--art-r-sm,6px) var(--art-r-sm,6px) 0"><i class="bi bi-images"></i></a>
          </div>
          <input type="text" class="form-control form-control-sm mb-2" data-field="alt" placeholder="Alt text" maxlength="255">
          <input type="text" class="form-control form-control-sm" data-field="caption" placeholder="Popis" maxlength="500">
        </div>
      </div>
    </div>
  </template>

  <template data-block-template="divider">
    <div class="bz-block" data-block-type="divider">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-dash-lg me-1"></i>Oddeľovač</span>
        <div class="bz-block-actions"></div>
      </div>
      <hr style="border-color:var(--art-border); margin:4px 0">
    </div>
  </template>

  <template data-block-template="sp_values">
    <div class="bz-block" data-block-type="sp_values">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-grid-3x3-gap me-1"></i>Hodnoty / vlastnosti</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="items" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="items">
        <i class="bi bi-plus-lg"></i> Pridať hodnotu
      </button>
    </div>
  </template>

  <template data-block-template="sp_team">
    <div class="bz-block" data-block-type="sp_team">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-people me-1"></i>Tím</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="members" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="members">
        <i class="bi bi-plus-lg"></i> Pridať člena
      </button>
    </div>
  </template>

  <template data-block-template="sp_contact_cta">
    <div class="bz-block" data-block-type="sp_contact_cta">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-megaphone me-1"></i>Kontakt CTA</span>
        <div class="bz-block-actions"></div>
      </div>
      <input type="text" class="form-control form-control-sm mb-2" data-field="title" placeholder="Nadpis CTA" maxlength="200">
      <textarea class="form-control form-control-sm mb-2" rows="2" data-field="text" placeholder="Text CTA" maxlength="500"></textarea>
      <input type="email" class="form-control form-control-sm mb-2" data-field="email" placeholder="Email" maxlength="255">
      <div class="form-check">
        <input type="checkbox" class="form-check-input" data-field="show_pgp">
        <label class="form-check-label" style="font-size:12px; color:var(--art-text-muted)">Zobraziť PGP kľúč tlačidlo</label>
      </div>
    </div>
  </template>

  <template data-block-template="sp_contact_form">
    <div class="bz-block" data-block-type="sp_contact_form">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-envelope me-1"></i>Kontaktný formulár</span>
        <div class="bz-block-actions"></div>
      </div>
      <div style="font-size:12px; color:var(--art-text-subtle); padding:8px 12px; background:var(--art-bg-inset); border-radius:var(--art-r-sm,6px)">
        <i class="bi bi-info-circle me-1"></i>
        Zobrazí sa kontaktný formulár (meno, email, téma, správa). Správy sa ukladajú do DB.
      </div>
    </div>
  </template>

  <template data-block-template="sp_channels">
    <div class="bz-block" data-block-type="sp_channels">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-signpost-2 me-1"></i>Kontaktné kanály</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="channels" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="channels">
        <i class="bi bi-plus-lg"></i> Pridať kanál
      </button>
    </div>
  </template>

  <template data-block-template="sp_office">
    <div class="bz-block" data-block-type="sp_office">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-geo-alt me-1"></i>Kancelária / sídlo</span>
        <div class="bz-block-actions"></div>
      </div>
      <input type="text" class="form-control form-control-sm mb-2" data-field="address" placeholder="Adresa" maxlength="255">
      <textarea class="form-control form-control-sm mb-2" rows="2" data-field="description" placeholder="Popis (otváracie hodiny…)" maxlength="1000"></textarea>
      <input type="text" class="form-control form-control-sm mb-2" data-field="map_url" placeholder="URL na mapy (Google Maps link)" maxlength="500">
      <label class="bz-art-field-label" style="margin-top:8px">Štatistiky (napr. vzdialenosť od stanice)</label>
      <div data-nested-list="stats" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="stats">
        <i class="bi bi-plus-lg"></i> Pridať štatistiku
      </button>
    </div>
  </template>

  <template data-block-template="sp_key_value">
    <div class="bz-block" data-block-type="sp_key_value">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-list-columns me-1"></i>Kľúč — hodnota</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="items" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="items">
        <i class="bi bi-plus-lg"></i> Pridať riadok
      </button>
    </div>
  </template>

  <template data-block-template="sp_rights">
    <div class="bz-block" data-block-type="sp_rights">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-shield-check me-1"></i>Práva (GDPR)</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="items" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="items">
        <i class="bi bi-plus-lg"></i> Pridať právo
      </button>
    </div>
  </template>

  <template data-block-template="sp_cookies">
    <div class="bz-block" data-block-type="sp_cookies">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-table me-1"></i>Tabuľka cookies</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="rows" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="rows">
        <i class="bi bi-plus-lg"></i> Pridať cookie
