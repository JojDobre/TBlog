    </div>
  </template>

  <template data-block-template="sp_summary">
    <div class="bz-block" data-block-type="sp_summary">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-chat-square-text me-1"></i>TL;DR + text</span>
        <div class="bz-block-actions"></div>
      </div>
      <input type="text" class="form-control form-control-sm mb-2" data-field="tldr" placeholder="TL;DR — jednoveťáčik" maxlength="500">
      <textarea class="form-control form-control-sm" rows="4" data-field="body" placeholder="Podrobný text…" maxlength="5000"></textarea>
    </div>
  </template>

  <template data-block-template="sp_legal_meta">
    <div class="bz-block" data-block-type="sp_legal_meta">
      <div class="bz-block-header">
        <span class="bz-block-label"><i class="bi bi-card-list me-1"></i>Právne informácie</span>
        <div class="bz-block-actions"></div>
      </div>
      <div data-nested-list="items" class="bz-nested-container"></div>
      <button type="button" class="bz-art-btn bz-art-btn-sm" style="margin-top:8px" data-nested-add="items">
        <i class="bi bi-plus-lg"></i> Pridať položku
      </button>
    </div>
  </template>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-page-editor.js" defer></script>
</body>
</html>
