<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Stránky' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Stránky' }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Stránka vytvorená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Zmeny uložené.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Stránka zmazaná.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Stránky</h1>
            <p class="bz-art-header-sub">O nás, Kontakt, GDPR, Podmienky a ďalšie.</p>
          </div>
          <div class="dropdown">
            <button class="bz-art-btn bz-art-btn-accent dropdown-toggle" data-bs-toggle="dropdown">
              <i class="bi bi-plus-lg"></i> Nová stránka
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/admin/pages/new?template=default"><i class="bi bi-file-earmark me-2"></i>Prázdna stránka</a></li>
              <li><a class="dropdown-item" href="/admin/pages/new?template=about"><i class="bi bi-people me-2"></i>O nás</a></li>
              <li><a class="dropdown-item" href="/admin/pages/new?template=contact"><i class="bi bi-envelope me-2"></i>Kontakt</a></li>
              <li><a class="dropdown-item" href="/admin/pages/new?template=legal"><i class="bi bi-shield-check me-2"></i>Právny dokument</a></li>
            </ul>
          </div>
        </div>

        <!-- Search -->
        <div class="bz-art-search">
          <form method="GET" action="/admin/pages" class="bz-art-search-wrap" style="display:flex; gap:8px;">
            <div class="bz-art-search-wrap" style="flex:1">
              <i class="bi bi-search bz-art-search-icon"></i>
              <input type="search" name="q" class="bz-art-search-input" placeholder="Hľadať podľa názvu…" value="<%= query.q || '' %>">
            </div>
            <button class="bz-art-btn bz-art-btn-sm" type="submit"><i class="bi bi-search"></i></button>
            <% if (query.q) { %>
              <a href="/admin/pages" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-x-lg"></i></a>
            <% } %>
          </form>
        </div>

        <!-- Table -->
        <% if (items.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-file-earmark-text bz-art-empty-icon"></i>
            <p class="bz-art-empty-text"><%= query.q ? 'Žiadne výsledky.' : 'Zatiaľ žiadne stránky.' %></p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th style="width:40px">#</th>
                  <th>Názov</th>
                  <th style="width:120px">Šablóna</th>
                  <th style="width:100px">Stav</th>
                  <th style="width:80px">Header</th>
                  <th style="width:80px">Footer</th>
                  <th style="width:100px">Poradie</th>
                  <th style="width:140px">Aktualizované</th>
                  <th style="width:120px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach(p => { %>
                  <%
                    const tplLabels = { default: 'Prázdna', about: 'O nás', contact: 'Kontakt', legal: 'Právna' };
                    const tplLabel = tplLabels[p.template] || p.template;
                  %>
                  <tr>
                    <td>
                      <span style="color:var(--art-text-subtle); font-family:var(--art-mono); font-size:11px"><%= p.id %></span>
                    </td>
                    <td>
                      <a href="/admin/pages/<%= p.id %>/edit" class="bz-art-title-link"><%= p.title %></a>
                      <span class="bz-art-slug-cell">/<%= p.slug %></span>
                    </td>
                    <td>
                      <span class="bz-art-badge bz-art-badge-review"><%= tplLabel %></span>
                    </td>
                    <td>
                      <% if (p.status === 'published') { %>
                        <span class="bz-art-badge bz-art-badge-published"><i class="bi bi-check-circle"></i> Publikovaná</span>
                      <% } else { %>
                        <span class="bz-art-badge bz-art-badge-draft"><i class="bi bi-pencil-square"></i> Koncept</span>
                      <% } %>
                    </td>
                    <td style="text-align:center; color:var(--art-text-muted)"><%= p.show_in_header ? '✓' : '—' %></td>
                    <td style="text-align:center; color:var(--art-text-muted)"><%= p.show_in_footer ? '✓' : '—' %></td>
                    <td style="text-align:center">
                      <span class="bz-art-badge bz-art-badge-article"><%= p.display_order %></span>
                    </td>
                    <td>
                      <span class="bz-art-time-val">
                        <%= new Date(p.updated_at).toLocaleDateString('sk-SK', { day:'numeric', month:'short', year:'numeric' }) %>
                      </span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions" style="width:180px; text-align:right">
                        <a href="/admin/pages/<%= p.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <% if (p.status === 'published') { %>
                          <a href="/<%= p.slug %>" target="_blank" class="bz-art-btn bz-art-btn-sm" title="Zobraziť">
                            <i class="bi bi-box-arrow-up-right"></i>
                          </a>
                        <% } %>
                        <form method="POST" action="/admin/pages/<%= p.id %>/delete" class="d-inline"
                              data-confirm="Naozaj zmazať stránku &quot;<%= p.title %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (pg) => {
                const params = new URLSearchParams();
                if (query.q) params.set('q', query.q);
                if (pg > 1) params.set('page', pg);
                const qs = params.toString();
                return '/admin/pages' + (qs ? '?' + qs : '');
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const show = new Set([1, tot, cur-1, cur, cur+1]);
              const pgs = [...show].filter(pg => pg >= 1 && pg <= tot).sort((a,b) => a-b);
            %>
            <div class="bz-art-pagination">
              <a href="<%= cur > 1 ? buildHref(cur-1) : '#' %>" class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>">‹</a>
              <% pgs.forEach((pg, idx) => { %>
                <% if (idx > 0 && pgs[idx-1] < pg - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a href="<%= buildHref(pg) %>" class="bz-art-page-btn <%= pg === cur ? 'active' : '' %>"><%= pg %></a>
              <% }) %>
              <a href="<%= cur < tot ? buildHref(cur+1) : '#' %>" class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>">›</a>
            </div>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
