<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Správa #' + msg.id }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Správa #' + msg.id }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <!-- Breadcrumb -->
        <div class="bz-art-breadcrumb" style="margin-bottom:20px">
          <a href="/admin/dashboard">Admin</a>
          <span class="bz-art-breadcrumb-sep">›</span>
          <a href="/admin/messages">Správy</a>
          <span class="bz-art-breadcrumb-sep">›</span>
          <span class="bz-art-breadcrumb-current">#<%= msg.id %></span>
        </div>

        <%# Reply flash %>
        <% if (typeof flash !== 'undefined' && flash && flash.replied) { %>
          <div class="bz-art-alert bz-art-alert-success" style="margin-bottom:16px">
            <i class="bi bi-check-circle-fill"></i> Odpoveď bola odoslaná do správ používateľa.
            <button class="bz-art-alert-close" onclick="this.closest('.bz-art-alert').remove()">×</button>
          </div>
        <% } %>

        <div class="row g-4">
          <!-- Message content -->
          <div class="col-lg-8">
            <div class="bz-art-content-card">
              <div class="bz-art-content-head">
                <span class="bz-art-content-title" style="display:flex; align-items:center; gap:8px">
                  <i class="bi bi-envelope-open"></i>
                  <% if (msg.subject) { %><%= msg.subject %><% } else { %>Bez predmetu<% } %>
                </span>
                <% if (msg.is_read) { %>
                  <span class="bz-art-badge bz-art-badge-draft">Prečítaná</span>
                <% } else { %>
                  <span class="bz-art-badge bz-art-badge-review">Neprečítaná</span>
                <% } %>
              </div>
              <div class="bz-art-content-body">
                <div style="display:flex; gap:12px; align-items:center; padding-bottom:14px; margin-bottom:14px; border-bottom:1px solid var(--art-border)">
                  <div style="width:40px; height:40px; border-radius:50%; background:oklch(0.65 0.18 280/0.2); color:oklch(0.75 0.12 280); display:flex; align-items:center; justify-content:center; font-family:var(--art-mono); font-size:13px; font-weight:700; flex-shrink:0">
                    <%= msg.name.split(' ').map(s => s[0]).slice(0,2).join('').toUpperCase() %>
                  </div>
                  <div style="flex:1">
                    <strong style="font-size:14px; color:var(--art-text)"><%= msg.name %></strong>
                    <div>
                      <a href="mailto:<%= msg.email %>" style="font-size:12px; color:var(--art-accent); text-decoration:none"><%= msg.email %></a>
                    </div>
                  </div>
                  <div style="font-family:var(--art-mono); font-size:11px; color:var(--art-text-subtle); text-align:right">
                    <%= new Date(msg.created_at).toLocaleDateString('sk-SK', { day:'numeric', month:'long', year:'numeric' }) %>
                    <br>o <%= new Date(msg.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                  </div>
                </div>
                <div style="white-space:pre-wrap; font-size:14px; line-height:1.7; color:var(--art-text-muted)"><%= msg.message %></div>
              </div>
            </div>

              <%# Reply to messaging %>
            <div class="bz-art-content-card" style="margin-top:16px">
              <div class="bz-art-side-head">
                <i class="bi bi-reply"></i> Odpovedať do správ
              </div>
              <div class="bz-art-side-body">
                <form method="POST" action="/admin/messages/<%= msg.id %>/reply">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <textarea class="form-control" name="reply" rows="3"
                            placeholder="Napíšte odpoveď..." required maxlength="5000"
                            style="margin-bottom:8px"></textarea>
                  <span class="bz-art-hint" style="display:block; margin-bottom:10px">
                    Odpoveď sa odošle do správ používateľa s emailom <strong><%= msg.email %></strong> (ak je registrovaný).
                  </span>
                  <button type="submit" class="bz-art-btn bz-art-btn-accent bz-art-btn-sm" style="justify-content:center; width:100%">
                    <i class="bi bi-send"></i> Odoslať do správ
                  </button>
                </form>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="col-lg-4 d-flex flex-column gap-3">
            <!-- Actions -->
            <div class="bz-art-side-card">
              <div class="bz-art-side-head">
                <i class="bi bi-gear"></i> Akcie
              </div>
              <div class="bz-art-side-body">
                <a href="mailto:<%= msg.email %>?subject=Re: <%= encodeURIComponent(msg.subject || 'Kontaktný formulár') %>"
                   class="bz-art-btn bz-art-btn-accent bz-art-btn-sm" style="justify-content:center; width:100%">
                  <i class="bi bi-reply"></i> Odpovedať emailom
                </a>
                <form method="POST" action="/admin/messages/<%= msg.id %>/toggle-read">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="bz-art-btn bz-art-btn-sm" style="justify-content:center; width:100%">
                    <i class="bi bi-<%= msg.is_read ? 'envelope' : 'envelope-open' %>"></i>
                    <%= msg.is_read ? 'Označiť ako neprečítanú' : 'Označiť ako prečítanú' %>
                  </button>
                </form>
                <form method="POST" action="/admin/messages/<%= msg.id %>/delete"
                      data-confirm="Naozaj zmazať túto správu?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" style="justify-content:center; width:100%">
                    <i class="bi bi-trash"></i> Zmazať správu
                  </button>
                </form>
              </div>
            </div>

            <!-- Details -->
            <div class="bz-art-side-card">
              <div class="bz-art-side-head">
                <i class="bi bi-info-circle"></i> Detaily
              </div>
              <div class="bz-art-side-body" style="display:grid; grid-template-columns:auto 1fr; gap:4px 12px; font-size:12px">
                <span class="bz-art-field-label" style="margin:0">ID</span>
                <span style="color:var(--art-text-muted)">#<%= msg.id %></span>

                <span class="bz-art-field-label" style="margin:0">Meno</span>
                <span style="color:var(--art-text-muted)"><%= msg.name %></span>

                <span class="bz-art-field-label" style="margin:0">Email</span>
                <span style="color:var(--art-text-muted)"><%= msg.email %></span>

                <span class="bz-art-field-label" style="margin:0">Predmet</span>
                <span style="color:var(--art-text-muted)"><%= msg.subject || '—' %></span>

                <span class="bz-art-field-label" style="margin:0">Odoslaná</span>
                <span style="color:var(--art-text-muted)">
                  <%= new Date(msg.created_at).toLocaleDateString('sk-SK') %>
                  <%= new Date(msg.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                </span>

                <% if (msg.read_at) { %>
                  <span class="bz-art-field-label" style="margin:0">Prečítaná</span>
                  <span style="color:var(--art-text-muted)">
                    <%= new Date(msg.read_at).toLocaleDateString('sk-SK') %>
                    <%= new Date(msg.read_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                  </span>
                <% } %>

                <% if (msg.ip_hash) { %>
                  <span class="bz-art-field-label" style="margin:0">IP hash</span>
                  <span style="font-family:var(--art-mono); font-size:11px; color:var(--art-text-subtle)"><%= msg.ip_hash.substring(0, 16) %>…</span>
                <% } %>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
