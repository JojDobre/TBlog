<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Správa #' + msg.id }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Správa #' + msg.id }) %>

    <main class="bz-content">
      <div class="container-fluid py-4">

        <%# Breadcrumb %>
        <nav class="mb-3">
          <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Admin</a></li>
            <li class="breadcrumb-item"><a href="/admin/messages">Správy</a></li>
            <li class="breadcrumb-item active">#<%= msg.id %></li>
          </ol>
        </nav>

        <div class="row g-4">
          <%# Message content %>
          <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                <h6 class="mb-0">
                  <i class="bi bi-envelope-open me-2"></i>
                  <% if (msg.subject) { %><%= msg.subject %><% } else { %>Bez predmetu<% } %>
                </h6>
                <span class="badge <%= msg.is_read ? 'bg-secondary' : 'bg-primary' %>">
                  <%= msg.is_read ? 'Prečítaná' : 'Neprečítaná' %>
                </span>
              </div>
              <div class="card-body">
                <div class="mb-3 pb-3 border-bottom">
                  <div class="d-flex gap-3 align-items-center">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;font-weight:600;font-size:15px;flex-shrink:0;">
                      <%= msg.name.split(' ').map(s => s[0]).slice(0,2).join('').toUpperCase() %>
                    </div>
                    <div>
                      <strong><%= msg.name %></strong>
                      <div class="text-muted small">
                        <a href="mailto:<%= msg.email %>"><%= msg.email %></a>
                      </div>
                    </div>
                    <div class="ms-auto text-muted small text-end">
                      <%= new Date(msg.created_at).toLocaleDateString('sk-SK', { day:'numeric', month:'long', year:'numeric' }) %>
                      o <%= new Date(msg.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                    </div>
                  </div>
                </div>
                <div style="white-space:pre-wrap;font-size:14px;line-height:1.7;color:var(--bs-body-color);"><%= msg.message %></div>
              </div>
            </div>
          </div>

          <%# Sidebar — actions + meta %>
          <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-3">
              <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-gear me-2"></i>Akcie</h6>
              </div>
              <div class="card-body d-grid gap-2">
                <a href="mailto:<%= msg.email %>?subject=Re: <%= encodeURIComponent(msg.subject || 'Kontaktný formulár') %>"
                   class="btn btn-primary btn-sm">
                  <i class="bi bi-reply me-1"></i>Odpovedať emailom
                </a>
                <form method="POST" action="/admin/messages/<%= msg.id %>/toggle-read">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                    <i class="bi bi-<%= msg.is_read ? 'envelope' : 'envelope-open' %> me-1"></i>
                    <%= msg.is_read ? 'Označiť ako neprečítanú' : 'Označiť ako prečítanú' %>
                  </button>
                </form>
                <form method="POST" action="/admin/messages/<%= msg.id %>/delete"
                      data-confirm="Naozaj zmazať túto správu?">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                    <i class="bi bi-trash me-1"></i>Zmazať správu
                  </button>
                </form>
              </div>
            </div>

            <div class="card border-0 shadow-sm">
              <div class="card-header bg-transparent">
                <h6 class="mb-0"><i class="bi bi-info-circle me-2"></i>Detaily</h6>
              </div>
              <div class="card-body">
                <dl class="row mb-0 small">
                  <dt class="col-5 text-muted">ID</dt>
                  <dd class="col-7">#<%= msg.id %></dd>

                  <dt class="col-5 text-muted">Meno</dt>
                  <dd class="col-7"><%= msg.name %></dd>

                  <dt class="col-5 text-muted">Email</dt>
                  <dd class="col-7"><%= msg.email %></dd>

                  <dt class="col-5 text-muted">Predmet</dt>
                  <dd class="col-7"><%= msg.subject || '—' %></dd>

                  <dt class="col-5 text-muted">Odoslaná</dt>
                  <dd class="col-7">
                    <%= new Date(msg.created_at).toLocaleDateString('sk-SK') %>
                    <%= new Date(msg.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                  </dd>

                  <% if (msg.read_at) { %>
                    <dt class="col-5 text-muted">Prečítaná</dt>
                    <dd class="col-7">
                      <%= new Date(msg.read_at).toLocaleDateString('sk-SK') %>
                      <%= new Date(msg.read_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                    </dd>
                  <% } %>

                  <% if (msg.ip_hash) { %>
                    <dt class="col-5 text-muted">IP hash</dt>
                    <dd class="col-7"><code class="small"><%= msg.ip_hash.substring(0, 16) %>…</code></dd>
                  <% } %>
                </dl>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
