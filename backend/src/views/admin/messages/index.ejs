<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Kontaktné správy' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Kontaktné správy' }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.marked) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Stav správy aktualizovaný.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Správa zmazaná.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Kontaktné správy</h1>
            <p class="bz-art-header-sub">Správy z kontaktného formulára na webe.</p>
          </div>
          <% if (unreadCount > 0) { %>
            <form method="POST" action="/admin/messages/mark-all-read" class="d-inline"
                  data-confirm="Označiť všetkých <%= unreadCount %> neprečítaných správ ako prečítané?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="bz-art-btn bz-art-btn-sm">
                <i class="bi bi-check-all"></i> Označiť všetko ako prečítané
              </button>
            </form>
          <% } %>

<a href="/admin/messages/broadcast" class="bz-art-btn bz-art-btn-sm">
  <i class="bi bi-megaphone"></i> Broadcast
</a>
        </div>

        <!-- Tabs -->
        <%
          const buildTabHref = (tab) => {
            const params = new URLSearchParams();
            params.set('tab', tab);
            if (query.q) params.set('q', query.q);
            return '/admin/messages?' + params.toString();
          };
        %>
        <div class="bz-art-status-tabs">
          <a class="bz-art-status-tab <%= activeTab === 'unread' ? 'active' : '' %>" href="<%= buildTabHref('unread') %>">
            Neprečítané
            <% if (unreadCount > 0) { %>
              <span class="bz-art-status-tab-badge"><%= unreadCount %></span>
            <% } %>
          </a>
          <a class="bz-art-status-tab <%= activeTab === 'read' ? 'active' : '' %>" href="<%= buildTabHref('read') %>">
            Prečítané
          </a>
        </div>

        <!-- Search -->
        <form method="GET" action="/admin/messages" class="bz-art-search">
          <input type="hidden" name="tab" value="<%= activeTab %>">
          <div class="bz-art-search-wrap">
            <i class="bi bi-search bz-art-search-icon"></i>
            <input type="search" name="q" class="bz-art-search-input"
                   placeholder="Hľadať podľa mena, emailu, predmetu…" value="<%= query.q || '' %>">
          </div>
          <button class="bz-art-btn bz-art-btn-sm" type="submit"><i class="bi bi-search"></i></button>
          <% if (query.q) { %>
            <a href="/admin/messages?tab=<%= activeTab %>" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-x-lg"></i></a>
          <% } %>
        </form>

        <!-- Table -->
        <% if (items.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-envelope-open bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">
              <%= query.q ? 'Žiadne výsledky.' : (activeTab === 'unread' ? 'Žiadne neprečítané správy.' : 'Žiadne prečítané správy.') %>
            </p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th style="width:40px"></th>
                  <th style="width:160px">Odosielateľ</th>
                  <th style="width:180px">Email</th>
                  <th>Predmet / Správa</th>
                  <th style="width:150px">Dátum</th>
                  <th style="width:180px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% items.forEach(m => { %>
                  <tr style="<%= !m.is_read ? 'background:oklch(0.65 0.18 280/0.06)' : '' %>">
                    <td style="text-align:center">
                      <% if (!m.is_read) { %>
                        <span style="display:inline-block; width:8px; height:8px; border-radius:50%; background:oklch(0.65 0.18 280); box-shadow:0 0 6px oklch(0.65 0.18 280/0.5);" title="Neprečítaná"></span>
                      <% } %>
                    </td>
                    <td>
                      <span style="font-size:13px; font-weight:<%= !m.is_read ? '600' : '400' %>; color:var(--art-text)"><%= m.name %></span>
                    </td>
                    <td>
                      <a href="mailto:<%= m.email %>" style="font-size:12px; color:var(--art-accent); text-decoration:none"><%= m.email %></a>
                    </td>
                    <td>
                      <a href="/admin/messages/<%= m.id %>" class="bz-art-title-link" style="font-size:13px">
                        <% if (m.subject) { %>
                          <span style="font-weight:<%= !m.is_read ? '600' : '500' %>"><%= m.subject %></span>
                          <span style="color:var(--art-text-subtle)"> — </span>
                        <% } %>
                        <span style="color:var(--art-text-muted); font-weight:400"><%= m.message.length > 80 ? m.message.substring(0, 80) + '…' : m.message %></span>
                      </a>
                    </td>
                    <td>
                      <span class="bz-art-time-val">
                        <%= new Date(m.created_at).toLocaleDateString('sk-SK', { day:'numeric', month:'short', year:'numeric' }) %>
                      </span>
                      <br>
                      <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle)">
                        <%= new Date(m.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %>
                      </span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions">
                        <a href="/admin/messages/<%= m.id %>" class="bz-art-btn bz-art-btn-sm" title="Detail">
                          <i class="bi bi-eye"></i>
                        </a>
                        <form method="POST" action="/admin/messages/<%= m.id %>/toggle-read" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm"
                                  title="<%= m.is_read ? 'Označiť ako neprečítanú' : 'Označiť ako prečítanú' %>">
                            <i class="bi bi-<%= m.is_read ? 'envelope' : 'envelope-open' %>"></i>
                          </button>
                        </form>
                        <form method="POST" action="/admin/messages/<%= m.id %>/delete" class="d-inline"
                              data-confirm="Zmazať správu od &quot;<%= m.name %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (pg) => {
                const params = new URLSearchParams();
                params.set('tab', activeTab);
                if (query.q) params.set('q', query.q);
                if (pg > 1) params.set('page', pg);
                return '/admin/messages?' + params.toString();
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const show = new Set([1, tot, cur-1, cur, cur+1]);
              const pgs = [...show].filter(pg => pg >= 1 && pg <= tot).sort((a,b) => a-b);
            %>
            <div class="bz-art-pagination">
              <a href="<%= cur > 1 ? buildHref(cur-1) : '#' %>" class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>">‹</a>
              <% pgs.forEach((pg, idx) => { %>
                <% if (idx > 0 && pgs[idx-1] < pg - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a href="<%= buildHref(pg) %>" class="bz-art-page-btn <%= pg === cur ? 'active' : '' %>"><%= pg %></a>
              <% }) %>
              <a href="<%= cur < tot ? buildHref(cur+1) : '#' %>" class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>">›</a>
            </div>
          <% } %>
        <% } %>

        <p class="bz-art-hint" style="margin-top:14px">
          <i class="bi bi-info-circle"></i>
          Celkom správ v tejto záložke: <%= pagination.total %>.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
