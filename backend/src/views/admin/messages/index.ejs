<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Kontaktné správy' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Kontaktné správy' }) %>

    <main class="bz-content">
      <div class="container-fluid py-4">

        <%# Flash %>
        <% if (flash.marked) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Stav správy aktualizovaný.
            <button class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>Správa zmazaná.
            <button class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button class="btn-close" data-bs-dismiss="alert"></button>
          </div>
        <% } %>

        <%# Header %>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h5 class="mb-1">Kontaktné správy</h5>
            <p class="text-muted small mb-0">Správy z kontaktného formulára na webe.</p>
          </div>
          <% if (unreadCount > 0) { %>
            <form method="POST" action="/admin/messages/mark-all-read" class="d-inline"
                  data-confirm="Označiť všetkých <%= unreadCount %> neprečítaných správ ako prečítané?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-primary">
                <i class="bi bi-check-all me-1"></i>Označiť všetko ako prečítané
              </button>
            </form>
          <% } %>
        </div>

        <%# Tabs %>
        <%
          const buildTabHref = (tab) => {
            const params = new URLSearchParams();
            params.set('tab', tab);
            if (query.q) params.set('q', query.q);
            return '/admin/messages?' + params.toString();
          };
        %>
        <ul class="nav nav-tabs mb-3">
          <li class="nav-item">
            <a class="nav-link <%= activeTab === 'unread' ? 'active' : '' %>" href="<%= buildTabHref('unread') %>">
              Neprečítané
              <% if (unreadCount > 0) { %>
                <span class="badge bg-danger ms-1"><%= unreadCount %></span>
              <% } %>
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= activeTab === 'read' ? 'active' : '' %>" href="<%= buildTabHref('read') %>">
              Prečítané
            </a>
          </li>
        </ul>

        <%# Search %>
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body py-2">
            <form method="GET" action="/admin/messages" class="d-flex gap-2">
              <input type="hidden" name="tab" value="<%= activeTab %>">
              <input type="search" name="q" class="form-control form-control-sm"
                     placeholder="Hľadať podľa mena, emailu, predmetu…" value="<%= query.q || '' %>">
              <button class="btn btn-sm btn-outline-secondary" type="submit"><i class="bi bi-search"></i></button>
              <% if (query.q) { %>
                <a href="/admin/messages?tab=<%= activeTab %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-lg"></i></a>
              <% } %>
            </form>
          </div>
        </div>

        <%# Table %>
        <% if (items.length === 0) { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-envelope-open" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">
              <%= query.q ? 'Žiadne výsledky.' : (activeTab === 'unread' ? 'Žiadne neprečítané správy.' : 'Žiadne prečítané správy.') %>
            </p>
          </div>
        <% } else { %>
          <div class="card border-0 shadow-sm">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th style="width:40px"></th>
                    <th style="width:160px">Odosielateľ</th>
                    <th style="width:180px">Email</th>
                    <th>Predmet / Správa</th>
                    <th style="width:150px">Dátum</th>
                    <th style="width:140px" class="text-end">Akcie</th>
                  </tr>
                </thead>
                <tbody>
                  <% items.forEach(m => { %>
                    <tr class="<%= !m.is_read ? 'table-active' : '' %>">
                      <td class="text-center">
                        <% if (!m.is_read) { %>
                          <span class="badge bg-primary rounded-pill" title="Neprečítaná">&bull;</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="<%= !m.is_read ? 'fw-semibold' : '' %>"><%= m.name %></span>
                      </td>
                      <td>
                        <a href="mailto:<%= m.email %>" class="text-decoration-none small"><%= m.email %></a>
                      </td>
                      <td>
                        <a href="/admin/messages/<%= m.id %>" class="text-decoration-none">
                          <% if (m.subject) { %>
                            <span class="<%= !m.is_read ? 'fw-semibold' : '' %>"><%= m.subject %></span>
                            <span class="text-muted"> — </span>
                          <% } %>
                          <span class="text-muted"><%= m.message.length > 80 ? m.message.substring(0, 80) + '…' : m.message %></span>
                        </a>
                      </td>
                      <td class="text-muted small">
                        <%= new Date(m.created_at).toLocaleDateString('sk-SK', { day:'numeric', month:'short', year:'numeric' }) %>
                        <br>
                        <span style="font-size:11px;"><%= new Date(m.created_at).toLocaleTimeString('sk-SK', { hour:'2-digit', minute:'2-digit' }) %></span>
                      </td>
                      <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                          <a href="/admin/messages/<%= m.id %>" class="btn btn-sm btn-outline-primary" title="Detail">
                            <i class="bi bi-eye"></i>
                          </a>
                          <form method="POST" action="/admin/messages/<%= m.id %>/toggle-read" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-secondary"
                                    title="<%= m.is_read ? 'Označiť ako neprečítanú' : 'Označiť ako prečítanú' %>">
                              <i class="bi bi-<%= m.is_read ? 'envelope' : 'envelope-open' %>"></i>
                            </button>
                          </form>
                          <form method="POST" action="/admin/messages/<%= m.id %>/delete" class="d-inline"
                                data-confirm="Zmazať správu od &quot;<%= m.name %>&quot;?">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Zmazať">
                              <i class="bi bi-trash"></i>
                            </button>
                          </form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <%# Pagination %>
          <% if (pagination.totalPages > 1) { %>
            <nav class="mt-3">
              <ul class="pagination justify-content-center mb-0">
                <%
                  const buildHref = (p) => {
                    const params = new URLSearchParams();
                    params.set('tab', activeTab);
                    if (query.q) params.set('q', query.q);
                    if (p > 1) params.set('page', p);
                    return '/admin/messages?' + params.toString();
                  };
                  const cur = pagination.page;
                  const tot = pagination.totalPages;
                  const show = new Set([1, tot, cur-1, cur, cur+1]);
                  const pgs = [...show].filter(p => p >= 1 && p <= tot).sort((a,b) => a-b);
                %>
                <li class="page-item <%= cur <= 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur > 1 ? buildHref(cur-1) : '#' %>">‹</a>
                </li>
                <% pgs.forEach((p, idx) => { %>
                  <% if (idx > 0 && pgs[idx-1] < p - 1) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% } %>
                  <li class="page-item <%= p === cur ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildHref(p) %>"><%= p %></a>
                  </li>
                <% }) %>
                <li class="page-item <%= cur >= tot ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur < tot ? buildHref(cur+1) : '#' %>">›</a>
                </li>
              </ul>
            </nav>
          <% } %>
        <% } %>

        <p class="text-muted small mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i>
          Celkom správ v tejto záložke: <%= pagination.total %>.
        </p>
      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
