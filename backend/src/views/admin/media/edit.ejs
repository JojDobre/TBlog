<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Úprava média' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar') %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Úprava média' }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">
        <div class="row g-4">
          <div class="col-md-5">
            <div class="card border-0 shadow-sm">
              <a href="/uploads/<%= item.original_path %>" target="_blank" rel="noopener">
                <img src="/uploads/<%= item.thumbnail_path %>" alt="<%= item.alt_text || item.original_filename %>" class="card-img-top" />
              </a>
              <div class="card-body small">
                <dl class="row mb-0">
                  <dt class="col-5 text-muted">Pôvodný názov</dt><dd class="col-7"><%= item.original_filename %></dd>
                  <dt class="col-5 text-muted">Rozmer</dt><dd class="col-7"><%= item.width || '?' %>×<%= item.height || '?' %></dd>
                  <dt class="col-5 text-muted">Veľkosť</dt><dd class="col-7"><%= Math.round(item.size_bytes / 1024) %> KB</dd>
                  <dt class="col-5 text-muted">Typ</dt><dd class="col-7"><%= item.mime %></dd>
                  <dt class="col-5 text-muted">Nahrané</dt><dd class="col-7"><%= new Date(item.created_at).toLocaleString('sk-SK') %></dd>
                  <dt class="col-5 text-muted">Nahral</dt><dd class="col-7"><%= item.uploader_nickname || '—' %></dd>
                </dl>
              </div>
            </div>
          </div>

          <div class="col-md-7">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white"><h2 class="h6 mb-0">Metadáta</h2></div>
              <div class="card-body">
                <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

                <form method="POST" action="/admin/media/<%= item.id %>/edit">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

                  <div class="mb-3">
                    <label for="alt_text" class="form-label">Alt text</label>
                    <input type="text" id="alt_text" name="alt_text" class="form-control"
                           value="<%= item.alt_text || '' %>" maxlength="255" />
                    <div class="form-text">Krátky popis pre prístupnosť (čítačky obrazovky, vyhľadávače).</div>
                  </div>

                  <div class="mb-3">
                    <label for="caption" class="form-label">Popis</label>
                    <textarea id="caption" name="caption" class="form-control" rows="3" maxlength="1000"><%= item.caption || '' %></textarea>
                    <div class="form-text">Voliteľný dlhší popis alebo zdroj/autor.</div>
                  </div>

                  <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Uložiť</button>
                    <a href="/admin/media" class="btn btn-link">Späť</a>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
