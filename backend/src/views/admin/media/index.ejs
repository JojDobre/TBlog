<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Médiá' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar') %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Médiá' }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% if (flash.uploaded) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Súbor bol úspešne nahraný.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Súbor bol zmazaný.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>

        <%# ====================================== UPLOAD FORM ====================================== %>
        <div class="card border-0 shadow-sm mb-4">
          <div class="card-header bg-white">
            <h2 class="h6 mb-0"><i class="bi bi-cloud-upload me-2"></i>Nahrať obrázok</h2>
          </div>
          <div class="card-body">
            <form method="POST" action="/admin/media/upload" enctype="multipart/form-data" class="row g-3">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

              <div class="col-md-6">
                <label for="file" class="form-label">Súbor <span class="text-muted small">(JPEG, PNG, WebP, GIF — max <%= maxSizeMb %> MB)</span></label>
                <input type="file" class="form-control" id="file" name="file"
                       accept="image/jpeg,image/png,image/webp,image/gif" required />
              </div>

              <div class="col-md-6">
                <label for="alt_text" class="form-label">Alt text <span class="text-muted small">(voliteľné)</span></label>
                <input type="text" class="form-control" id="alt_text" name="alt_text" maxlength="255"
                       placeholder="Krátky popis obrázka pre prístupnosť" />
              </div>

              <div class="col-12">
                <label for="caption" class="form-label">Popis <span class="text-muted small">(voliteľné)</span></label>
                <input type="text" class="form-control" id="caption" name="caption" maxlength="1000"
                       placeholder="Dlhší popis alebo zdroj" />
              </div>

              <div class="col-12">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-upload me-1"></i>Nahrať
                </button>
              </div>
            </form>
          </div>
        </div>

        <%# ====================================== GRID ====================================== %>
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white d-flex align-items-center">
            <h2 class="h6 mb-0"><i class="bi bi-images me-2"></i>Knižnica</h2>
            <span class="ms-auto text-muted small"><%= items.length %> najnovších položiek</span>
          </div>
          <div class="card-body">
            <% if (items.length === 0) { %>
              <p class="text-muted text-center py-4 mb-0">
                Knižnica je prázdna. Nahraj prvý obrázok vyššie.
              </p>
            <% } else { %>
              <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
                <% items.forEach(item => { %>
                  <div class="col">
                    <div class="card h-100 bz-media-card">
                      <a href="/uploads/<%= item.original_path %>" target="_blank" rel="noopener" class="bz-media-thumb">
                        <img src="/uploads/<%= item.thumbnail_path %>"
                             alt="<%= item.alt_text || item.original_filename %>"
                             loading="lazy"
                             class="card-img-top" />
                      </a>
                      <div class="card-body p-2">
                        <p class="small text-truncate mb-1" title="<%= item.original_filename %>">
                          <%= item.original_filename %>
                        </p>
                        <p class="small text-muted mb-2">
                          <% if (item.width && item.height) { %><%= item.width %>×<%= item.height %> · <% } %>
                          <%= Math.round(item.size_bytes / 1024) %> KB
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                          <% if (item.usage_count > 0) { %>
                            <span class="badge text-bg-secondary">Použité <%= item.usage_count %>×</span>
                          <% } else { %>
                            <span class="badge text-bg-light text-muted">Nepoužité</span>
                          <% } %>
                          <% if (item.usage_count === 0) { %>
                            <form method="POST" action="/admin/media/<%= item.id %>/delete" class="m-0"
                                  onsubmit="return confirm('Naozaj zmazať tento obrázok?');">
                              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                              <button type="submit" class="btn btn-sm btn-outline-danger" title="Zmazať">
                                <i class="bi bi-trash"></i>
                              </button>
                            </form>
                          <% } %>
                        </div>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } %>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
