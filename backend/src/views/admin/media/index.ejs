<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Médiá' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: 'Médiá' }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.uploadedCount > 0) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Nahraných: <%= flash.uploadedCount %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Súbor zmazaný.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.saved) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Zmeny uložené.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Médiá</h1>
            <p class="bz-art-header-sub">Nahrávanie a správa obrázkov</p>
          </div>
        </div>

        <!-- Upload card -->
        <div class="bz-art-content-card" style="margin-bottom:24px">
          <div class="bz-art-content-head">
            <span class="bz-art-content-title"><i class="bi bi-cloud-upload me-2"></i>Nahrať obrázky</span>
          </div>
          <div class="bz-art-content-body">
            <form method="POST" action="/admin/media/upload" enctype="multipart/form-data"
                  data-max-files="<%= maxFiles %>">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <div style="margin-bottom:14px">
                <label for="files" class="bz-art-field-label">
                  Súbory <span style="color:var(--art-text-subtle); text-transform:none; letter-spacing:0; font-weight:400">(JPEG, PNG, WebP, GIF — max <%= maxSizeMb %> MB / súbor, naraz max <%= maxFiles %>)</span>
                </label>
                <input type="file" class="form-control" id="files" name="files"
                       accept="image/jpeg,image/png,image/webp,image/gif"
                       multiple required data-multi-file-input />
                <span class="bz-art-hint" style="margin-top:4px" data-file-count-info>Vyber viacero súborov naraz (Ctrl/Shift + klik).</span>
              </div>
              <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px">
                <div>
                  <label for="alt_text" class="bz-art-field-label">Alt text <span style="color:var(--art-text-subtle); text-transform:none; letter-spacing:0; font-weight:400">(spoločný)</span></label>
                  <input type="text" class="form-control" id="alt_text" name="alt_text" maxlength="255" />
                </div>
                <div>
                  <label for="caption" class="bz-art-field-label">Popis <span style="color:var(--art-text-subtle); text-transform:none; letter-spacing:0; font-weight:400">(spoločný)</span></label>
                  <input type="text" class="form-control" id="caption" name="caption" maxlength="1000" />
                </div>
              </div>
              <button type="submit" class="bz-art-btn bz-art-btn-accent">
                <i class="bi bi-upload"></i> Nahrať
              </button>
            </form>
          </div>
        </div>

        <!-- Library -->
        <div class="bz-art-content-card">
          <div class="bz-art-content-head">
            <span class="bz-art-content-title"><i class="bi bi-images me-2"></i>Knižnica</span>
            <div style="display:flex; align-items:center; gap:10px">
              <form method="GET" action="/admin/media" style="display:flex; gap:6px">
                <div class="bz-art-search-wrap" style="min-width:200px">
                  <i class="bi bi-search bz-art-search-icon"></i>
                  <input type="search" name="q" value="<%= q %>" class="bz-art-search-input" placeholder="Hľadať…" />
                </div>
                <button type="submit" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-search"></i></button>
                <% if (q) { %><a href="/admin/media" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-x-lg"></i></a><% } %>
              </form>
              <span style="font-family:var(--art-mono); font-size:11px; color:var(--art-text-subtle); white-space:nowrap">
                <% if (q) { %>Nájdených: <%= totalCount %><% } else { %><%= totalCount %> položiek<% } %>
              </span>
            </div>
          </div>
          <div class="bz-art-content-body">
            <% if (items.length === 0) { %>
              <div class="bz-art-empty" style="border:none">
                <i class="bi bi-images bz-art-empty-icon"></i>
                <p class="bz-art-empty-text">
                  <% if (q) { %>Pre hľadaný výraz sa nič nenašlo.<% } else { %>Knižnica je prázdna.<% } %>
                </p>
              </div>
            <% } else { %>
              <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(160px, 1fr)); gap:14px">
                <% items.forEach(item => { %>
                  <div style="background:var(--art-bg-inset); border:1px solid var(--art-border); border-radius:var(--art-r-md); overflow:hidden; display:flex; flex-direction:column">
                    <a href="/uploads/<%= item.original_path %>" target="_blank" rel="noopener"
                       style="display:block; aspect-ratio:4/3; background:oklch(0.13 0.005 240); overflow:hidden">
                      <img src="/uploads/<%= item.thumbnail_path %>" alt="<%= item.alt_text || item.original_filename %>"
                           loading="lazy" style="width:100%; height:100%; object-fit:cover; display:block" />
                    </a>
                    <div style="padding:8px 10px; flex:1; display:flex; flex-direction:column; gap:4px">
                      <p style="font-size:12px; font-weight:500; color:var(--art-text); margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis"
                         title="<%= item.original_filename %>"><%= item.original_filename %></p>
                      <p style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle); margin:0">
                        <% if (item.width && item.height) { %><%= item.width %>×<%= item.height %> · <% } %>
                        <%= Math.round(item.size_bytes / 1024) %> KB
                      </p>
                      <div style="display:flex; gap:4px; align-items:center; margin-top:auto">
                        <% if (item.usage_count > 0) { %>
                          <span class="bz-art-badge bz-art-badge-published" style="flex:1; text-align:center">Použité <%= item.usage_count %>×</span>
                        <% } else { %>
                          <span class="bz-art-badge bz-art-badge-draft" style="flex:1; text-align:center">Nepoužité</span>
                        <% } %>
                        <a href="/admin/media/<%= item.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť" style="padding:4px 8px">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <% if (item.usage_count === 0) { %>
                          <form method="POST" action="/admin/media/<%= item.id %>/delete" style="margin:0" onsubmit="return confirm('Naozaj zmazať?');">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                            <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať" style="padding:4px 8px">
                              <i class="bi bi-trash"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </div>
                  </div>
                <% }) %>
              </div>

              <% if (totalPages > 1) { %>
                <% const qs = q ? '&q=' + encodeURIComponent(q) : ''; %>
                <div class="bz-art-pagination">
                  <% if (page > 1) { %>
                    <a href="?page=<%= page-1 %><%= qs %>" class="bz-art-page-btn">‹</a>
                  <% } %>
                  <% for (let p = Math.max(1, page-2); p <= Math.min(totalPages, page+2); p++) { %>
                    <a href="?page=<%= p %><%= qs %>" class="bz-art-page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
                  <% } %>
                  <% if (page < totalPages) { %>
                    <a href="?page=<%= page+1 %><%= qs %>" class="bz-art-page-btn">›</a>
                  <% } %>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-media.js" defer></script>
</body>
</html>
