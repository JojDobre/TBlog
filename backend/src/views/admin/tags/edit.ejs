<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: pageTitle }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap" style="max-width:860px">

        <div class="bz-art-breadcrumb" style="margin-bottom:20px">
          <a href="/admin/dashboard">Dashboard</a>
          <span class="bz-art-breadcrumb-sep">›</span>
          <a href="/admin/tags">Tagy</a>
          <span class="bz-art-breadcrumb-sep">›</span>
          <span class="bz-art-breadcrumb-current"><%= isNew ? 'Nový' : (tag.name || 'Upraviť') %></span>
        </div>

        <div class="bz-art-content-card">
          <div class="bz-art-content-head">
            <span class="bz-art-content-title"><%= pageTitle %></span>
          </div>
          <div class="bz-art-content-body">

            <% if (Object.keys(errors).length > 0) { %>
              <div class="bz-art-alert bz-art-alert-error" style="margin-bottom:16px">
                <i class="bi bi-exclamation-triangle-fill"></i> Skontroluj chyby vo formulári nižšie.
              </div>
            <% } %>

            <form
              method="POST"
              action="<%= isNew ? '/admin/tags' : ('/admin/tags/' + tag.id) %>"
              novalidate
              data-tag-form
            >
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">

              <div style="margin-bottom:14px">
                <label for="name" class="bz-art-field-label">Názov <span style="color:oklch(0.68 0.18 25)">*</span></label>
                <input
                  type="text"
                  class="form-control <%= errors.name ? 'is-invalid' : '' %>"
                  id="name"
                  name="name"
                  maxlength="64"
                  required
                  autofocus
                  value="<%= tag.name || '' %>"
                  data-color-name-source
                >
                <% if (errors.name) { %>
                  <div class="invalid-feedback"><%= errors.name %></div>
                <% } else { %>
                  <span class="bz-art-hint" style="margin-top:4px">Max 64 znakov.</span>
                <% } %>
              </div>

              <div style="margin-bottom:14px">
                <label for="slug" class="bz-art-field-label">Slug</label>
                <input
                  type="text"
                  class="form-control <%= errors.slug ? 'is-invalid' : '' %>"
                  id="slug"
                  name="slug"
                  maxlength="120"
                  pattern="[a-z0-9]+(-[a-z0-9]+)*"
                  value="<%= tag.slug || '' %>"
                  placeholder="<%= isNew ? 'Nechaj prázdne pre automatické generovanie' : '' %>"
                >
                <% if (errors.slug) { %>
                  <div class="invalid-feedback"><%= errors.slug %></div>
                <% } else { %>
                  <span class="bz-art-hint" style="margin-top:4px">Časť URL — len a-z, 0-9 a pomlčky.</span>
                <% } %>
              </div>

              <div style="margin-bottom:14px">
                <label class="bz-art-field-label">Farba</label>
                <div style="display:flex; gap:8px; align-items:center; margin-bottom:10px; flex-wrap:wrap">
                  <input
                    type="color"
                    class="form-control form-control-color <%= errors.color ? 'is-invalid' : '' %>"
                    id="color"
                    name="color"
                    value="<%= tag.color || '#9ca3af' %>"
                    title="Vyber farbu"
                    style="width:60px"
                    data-color-input
                  >
                  <input
                    type="text"
                    class="form-control"
                    id="color_text"
                    maxlength="7"
                    value="<%= tag.color || '' %>"
                    placeholder="<%= isNew ? '(prázdne = náhodná z palety)' : '' %>"
                    style="max-width:180px; font-family:var(--art-mono)"
                    data-color-text
                    aria-label="Hex hodnota farby"
                  >
                  <span
                    class="bz-tag-pill"
                    style="--bz-tag-color:<%= tag.color || '#9ca3af' %>;"
                    data-color-preview
                  >
                    <%= tag.name || 'náhľad' %>
                  </span>
                </div>

                <div style="display:flex; flex-wrap:wrap; gap:4px; margin-bottom:10px; align-items:center" role="group" aria-label="Paleta farieb">
                  <% palette.forEach(c => { %>
                    <button
                      type="button"
                      class="bz-color-chip"
                      data-color-chip="<%= c %>"
                      style="background:<%= c %>;"
                      title="<%= c %>"
                      aria-label="Vybrať farbu <%= c %>"
                    ></button>
                  <% }) %>
                  <button
                    type="button"
                    class="bz-art-btn bz-art-btn-sm" style="margin-left:8px"
                    data-color-clear
                    title="Vymazať — pri uložení sa vyberie náhodná z palety"
                  >
                    <i class="bi bi-shuffle"></i> Náhodná
                  </button>
                </div>

                <% if (errors.color) { %>
                  <div class="invalid-feedback d-block"><%= errors.color %></div>
                <% } else { %>
                  <span class="bz-art-hint">Hex #RRGGBB. Ak necháš prázdne, vyberie sa náhodná z palety.</span>
                <% } %>
              </div>

              <div style="margin-bottom:20px">
                <label for="description" class="bz-art-field-label">Popis</label>
                <textarea
                  class="form-control"
                  id="description"
                  name="description"
                  rows="3"
                ><%= tag.description || '' %></textarea>
                <span class="bz-art-hint" style="margin-top:4px">Voliteľný popis (zobrazí sa na stránke tagu).</span>
              </div>

              <div style="display:flex; gap:8px">
                <button type="submit" class="bz-art-btn bz-art-btn-accent">
                  <i class="bi bi-check-lg"></i>
                  <%= isNew ? 'Vytvoriť tag' : 'Uložiť zmeny' %>
                </button>
                <a href="/admin/tags" class="bz-art-btn">Zrušiť</a>
              </div>
            </form>

          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
