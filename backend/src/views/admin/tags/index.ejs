<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Tagy' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Tag bol vytvorený.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Tag bol upravený.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Tag bol zmazaný.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Tagy</h1>
            <p class="bz-art-header-sub">Kľúčové slová s farbou — pre filtrovanie a vizuálne odlíšenie článkov.</p>
          </div>
          <a href="/admin/tags/new" class="bz-art-btn bz-art-btn-accent">
            <i class="bi bi-plus-lg"></i> Nový tag
          </a>
        </div>

        <!-- Search -->
        <form method="GET" action="/admin/tags" class="bz-art-search">
          <div class="bz-art-search-wrap">
            <i class="bi bi-search bz-art-search-icon"></i>
            <input type="text" name="q" class="bz-art-search-input"
                   placeholder="Hľadať podľa názvu alebo slugu..." value="<%= query.q || '' %>">
          </div>
          <button type="submit" class="bz-art-btn bz-art-btn-sm"><i class="bi bi-search"></i></button>
          <% if (query.q) { %>
            <a href="/admin/tags" class="bz-art-btn bz-art-btn-sm">Vyčistiť</a>
          <% } %>
          <span style="font-family:var(--art-mono); font-size:11px; color:var(--art-text-subtle)">
            Spolu: <strong style="color:var(--art-text-muted)"><%= pagination.total %></strong>
          </span>
        </form>

        <!-- Table -->
        <% if (tags.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-tags bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">
              <% if (query.q) { %>
                Žiadne tagy nezodpovedajú hľadaniu „<strong><%= query.q %></strong>".
              <% } else { %>
                Žiadne tagy. Vytvor prvý cez tlačidlo vyššie.
              <% } %>
            </p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th style="width:56px"></th>
                  <th>Názov</th>
                  <th>Slug</th>
                  <th>Popis</th>
                  <th style="width:120px; text-align:center">Články</th>
                  <th style="width:160px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% tags.forEach(t => { %>
                  <tr>
                    <td>
                      <span class="bz-tag-swatch"
                            style="background:<%= t.color || '#9ca3af' %>;"
                            title="<%= t.color || 'bez farby' %>"
                            aria-hidden="true"></span>
                    </td>
                    <td>
                      <span class="bz-tag-pill" style="--bz-tag-color:<%= t.color || '#9ca3af' %>;">
                        <%= t.name %>
                      </span>
                    </td>
                    <td>
                      <span class="bz-art-slug-cell"><%= t.slug %></span>
                    </td>
                    <td style="color:var(--art-text-muted); font-size:12px">
                      <% if (t.description) { %>
                        <%= t.description.length > 80 ? t.description.slice(0, 80) + '…' : t.description %>
                      <% } else { %>
                        <span style="color:var(--art-text-subtle)">—</span>
                      <% } %>
                    </td>
                    <td style="text-align:center">
                      <span class="bz-art-badge bz-art-badge-article"><%= t.article_count %></span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions">
                        <a href="/admin/tags/<%= t.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form method="POST" action="/admin/tags/<%= t.id %>/delete" class="d-inline"
                              data-confirm="Naozaj zmazať tag &quot;<%= t.name %>&quot;?">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (pg) => {
                const params = new URLSearchParams();
                if (query.q) params.set('q', query.q);
                if (pg > 1) params.set('page', pg);
                const qs = params.toString();
                return '/admin/tags' + (qs ? '?' + qs : '');
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const show = new Set([1, tot, cur - 1, cur, cur + 1, cur - 2, cur + 2]);
              const pgs = [...show].filter(pg => pg >= 1 && pg <= tot).sort((a, b) => a - b);
            %>
            <div class="bz-art-pagination">
              <a href="<%= cur > 1 ? buildHref(cur-1) : '#' %>" class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>">‹</a>
              <% pgs.forEach((pg, idx) => { %>
                <% if (idx > 0 && pgs[idx-1] < pg - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a href="<%= buildHref(pg) %>" class="bz-art-page-btn <%= pg === cur ? 'active' : '' %>"><%= pg %></a>
              <% }) %>
              <a href="<%= cur < tot ? buildHref(cur+1) : '#' %>" class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>">›</a>
            </div>
          <% } %>
        <% } %>

        <p class="bz-art-hint" style="margin-top:14px">
          <i class="bi bi-info-circle"></i>
          Tag nemožno zmazať, ak je priradený k článkom — najprv ho z nich odober.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
