<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Tagy' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% if (flash.created) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Tag bol vytvorený.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Tag bol upravený.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Tag bol zmazaný.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
          <div>
            <h1 class="h3 mb-1">Tagy</h1>
            <p class="text-muted mb-0 small">
              Kľúčové slová s farbou — pre filtrovanie a vizuálne odlíšenie článkov.
            </p>
          </div>
          <a href="/admin/tags/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nový tag
          </a>
        </div>

        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body">
            <form method="GET" action="/admin/tags" class="row g-2 align-items-center">
              <div class="col-12 col-md">
                <div class="input-group">
                  <span class="input-group-text"><i class="bi bi-search"></i></span>
                  <input
                    type="text"
                    name="q"
                    class="form-control"
                    placeholder="Hľadať podľa názvu alebo slugu..."
                    value="<%= query.q || '' %>"
                  >
                </div>
              </div>
              <div class="col-auto">
                <button type="submit" class="btn btn-outline-primary">Hľadať</button>
                <% if (query.q) { %>
                  <a href="/admin/tags" class="btn btn-outline-secondary">Vyčistiť</a>
                <% } %>
              </div>
              <div class="col-auto text-muted small">
                Spolu: <strong><%= pagination.total %></strong>
              </div>
            </form>
          </div>
        </div>

        <% if (tags.length === 0) { %>
          <div class="card border-0 shadow-sm">
            <div class="card-body text-center text-muted py-5">
              <i class="bi bi-tags fs-1 d-block mb-2 text-body-tertiary"></i>
              <% if (query.q) { %>
                Žiadne tagy nezodpovedajú hľadaniu „<strong><%= query.q %></strong>".
              <% } else { %>
                Žiadne tagy. Vytvor prvý cez tlačidlo vyššie.
              <% } %>
            </div>
          </div>
        <% } else { %>
          <div class="card border-0 shadow-sm">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th style="width: 56px;"></th>
                    <th>Názov</th>
                    <th>Slug</th>
                    <th>Popis</th>
                    <th class="text-center" style="width: 120px;">Články</th>
                    <th class="text-end" style="width: 160px;">Akcie</th>
                  </tr>
                </thead>
                <tbody>
                  <% tags.forEach(t => { %>
                    <tr>
                      <td>
                        <span
                          class="bz-tag-swatch"
                          style="background: <%= t.color || '#9ca3af' %>;"
                          title="<%= t.color || 'bez farby' %>"
                          aria-hidden="true"
                        ></span>
                      </td>
                      <td>
                        <span class="bz-tag-pill" style="--bz-tag-color: <%= t.color || '#9ca3af' %>;">
                          <%= t.name %>
                        </span>
                      </td>
                      <td><code class="small"><%= t.slug %></code></td>
                      <td class="text-muted small">
                        <% if (t.description) { %>
                          <%= t.description.length > 80 ? t.description.slice(0, 80) + '…' : t.description %>
                        <% } else { %>
                          <span class="text-body-tertiary">—</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <span class="badge text-bg-secondary"><%= t.article_count %></span>
                      </td>
                      <td class="text-end">
                        <a href="/admin/tags/<%= t.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Upraviť">
                          <i class="bi bi-pencil"></i>
                        </a>
                        <form
                          method="POST"
                          action="/admin/tags/<%= t.id %>/delete"
                          class="d-inline"
                          data-confirm="Naozaj zmazať tag &quot;<%= t.name %>&quot;?"
                        >
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-outline-danger" title="Zmazať">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <nav aria-label="Stránkovanie" class="mt-3">
              <ul class="pagination justify-content-center mb-0">
                <%
                  const buildHref = (p) => {
                    const params = new URLSearchParams();
                    if (query.q) params.set('q', query.q);
                    if (p > 1) params.set('page', p);
                    const qs = params.toString();
                    return '/admin/tags' + (qs ? '?' + qs : '');
                  };
                  const cur = pagination.page;
                  const tot = pagination.totalPages;
                  // jednoduchý windowed paging — max ~7 čísel
                  const show = new Set([1, tot, cur - 1, cur, cur + 1, cur - 2, cur + 2]);
                  const pages = [...show].filter(p => p >= 1 && p <= tot).sort((a, b) => a - b);
                %>
                <li class="page-item <%= cur <= 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur > 1 ? buildHref(cur - 1) : '#' %>" aria-label="Predošlá">
                    <i class="bi bi-chevron-left"></i>
                  </a>
                </li>
                <% pages.forEach((p, idx) => { %>
                  <% if (idx > 0 && pages[idx-1] < p - 1) { %>
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                  <% } %>
                  <li class="page-item <%= p === cur ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildHref(p) %>"><%= p %></a>
                  </li>
                <% }) %>
                <li class="page-item <%= cur >= tot ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= cur < tot ? buildHref(cur + 1) : '#' %>" aria-label="Ďalšia">
                    <i class="bi bi-chevron-right"></i>
                  </a>
                </li>
              </ul>
            </nav>
          <% } %>
        <% } %>

        <p class="text-muted small mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i>
          Tag nemožno zmazať, ak je priradený k článkom — najprv ho z nich odober.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
