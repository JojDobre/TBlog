<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: title }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.success) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> <%= flash.success %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Používatelia</h1>
            <p class="bz-art-header-sub">Správa registrovaných používateľov</p>
          </div>
        </div>

        <!-- Tabs -->
        <div class="bz-art-status-tabs">
          <% tabs.forEach(t => { %>
            <a class="bz-art-status-tab <%= activeTab === t.key ? 'active' : '' %>"
               href="/admin/users?tab=<%= t.key %>">
              <%= t.label %>
              <span class="bz-art-status-tab-badge"><%= counts[t.key] || 0 %></span>
            </a>
          <% }) %>
        </div>

        <!-- Search -->
        <form method="GET" action="/admin/users" class="bz-art-search">
          <input type="hidden" name="tab" value="<%= activeTab %>">
          <div class="bz-art-search-wrap">
            <i class="bi bi-search bz-art-search-icon"></i>
            <input type="text" name="q" class="bz-art-search-input"
                   placeholder="Hľadať podľa nicku alebo emailu..." value="<%= query.q || '' %>">
          </div>
          <button class="bz-art-btn bz-art-btn-sm" type="submit"><i class="bi bi-search"></i></button>
          <% if (query.q) { %>
            <a href="/admin/users?tab=<%= activeTab %>" class="bz-art-btn bz-art-btn-sm">Zrušiť</a>
          <% } %>
        </form>

        <!-- Table -->
        <% if (users.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-people bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">Žiadni používatelia.</p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th style="width:40px">#</th>
                  <th>Používateľ</th>
                  <th>Email</th>
                  <th style="width:90px">Rola</th>
                  <th style="width:80px">Stav</th>
                  <th style="width:110px">Registrácia</th>
                  <th style="width:110px">Posl. login</th>
                  <th style="width:60px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                  <tr style="<%= u.is_banned ? 'background:oklch(0.62 0.21 25/0.06)' : '' %>">
                    <td>
                      <span style="color:var(--art-text-subtle); font-family:var(--art-mono); font-size:11px"><%= u.id %></span>
                    </td>
                    <td>
                      <a href="/admin/users/<%= u.id %>" class="bz-art-title-link" style="font-size:13px; display:flex; align-items:center; gap:8px">
                        <% if (u.avatar_path) { %>
                          <img src="/uploads/<%= u.avatar_path %>" alt=""
                               style="width:24px; height:24px; border-radius:50%; object-fit:cover; flex-shrink:0">
                        <% } else { %>
                          <div style="width:24px; height:24px; border-radius:50%; background:oklch(0.3 0.01 240); display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:10px; color:var(--art-text-subtle); font-weight:600">
                            <%= (u.nickname || '?').charAt(0).toUpperCase() %>
                          </div>
                        <% } %>
                        <%= u.nickname %>
                      </a>
                    </td>
                    <td>
                      <span style="font-size:12px; color:var(--art-text-muted)"><%= u.email || '—' %></span>
                    </td>
                    <td>
                      <%
                        const roleBadge = {
                          admin:  'bz-art-badge-trash',
                          editor: 'bz-art-badge-scheduled',
                          reader: 'bz-art-badge-article',
                        };
                      %>
                      <span class="bz-art-badge <%= roleBadge[u.role] || 'bz-art-badge-draft' %>"><%= u.role %></span>
                    </td>
                    <td>
                      <% if (u.is_banned) { %>
                        <span class="bz-art-badge bz-art-badge-trash">banned</span>
                      <% } else { %>
                        <span class="bz-art-badge bz-art-badge-published">aktívny</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="bz-art-time-val">
                        <%= new Date(u.created_at).toLocaleDateString('sk-SK') %>
                      </span>
                    </td>
                    <td>
                      <span class="bz-art-time-val">
                        <%= u.last_login_at ? new Date(u.last_login_at).toLocaleDateString('sk-SK') : '—' %>
                      </span>
                    </td>
                    <td>
                      <div class="bz-art-row-actions" style="text-align:right">
                        <a href="/admin/users/<%= u.id %>" class="bz-art-btn bz-art-btn-sm" title="Detail">
                          <i class="bi bi-eye"></i>
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (pg) => {
                const params = new URLSearchParams();
                params.set('tab', activeTab);
                if (query.q) params.set('q', query.q);
                if (pg > 1) params.set('page', pg);
                return '/admin/users?' + params.toString();
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const show = new Set([1, tot, cur-1, cur, cur+1]);
              const pages = [...show].filter(pg => pg >= 1 && pg <= tot).sort((a,b) => a-b);
            %>
            <div class="bz-art-pagination">
              <a href="<%= cur > 1 ? buildHref(cur-1) : '#' %>" class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>">‹</a>
              <% pages.forEach((pg, idx) => { %>
                <% if (idx > 0 && pages[idx-1] < pg - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a href="<%= buildHref(pg) %>" class="bz-art-page-btn <%= pg === cur ? 'active' : '' %>"><%= pg %></a>
              <% }) %>
              <a href="<%= cur < tot ? buildHref(cur+1) : '#' %>" class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>">›</a>
            </div>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
