<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: title }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Komentár bol zmazaný.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.restored) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Komentár bol obnovený.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.resolved) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Nahlásenie bolo vyriešené.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Komentáre</h1>
            <p class="bz-art-header-sub">Správa komentárov a nahlásení</p>
          </div>
        </div>

        <!-- Tabs -->
        <div class="bz-art-status-tabs">
          <% tabs.forEach(t => { %>
            <a class="bz-art-status-tab <%= activeTab === t.key ? 'active' : '' %>"
               href="/admin/comments?tab=<%= t.key %>">
              <%= t.label %>
              <span class="bz-art-status-tab-badge"><%= counts[t.key] || 0 %></span>
            </a>
          <% }) %>
        </div>

        <!-- Search -->
        <form method="GET" action="/admin/comments" class="bz-art-search">
          <input type="hidden" name="tab" value="<%= activeTab %>">
          <div class="bz-art-search-wrap">
            <i class="bi bi-search bz-art-search-icon"></i>
            <input type="text" name="q" class="bz-art-search-input"
                   placeholder="Hľadať v komentároch..." value="<%= query.q || '' %>">
          </div>
          <button class="bz-art-btn bz-art-btn-sm" type="submit"><i class="bi bi-search"></i></button>
          <% if (query.q || query.article) { %>
            <a href="/admin/comments?tab=<%= activeTab %>" class="bz-art-btn bz-art-btn-sm">Zrušiť</a>
          <% } %>
          <% if (query.article) { %>
            <input type="hidden" name="article" value="<%= query.article %>">
            <span class="bz-art-badge bz-art-badge-review">
              Článok #<%= query.article %>
              <a href="/admin/comments?tab=<%= activeTab %>" style="color:inherit; margin-left:4px">&times;</a>
            </span>
          <% } %>
        </form>

        <!-- Table -->
        <% if (comments.length === 0) { %>
          <div class="bz-art-empty">
            <i class="bi bi-chat-dots bz-art-empty-icon"></i>
            <p class="bz-art-empty-text">Žiadne komentáre.</p>
          </div>
        <% } else { %>
          <div class="bz-art-table-wrap">
            <table class="bz-art-table">
              <thead>
                <tr>
                  <th style="width:40px">#</th>
                  <th>Komentár</th>
                  <th>Autor</th>
                  <th>Článok</th>
                  <th style="width:100px">Dátum</th>
                  <th style="width:60px">Report</th>
                  <th style="width:200px; text-align:right">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% comments.forEach(c => { %>
                  <tr style="<%= c.is_deleted_by_admin ? 'background:oklch(0.62 0.21 25/0.06)' : '' %><%= c.reports_count > 0 && !c.is_deleted_by_admin ? 'background:oklch(0.74 0.16 60/0.06)' : '' %>">
                    <td>
                      <span style="color:var(--art-text-subtle); font-family:var(--art-mono); font-size:11px"><%= c.id %></span>
                    </td>
                    <td>
                      <a href="/admin/comments/<%= c.id %>" class="bz-art-title-link" style="font-size:13px">
                        <% if (c.is_deleted_by_admin) { %>
                          <span style="color:var(--art-text-subtle); font-style:italic">[zmazané adminom]</span>
                        <% } else { %>
                          <%= c.content_short %>
                        <% } %>
                      </a>
                      <% if (c.parent_id) { %>
                        <span class="bz-art-badge bz-art-badge-article" style="margin-left:4px">odpoveď</span>
                      <% } %>
                    </td>
                    <td>
                      <span style="font-size:12px; color:var(--art-text-muted)"><%= c.nickname || '[zmazaný]' %></span>
                    </td>
                    <td>
                      <% if (c.article_title) { %>
                        <a href="/admin/comments?article=<%= c.article_id %>" style="font-size:12px; color:var(--art-text-muted); text-decoration:none">
                          <%= c.article_title.length > 40 ? c.article_title.slice(0, 40) + '…' : c.article_title %>
                        </a>
                      <% } else { %>
                        <span style="font-size:12px; color:var(--art-text-subtle)">[zmazaný]</span>
                      <% } %>
                    </td>
                    <td>
                      <span class="bz-art-time-val">
                        <%= new Date(c.created_at).toLocaleDateString('sk-SK') %>
                      </span>
                    </td>
                    <td style="text-align:center">
                      <% if (c.reports_count > 0) { %>
                        <span class="bz-art-badge bz-art-badge-trash"><%= c.reports_count %></span>
                      <% } %>
                    </td>
                    <td>
                      <div class="bz-art-row-actions" style="width:180px; text-align:right">
                        <a href="/admin/comments/<%= c.id %>" class="bz-art-btn bz-art-btn-sm" title="Detail">
                          <i class="bi bi-eye"></i>
                        </a>
                        <% if (c.article_slug) { %>
                          <a href="/<%= c.article_type === 'review' ? 'recenzia' : 'clanok' %>/<%= c.article_slug %>"
                             class="bz-art-btn bz-art-btn-sm" target="_blank" title="Zobraziť na webe">
                            <i class="bi bi-box-arrow-up-right"></i>
                          </a>
                        <% } %>
                        <form method="POST" action="/admin/comments/<%= c.id %>/toggle-delete" class="d-inline">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="bz-art-btn bz-art-btn-sm <%= c.is_deleted_by_admin ? '' : 'bz-art-btn-danger' %>"
                                  title="<%= c.is_deleted_by_admin ? 'Obnoviť' : 'Skryť' %>">
                            <i class="bi bi-<%= c.is_deleted_by_admin ? 'arrow-counterclockwise' : 'eye-slash' %>"></i>
                          </button>
                        </form>
                        <form method="POST" action="/admin/comments/<%= c.id %>/hard-delete" class="d-inline"
                              data-confirm="Permanentne zmazať komentár #<%= c.id %>? Táto akcia je nevratná.">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Permanentne zmazať">
                            <i class="bi bi-x-lg"></i>
                          </button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <% if (pagination.totalPages > 1) { %>
            <%
              const buildHref = (pg) => {
                const params = new URLSearchParams();
                params.set('tab', activeTab);
                if (query.q) params.set('q', query.q);
                if (query.article) params.set('article', query.article);
                if (pg > 1) params.set('page', pg);
                return '/admin/comments?' + params.toString();
              };
              const cur = pagination.page;
              const tot = pagination.totalPages;
              const show = new Set([1, tot, cur-1, cur, cur+1]);
              const pages = [...show].filter(pg => pg >= 1 && pg <= tot).sort((a,b) => a-b);
            %>
            <div class="bz-art-pagination">
              <a href="<%= cur > 1 ? buildHref(cur-1) : '#' %>" class="bz-art-page-btn <%= cur <= 1 ? 'disabled' : '' %>">‹</a>
              <% pages.forEach((pg, idx) => { %>
                <% if (idx > 0 && pages[idx-1] < pg - 1) { %>
                  <span class="bz-art-page-ellipsis">…</span>
                <% } %>
                <a href="<%= buildHref(pg) %>" class="bz-art-page-btn <%= pg === cur ? 'active' : '' %>"><%= pg %></a>
              <% }) %>
              <a href="<%= cur < tot ? buildHref(cur+1) : '#' %>" class="bz-art-page-btn <%= cur >= tot ? 'disabled' : '' %>">›</a>
            </div>
          <% } %>
        <% } %>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
