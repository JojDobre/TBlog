<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: title }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

<div class="bz-art-breadcrumb" style="margin-bottom:20px">
  <a href="/admin/dashboard">Dashboard</a>
  <span class="bz-art-breadcrumb-sep">›</span>
  <a href="/admin/comments">Komentáre</a>
  <span class="bz-art-breadcrumb-sep">›</span>
  <span class="bz-art-breadcrumb-current">#<%= comment.id %></span>
</div>

        <div class="row g-4">
          <!-- Comment detail -->
          <div class="col-lg-8">
            <div class="bz-art-content-card">
              <div class="bz-art-content-head">
                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap">
                  <strong style="font-size:13px; color:var(--art-text)"><%= comment.nickname || '[zmazaný]' %></strong>
                  <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle)">
                    <%= new Date(comment.created_at).toLocaleString('sk-SK') %>
                  </span>
                  <% if (comment.parent_id) { %>
                    <span class="bz-art-badge bz-art-badge-article">odpoveď na #<%= comment.parent_id %></span>
                  <% } %>
                </div>
                <% if (comment.is_deleted_by_admin) { %>
                  <span class="bz-art-badge bz-art-badge-trash">Zmazané</span>
                <% } %>
              </div>
              <div class="bz-art-content-body">
                <% if (comment.is_deleted_by_admin) { %>
                  <p style="color:var(--art-text-subtle); font-style:italic; margin-bottom:8px">[Tento komentár bol skrytý administrátorom]</p>
                  <p style="margin:0; opacity:0.5; white-space:pre-wrap; color:var(--art-text-muted)"><%= comment.content %></p>
                <% } else { %>
                  <p style="margin:0; white-space:pre-wrap; color:var(--art-text)"><%= comment.content %></p>
                <% } %>
              </div>
              <div style="padding:12px 20px; border-top:1px solid var(--art-border); display:flex; gap:8px; flex-wrap:wrap">
                <% if (comment.article_title) { %>
                  <a href="/<%= comment.article_type === 'review' ? 'recenzia' : 'clanok' %>/<%= comment.article_slug %>"
                     class="bz-art-btn bz-art-btn-sm" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i> <%= comment.article_title %>
                  </a>
                <% } %>

                <form method="POST" action="/admin/comments/<%= comment.id %>/toggle-delete">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="bz-art-btn bz-art-btn-sm <%= comment.is_deleted_by_admin ? '' : 'bz-art-btn-danger' %>">
                    <i class="bi bi-<%= comment.is_deleted_by_admin ? 'arrow-counterclockwise' : 'eye-slash' %>"></i>
                    <%= comment.is_deleted_by_admin ? 'Obnoviť' : 'Skryť komentár' %>
                  </button>
                </form>

                <form method="POST" action="/admin/comments/<%= comment.id %>/hard-delete"
                      data-confirm="Permanentne zmazať komentár #<%= comment.id %>? Táto akcia je nevratná.">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="bz-art-btn bz-art-btn-sm bz-art-btn-danger">
                    <i class="bi bi-trash"></i> Permanentne zmazať
                  </button>
                </form>
              </div>
            </div>

            <!-- Meta info -->
            <div class="bz-art-content-card" style="margin-top:14px">
              <div class="bz-art-content-body" style="display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:10px">
                <div>
                  <span class="bz-art-field-label">ID</span>
                  <span style="font-size:13px; color:var(--art-text-muted)"><%= comment.id %></span>
                </div>
                <div>
                  <span class="bz-art-field-label">Článok</span>
                  <a href="/admin/comments?article=<%= comment.article_id %>" style="font-size:13px; color:var(--art-accent); text-decoration:none">#<%= comment.article_id %></a>
                </div>
                <div>
                  <span class="bz-art-field-label">User</span>
                  <span style="font-size:13px; color:var(--art-text-muted)"><%= comment.nickname %> (#<%= comment.user_id %>)</span>
                </div>
                <div>
                  <span class="bz-art-field-label">Vytvorený</span>
                  <span style="font-size:13px; color:var(--art-text-muted)"><%= new Date(comment.created_at).toLocaleString('sk-SK') %></span>
                </div>
                <div>
                  <span class="bz-art-field-label">Upravený</span>
                  <span style="font-size:13px; color:var(--art-text-muted)"><%= new Date(comment.updated_at).toLocaleString('sk-SK') %></span>
                </div>
              </div>
            </div>
          </div>

          <!-- Reports -->
          <div class="col-lg-4">
            <div class="bz-art-side-card">
              <div class="bz-art-side-head">
                <i class="bi bi-flag"></i> Nahlásenia
                <span class="bz-art-status-tab-badge" style="margin-left:auto"><%= reports.length %></span>
              </div>
              <% if (reports.length === 0) { %>
                <div style="text-align:center; padding:28px 14px; color:var(--art-text-subtle)">
                  <i class="bi bi-check-circle" style="font-size:2rem; display:block; margin-bottom:8px"></i>
                  <span style="font-size:12px">Žiadne nahlásenia</span>
                </div>
              <% } else { %>
                <div style="display:flex; flex-direction:column">
                  <% reports.forEach(r => { %>
                    <div style="padding:12px 14px; border-bottom:1px solid oklch(from var(--art-border) l c h/.5); <%= r.is_resolved ? 'opacity:0.7' : '' %>">
                      <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px">
                        <strong style="font-size:12px; color:var(--art-text)"><%= r.reporter_nickname || '[zmazaný]' %></strong>
                        <% if (r.is_resolved) { %>
                          <span class="bz-art-badge bz-art-badge-published">Vyriešené</span>
                        <% } else { %>
                          <span class="bz-art-badge bz-art-badge-scheduled">Otvorené</span>
                        <% } %>
                      </div>
                      <% if (r.reason) { %>
                        <p style="font-size:12px; color:var(--art-text-muted); margin:0 0 6px"><%= r.reason %></p>
                      <% } else { %>
                        <p style="font-size:12px; color:var(--art-text-subtle); font-style:italic; margin:0 0 6px">Bez udania dôvodu</p>
                      <% } %>
                      <div style="display:flex; justify-content:space-between; align-items:center">
                        <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle)"><%= new Date(r.created_at).toLocaleString('sk-SK') %></span>
                        <% if (!r.is_resolved) { %>
                          <form method="POST" action="/admin/comments/reports/<%= r.id %>/resolve" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="bz-art-btn bz-art-btn-sm" style="padding:3px 8px; font-size:11px">
                              <i class="bi bi-check-lg"></i> Vyriešiť
                            </button>
                          </form>
                        <% } else { %>
                          <span style="font-family:var(--art-mono); font-size:10px; color:var(--art-text-subtle)">
                            <%= r.resolver_nickname || '' %>
                            <% if (r.resolved_at) { %>
                              · <%= new Date(r.resolved_at).toLocaleDateString('sk-SK') %>
                            <% } %>
                          </span>
                        <% } %>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
