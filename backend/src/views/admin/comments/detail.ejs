<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: title }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid py-4">

        <a href="/admin/comments" class="btn btn-sm btn-outline-secondary mb-3">
          <i class="bi bi-arrow-left me-1"></i>Späť na zoznam
        </a>

        <div class="row g-4">
          <%# Comment detail %>
          <div class="col-lg-8">
            <div class="card">
              <div class="card-header d-flex align-items-center justify-content-between">
                <span>
                  <strong><%= comment.nickname || '[zmazaný]' %></strong>
                  <small class="text-muted ms-2">
                    <%= new Date(comment.created_at).toLocaleString('sk-SK') %>
                  </small>
                  <% if (comment.parent_id) { %>
                    <span class="badge bg-light text-muted ms-1">odpoveď na #<%= comment.parent_id %></span>
                  <% } %>
                </span>
                <% if (comment.is_deleted_by_admin) { %>
                  <span class="badge bg-danger">Zmazané</span>
                <% } %>
              </div>
              <div class="card-body">
                <% if (comment.is_deleted_by_admin) { %>
                  <p class="text-muted fst-italic mb-2">[Tento komentár bol skrytý administrátorom]</p>
                  <p class="mb-0" style="opacity:0.5;"><%= comment.content %></p>
                <% } else { %>
                  <p class="mb-0" style="white-space:pre-wrap;"><%= comment.content %></p>
                <% } %>
              </div>
              <div class="card-footer d-flex gap-2 flex-wrap">
                <% if (comment.article_title) { %>
                  <a href="/<%= comment.article_type === 'review' ? 'recenzia' : 'clanok' %>/<%= comment.article_slug %>"
                     class="btn btn-sm btn-outline-secondary" target="_blank">
                    <i class="bi bi-box-arrow-up-right me-1"></i><%= comment.article_title %>
                  </a>
                <% } %>

                <form method="POST" action="/admin/comments/<%= comment.id %>/toggle-delete">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm <%= comment.is_deleted_by_admin ? 'btn-success' : 'btn-warning' %>">
                    <i class="bi bi-<%= comment.is_deleted_by_admin ? 'arrow-counterclockwise' : 'eye-slash' %> me-1"></i>
                    <%= comment.is_deleted_by_admin ? 'Obnoviť' : 'Skryť komentár' %>
                  </button>
                </form>

                <form method="POST" action="/admin/comments/<%= comment.id %>/hard-delete"
                      data-confirm="Permanentne zmazať komentár #<%= comment.id %>? Táto akcia je nevratná.">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <button class="btn btn-sm btn-danger">
                    <i class="bi bi-trash me-1"></i>Permanentne zmazať
                  </button>
                </form>
              </div>
            </div>

            <%# Meta info %>
            <div class="card mt-3">
              <div class="card-body">
                <div class="row text-muted small">
                  <div class="col-sm-4">
                    <strong>ID:</strong> <%= comment.id %>
                  </div>
                  <div class="col-sm-4">
                    <strong>Článok:</strong>
                    <a href="/admin/comments?article=<%= comment.article_id %>">#<%= comment.article_id %></a>
                  </div>
                  <div class="col-sm-4">
                    <strong>User:</strong> <%= comment.nickname %> (#<%= comment.user_id %>)
                  </div>
                  <div class="col-sm-4 mt-2">
                    <strong>Vytvorený:</strong> <%= new Date(comment.created_at).toLocaleString('sk-SK') %>
                  </div>
                  <div class="col-sm-4 mt-2">
                    <strong>Upravený:</strong> <%= new Date(comment.updated_at).toLocaleString('sk-SK') %>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <%# Reports %>
          <div class="col-lg-4">
            <div class="card">
              <div class="card-header">
                <i class="bi bi-flag me-1"></i>
                Nahlásenia
                <span class="badge bg-secondary ms-1"><%= reports.length %></span>
              </div>
              <% if (reports.length === 0) { %>
                <div class="card-body text-center text-muted py-4">
                  <i class="bi bi-check-circle display-6"></i>
                  <p class="mt-2 mb-0">Žiadne nahlásenia</p>
                </div>
              <% } else { %>
                <ul class="list-group list-group-flush">
                  <% reports.forEach(r => { %>
                    <li class="list-group-item <%= r.is_resolved ? 'bg-light' : '' %>">
                      <div class="d-flex justify-content-between align-items-start mb-1">
                        <small class="fw-bold"><%= r.reporter_nickname || '[zmazaný]' %></small>
                        <% if (r.is_resolved) { %>
                          <span class="badge bg-success">Vyriešené</span>
                        <% } else { %>
                          <span class="badge bg-warning text-dark">Otvorené</span>
                        <% } %>
                      </div>
                      <% if (r.reason) { %>
                        <p class="small mb-1"><%= r.reason %></p>
                      <% } else { %>
                        <p class="small text-muted fst-italic mb-1">Bez udania dôvodu</p>
                      <% } %>
                      <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted"><%= new Date(r.created_at).toLocaleString('sk-SK') %></small>
                        <% if (!r.is_resolved) { %>
                          <form method="POST" action="/admin/comments/reports/<%= r.id %>/resolve" class="d-inline">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button class="btn btn-sm btn-outline-success py-0 px-2">
                              <i class="bi bi-check-lg me-1"></i>Vyriešiť
                            </button>
                          </form>
                        <% } else { %>
                          <small class="text-muted">
                            <%= r.resolver_nickname || '' %>
                            <% if (r.resolved_at) { %>
                              · <%= new Date(r.resolved_at).toLocaleDateString('sk-SK') %>
                            <% } %>
                          </small>
                        <% } %>
                      </div>
                    </li>
                  <% }) %>
                </ul>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
