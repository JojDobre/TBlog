<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: 'Rubriky' }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <% if (flash.created) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rubrika bola vytvorená.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rubrika bola upravená.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>Rubrika bola zmazaná.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i><%= flash.err %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zatvoriť"></button>
          </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h1 class="h3 mb-1">Rubriky</h1>
            <p class="text-muted mb-0 small">
              Veľké sekcie webu (Recenzie, Návody, Aktuality, Rebríčky).
              Sú ploché, bez hierarchie.
            </p>
          </div>
          <a href="/admin/rubrics/new" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i>Nová rubrika
          </a>
        </div>

        <div class="card border-0 shadow-sm">
          <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th style="width: 80px;">Poradie</th>
                  <th>Názov</th>
                  <th>Slug</th>
                  <th>Popis</th>
                  <th class="text-center" style="width: 120px;">Články</th>
                  <th class="text-end" style="width: 160px;">Akcie</th>
                </tr>
              </thead>
              <tbody>
                <% if (rubrics.length === 0) { %>
                  <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                      Žiadne rubriky. Vytvor prvú cez tlačidlo vyššie.
                    </td>
                  </tr>
                <% } %>
                <% rubrics.forEach(r => { %>
                  <tr>
                    <td><span class="badge text-bg-light"><%= r.display_order %></span></td>
                    <td>
                      <strong><%= r.name %></strong>
                    </td>
                    <td>
                      <code class="small"><%= r.slug %></code>
                    </td>
                    <td class="text-muted small">
                      <% if (r.description) { %>
                        <%= r.description.length > 100 ? r.description.slice(0, 100) + '…' : r.description %>
                      <% } else { %>
                        <span class="text-body-tertiary">—</span>
                      <% } %>
                    </td>
                    <td class="text-center">
                      <span class="badge text-bg-secondary"><%= r.article_count %></span>
                    </td>
                    <td class="text-end">
                      <a href="/admin/rubrics/<%= r.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Upraviť">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form
                        method="POST"
                        action="/admin/rubrics/<%= r.id %>/delete"
                        class="d-inline"
                        data-confirm="Naozaj zmazať rubriku &quot;<%= r.name %>&quot;?"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Zmazať">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <p class="text-muted small mt-3 mb-0">
          <i class="bi bi-info-circle me-1"></i>
          Rubriku nemožno zmazať, ak je priradená k článkom — najprv ju z nich odober.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
