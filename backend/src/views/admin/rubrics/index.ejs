<!doctype html>
<html lang="sk" data-bs-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Rubriky' }) %>
</head>
<body class="bz-admin-body bz-art-page">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="bz-art-wrap">

        <% if (flash.created) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rubrika bola vytvorená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.updated) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rubrika bola upravená.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.deleted) { %>
          <div class="bz-art-alert bz-art-alert-success">
            <i class="bi bi-check-circle-fill"></i> Rubrika bola zmazaná.
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>
        <% if (flash.err) { %>
          <div class="bz-art-alert bz-art-alert-error">
            <i class="bi bi-exclamation-triangle-fill"></i> <%= flash.err %>
            <button class="bz-art-alert-close" data-bs-dismiss="alert" aria-label="Zatvoriť">×</button>
          </div>
        <% } %>

        <!-- Header -->
        <div class="bz-art-header">
          <div>
            <h1 class="bz-art-header-title">Rubriky</h1>
            <p class="bz-art-header-sub">Veľké sekcie webu (Recenzie, Návody, Aktuality, Rebríčky). Sú ploché, bez hierarchie.</p>
          </div>
          <a href="/admin/rubrics/new" class="bz-art-btn bz-art-btn-accent">
            <i class="bi bi-plus-lg"></i> Nová rubrika
          </a>
        </div>

        <!-- Tabuľka -->
        <div class="bz-art-table-wrap">
          <table class="bz-art-table">
            <thead>
              <tr>
                <th style="width:80px">Poradie</th>
                <th>Názov</th>
                <th>Slug</th>
                <th>Popis</th>
                <th style="width:120px; text-align:center">Články</th>
                <th style="width:160px; text-align:right">Akcie</th>
              </tr>
            </thead>
            <tbody>
              <% if (rubrics.length === 0) { %>
                <tr>
                  <td colspan="6" class="bz-art-empty" style="padding:40px">
                    Žiadne rubriky. Vytvor prvú cez tlačidlo vyššie.
                  </td>
                </tr>
              <% } %>
              <% rubrics.forEach(r => { %>
                <tr>
                  <td>
                    <span class="bz-art-badge bz-art-badge-article" style="font-family:var(--art-mono)"><%= r.display_order %></span>
                  </td>
                  <td>
                    <strong style="color:var(--art-text); font-size:13.5px"><%= r.name %></strong>
                  </td>
                  <td>
                    <span class="bz-art-slug-cell"><%= r.slug %></span>
                  </td>
                  <td class="bz-art-meta-text">
                    <% if (r.description) { %>
                      <%= r.description.length > 100 ? r.description.slice(0, 100) + '…' : r.description %>
                    <% } else { %>
                      <span style="color:var(--art-text-subtle)">—</span>
                    <% } %>
                  </td>
                  <td style="text-align:center">
                    <span class="bz-art-badge bz-art-badge-article"><%= r.article_count %></span>
                  </td>
                  <td>
                    <div class="bz-art-row-actions">
                      <a href="/admin/rubrics/<%= r.id %>/edit" class="bz-art-btn bz-art-btn-sm" title="Upraviť">
                        <i class="bi bi-pencil"></i>
                      </a>
                      <form
                        method="POST"
                        action="/admin/rubrics/<%= r.id %>/delete"
                        class="d-inline"
                        data-confirm="Naozaj zmazať rubriku &quot;<%= r.name %>&quot;?"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <button type="submit" class="bz-art-btn bz-art-btn-sm bz-art-btn-danger" title="Zmazať">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Info poznámka -->
        <p class="bz-art-hint" style="margin-top:14px">
          <i class="bi bi-info-circle"></i>
          Rubriku nemožno zmazať, ak je priradená k článkom — najprv ju z nich odober.
        </p>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
  <script src="/admin/static/js/admin-taxonomy.js" defer></script>
</body>
</html>
