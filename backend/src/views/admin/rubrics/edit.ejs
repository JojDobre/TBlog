<!doctype html>
<html lang="sk" data-bs-theme="light">
<head>
  <%- include('../partials/head', { title: pageTitle }) %>
</head>
<body class="bz-admin-body">
  <%- include('../partials/sidebar', { currentPath: currentPath }) %>

  <div class="bz-main">
    <%- include('../partials/topbar', { pageTitle: pageTitle }) %>

    <main class="bz-content">
      <div class="container-fluid p-4">

        <nav aria-label="breadcrumb" class="mb-3">
          <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item"><a href="/admin/dashboard">Dashboard</a></li>
            <li class="breadcrumb-item"><a href="/admin/rubrics">Rubriky</a></li>
            <li class="breadcrumb-item active" aria-current="page">
              <%= isNew ? 'Nová' : (rubric.name || 'Upraviť') %>
            </li>
          </ol>
        </nav>

        <div class="row">
          <div class="col-lg-8 col-xl-7">
            <div class="card border-0 shadow-sm">
              <div class="card-header bg-white">
                <h2 class="h5 mb-0"><%= pageTitle %></h2>
              </div>
              <div class="card-body">

                <% if (Object.keys(errors).length > 0) { %>
                  <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Skontroluj chyby vo formulári nižšie.
                  </div>
                <% } %>

                <form
                  method="POST"
                  action="<%= isNew ? '/admin/rubrics' : ('/admin/rubrics/' + rubric.id) %>"
                  novalidate
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

                  <div class="mb-3">
                    <label for="name" class="form-label">
                      Názov <span class="text-danger">*</span>
                    </label>
                    <input
                      type="text"
                      class="form-control <%= errors.name ? 'is-invalid' : '' %>"
                      id="name"
                      name="name"
                      maxlength="80"
                      required
                      autofocus
                      value="<%= rubric.name || '' %>"
                    >
                    <% if (errors.name) { %>
                      <div class="invalid-feedback"><%= errors.name %></div>
                    <% } else { %>
                      <div class="form-text">Max 80 znakov.</div>
                    <% } %>
                  </div>

                  <div class="mb-3">
                    <label for="slug" class="form-label">Slug</label>
                    <input
                      type="text"
                      class="form-control <%= errors.slug ? 'is-invalid' : '' %>"
                      id="slug"
                      name="slug"
                      maxlength="120"
                      pattern="[a-z0-9]+(-[a-z0-9]+)*"
                      value="<%= rubric.slug || '' %>"
                      placeholder="<%= isNew ? 'Nechaj prázdne pre automatické generovanie' : '' %>"
                    >
                    <% if (errors.slug) { %>
                      <div class="invalid-feedback"><%= errors.slug %></div>
                    <% } else { %>
                      <div class="form-text">
                        Časť URL — len <code>a-z</code>, <code>0-9</code> a pomlčky.
                        Ak nezadáš, vygeneruje sa z názvu.
                      </div>
                    <% } %>
                  </div>

                  <div class="mb-3">
                    <label for="description" class="form-label">Popis</label>
                    <textarea
                      class="form-control"
                      id="description"
                      name="description"
                      rows="3"
                    ><%= rubric.description || '' %></textarea>
                    <div class="form-text">Voliteľný popis sekcie (zobrazí sa na listing stránke).</div>
                  </div>

                  <div class="mb-4">
                    <label for="display_order" class="form-label">Poradie zobrazenia</label>
                    <input
                      type="number"
                      class="form-control <%= errors.display_order ? 'is-invalid' : '' %>"
                      id="display_order"
                      name="display_order"
                      min="0"
                      max="99999"
                      style="max-width: 140px;"
                      value="<%= rubric.display_order != null ? rubric.display_order : 0 %>"
                    >
                    <% if (errors.display_order) { %>
                      <div class="invalid-feedback"><%= errors.display_order %></div>
                    <% } else { %>
                      <div class="form-text">Nižšie číslo = vyššie v zozname. Default 0.</div>
                    <% } %>
                  </div>

                  <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                      <i class="bi bi-check-lg me-1"></i>
                      <%= isNew ? 'Vytvoriť rubriku' : 'Uložiť zmeny' %>
                    </button>
                    <a href="/admin/rubrics" class="btn btn-outline-secondary">Zrušiť</a>
                  </div>
                </form>

              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>

  <%- include('../partials/scripts') %>
</body>
</html>
