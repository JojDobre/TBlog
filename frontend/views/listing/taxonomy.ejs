<!doctype html>
<html lang="sk" data-theme="dark" data-density="comfortable" data-cardstyle="bordered">
<head>
  <%- include('../partials/head', { title: pageTitle, description: pageTitle + ' — ' + appName }) %>
</head>
<body>
  <%- include('../partials/header', { currentPath: currentPath }) %>

  <main class="page">
    <div class="container">

      <nav class="article-breadcrumb">
        <a href="/">Domov</a>
        <span class="bc-sep"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span>
        <span class="bc-current"><%= pageTitle %></span>
      </nav>

      <header class="listing-header" style="border-bottom:1px solid var(--border); padding-bottom:var(--s-8);">
        <div class="listing-header-left">
          <span class="eyebrow"><%= eyebrow %></span>
          <h1 class="h-1" style="margin:16px 0 12px;"><%= pageTitle %></h1>
          <p class="lead" style="max-width:600px;"><%= subtitle %></p>
        </div>
      </header>

      <div class="taxonomy-grid">
        <% items.forEach(item => { %>
          <a href="<%= item.href %>" class="taxonomy-card card card-link">
            <div class="taxonomy-card-icon">
              <% if (item.color) { %>
                <span style="width:12px;height:12px;border-radius:50%;background:<%= item.color %>;"></span>
              <% } else { %>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <% if (taxonomyType === 'category') { %>
                    <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                  <% } else if (taxonomyType === 'rubric') { %>
                    <rect x="4" y="4" width="16" height="16" rx="2"/><path d="M8 9h8M8 13h8M8 17h5"/>
                  <% } else { %>
                    <path d="M20 12l-8 8a2 2 0 0 1-2.8 0L3 13.8a2 2 0 0 1 0-2.8L11 3h9v9z"/><circle cx="16" cy="8" r="1.5"/>
                  <% } %>
                </svg>
              <% } %>
            </div>
            <div class="taxonomy-card-body">
              <h3 class="taxonomy-card-name"><%= item.name %></h3>
              <span class="taxonomy-card-count"><%= item.count %> článkov</span>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="taxonomy-card-arrow"><path d="M9 6l6 6-6 6"/></svg>
          </a>
        <% }) %>
      </div>

    </div>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/site.js" defer></script>
</body>
</html>