<!doctype html>
<html lang="sk" data-theme="dark">
<head>
  <%- include('../partials/head', { title: 'Chyba servera' }) %>
</head>
<body>
  <%- include('../partials/header', { currentPath: '' }) %>

  <main class="page">
    <div class="container">
      <div class="error-page">
        <div class="error-glow error-glow--red"></div>
        <div class="error-code error-code--red">500​</div>
        <h1 class="error-title">Niečo sa pokazilo</h1>
        <p class="error-desc">Server narazil na neočakávanú chybu. Skús to o chvíľu znova. Ak problém pretrváva, kontaktuj nás.</p>
        <div class="error-actions">
          <a href="/" class="btn btn-accent btn-lg">Na hlavnú stránku</a>
          <a href="javascript:location.reload()" class="btn btn-lg">Skúsiť znova</a>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
