<!doctype html>
<html lang="sk">
<head>
  <%- include('../partials/head', { title: title }) %>
</head>
<body>
  <%- include('../partials/header', { currentPath: currentPath }) %>

  <main class="site-main">
    <div class="site-container">
      <section class="error-page error-page--500">
        <div class="error-page__code"><%= status %></div>
        <h1><%= title %></h1>
        <p><%= message %></p>

        <% if (stack) { %>
          <details>
            <summary>Detail chyby (dev only)</summary>
            <pre><%= stack %></pre>
          </details>
        <% } %>

        <p><a href="/">← Späť na úvod</a></p>
      </section>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
