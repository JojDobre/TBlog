<!doctype html>
<html lang="sk">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %> — Bytezone</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      max-width: 720px;
      margin: 4rem auto;
      padding: 0 1.5rem;
      line-height: 1.6;
    }
    .code { font-size: 5rem; font-weight: 700; margin: 0; color: #d0d7de; text-align: center; }
    h1 { margin: 0.5rem 0 1rem; text-align: center; }
    .msg { text-align: center; color: #666; }
    pre {
      background: #f6f8fa;
      border: 1px solid #d0d7de;
      border-radius: 8px;
      padding: 1rem;
      overflow: auto;
      font-size: 0.85rem;
      margin-top: 2rem;
    }
    a { color: #0969da; text-decoration: none; }
    a:hover { text-decoration: underline; }
    @media (prefers-color-scheme: dark) {
      .code { color: #30363d; }
      .msg { color: #999; }
      pre { background: #161b22; border-color: #30363d; }
      a { color: #58a6ff; }
    }
  </style>
</head>
<body>
  <p class="code"><%= status %></p>
  <h1><%= title %></h1>
  <p class="msg"><%= message %></p>
  <% if (stack) { %>
    <pre><%= stack %></pre>
  <% } %>
  <p style="text-align: center; margin-top: 2rem;"><a href="/">← Späť na úvod</a></p>
</body>
</html>
