<!doctype html>
<html lang="sk" data-theme="dark" data-density="comfortable" data-cardstyle="bordered">
<head>
  <%- include('../partials/head', {
    title: article.seo_title || article.title,
    description: article.seo_description || article.excerpt || ''
  }) %>
  <% if (ogImage) { %><meta property="og:image" content="<%= ogImage %>"><% } %>
  <meta property="og:title" content="<%= article.seo_title || article.title %>">
  <meta property="og:type" content="article">
</head>
<body>
  <%- include('../partials/header', { currentPath: '/recenzie' }) %>

  <main class="page">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="article-breadcrumb">
        <a href="/">Domov</a>
        <span class="bc-sep"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span>
        <% if (category) { %>
          <a href="/kategorie/<%= category.slug %>"><%= category.name %></a>
          <span class="bc-sep"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg></span>
        <% } %>
        <span class="bc-current"><%= article.title %></span>
      </nav>

      <!-- Header — split layout -->
      <header class="review-header">
        <div class="review-header-text">
          <span class="eyebrow">Recenzia<% if (category) { %> · <%= category.name %><% } %></span>
          <h1 class="h-1" style="margin:16px 0;"><%= article.title %></h1>
          <% if (article.excerpt) { %>
            <p class="lead" style="max-width:520px;"><%= article.excerpt %></p>
          <% } %>
          <div class="review-header-author">
            <span class="avatar" style="width:36px;height:36px;font-size:13px;">
              <%= (article.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %>
            </span>
            <div>
              <div style="font-size:14px; font-weight:600;"><%= article.author_name || 'Redakcia' %></div>
              <div style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);">
                <%= article.published_at ? new Date(article.published_at).toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %>
                · <%= readTime %> čítania
              </div>
            </div>
          </div>
          <div style="display:flex; gap:8px; margin-top:24px;">
            <button class="btn btn-primary">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
              Uložiť recenziu
            </button>
            <button class="btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5L8.6 10.5"/></svg>
              Zdieľať
            </button>
          </div>
        </div>
        <div class="review-header-img">
          <% if (coverImage) { %>
            <img src="/uploads/<%= coverImage %>" alt="<%= article.title %>">
          <% } else { %>
            <div class="ph ph-<%= (article.id % 9) + 1 %>" style="aspect-ratio:auto; position:absolute; inset:0;"></div>
          <% } %>
        </div>
      </header>

      <!-- Verdict -->
      <section class="verdict">
        <div class="verdict-score">
          <span class="verdict-score-label">Celkové skóre</span>
          <span class="verdict-score-num"><%= reviewData.score ? reviewData.score.toFixed(1) : '—' %></span>
          <div class="verdict-stars">
            <% var fullStars = Math.round((reviewData.score || 0) / 2); %>
            <% for (var si = 0; si < 5; si++) { %>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="<%= si < fullStars ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5L12 3z"/></svg>
            <% } %>
          </div>
          <% if (reviewData.badge) { %>
            <span class="verdict-badge"><%= reviewData.badge %></span>
          <% } %>
        </div>
        <div class="verdict-text">
          <% if (reviewData.verdict_title) { %>
            <h3 class="h-3" style="margin:0 0 12px;"><%= reviewData.verdict_title %></h3>
          <% } %>
          <% if (reviewData.verdict_text) { %>
            <p style="color:var(--text-muted); font-size:16px; line-height:1.6; margin:0;"><%= reviewData.verdict_text %></p>
          <% } %>
        </div>
      </section>

      <!-- Breakdown + Specs -->
      <div class="review-details">
        <% if (reviewData.breakdown && reviewData.breakdown.length > 0) { %>
          <div>
            <h3 class="h-4" style="margin-bottom:24px;">Hodnotenie podľa kategórií</h3>
            <div class="score-bd">
              <% reviewData.breakdown.forEach(b => { %>
                <div class="score-bd-row">
                  <span class="score-bd-label"><%= b.label %></span>
                  <div class="score-bar"><i style="width:<%= b.val * 10 %>%;"></i></div>
                  <span class="score-bd-val"><%= b.val.toFixed(1) %></span>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

        <% if (reviewData.specs && reviewData.specs.length > 0) { %>
          <div>
            <h3 class="h-4" style="margin-bottom:24px;">Špecifikácie</h3>
            <table class="spec-table">
              <tbody>
                <% reviewData.specs.forEach(s => { %>
                  <tr><th><%= s.label %></th><td><%= s.value %></td></tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Pros / Cons -->
      <% if ((reviewData.pros && reviewData.pros.length > 0) || (reviewData.cons && reviewData.cons.length > 0)) { %>
        <div class="proscons">
          <% if (reviewData.pros && reviewData.pros.length > 0) { %>
            <div class="proscons-col proscons-col--pros">
              <h6 class="proscons-title proscons-title--pros">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
                Páči sa nám
              </h6>
              <ul>
                <% reviewData.pros.forEach(p => { %><li><%= p %></li><% }) %>
              </ul>
            </div>
          <% } %>
          <% if (reviewData.cons && reviewData.cons.length > 0) { %>
            <div class="proscons-col proscons-col--cons">
              <h6 class="proscons-title proscons-title--cons">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
                Zamyslíme sa
              </h6>
              <ul>
                <% reviewData.cons.forEach(c => { %><li><%= c %></li><% }) %>
              </ul>
            </div>
          <% } %>
        </div>
      <% } %>






