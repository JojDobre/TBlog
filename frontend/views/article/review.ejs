<!doctype html>
<html lang="sk" data-theme="dark" data-density="comfortable" data-cardstyle="bordered">

<head>
  <%- include('../partials/head', {
    title: article.seo_title || article.title,
    description: article.seo_description || article.excerpt || ''
  }) %>
  <% if (ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>"><% } %>
  <meta property="og:title" content="<%= article.seo_title || article.title %>">
  <meta property="og:type" content="article">
</head>

<body>
  <%- include('../partials/header', { currentPath: '/recenzie' }) %>

  <main class="page">
    <div class="container">

      <!-- Breadcrumb -->
      <nav class="article-breadcrumb">
        <a href="/">Domov</a>
        <span class="bc-sep"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 6l6 6-6 6" />
          </svg></span>
        <% if (category) { %>
        <a href="/kategorie/<%= category.slug %>"><%= category.name %></a>
        <span class="bc-sep"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 6l6 6-6 6" />
          </svg></span>
        <% } %>
        <span class="bc-current"><%= article.title %></span>
      </nav>

      <!-- Header — split layout -->
      <header class="review-header">
        <div class="review-header-text">
          <span class="eyebrow">Recenzia<% if (category) { %> · <%= category.name %><% } %></span>
          <h1 class="h-1" style="margin:16px 0;"><%= article.title %></h1>
          <% if (article.excerpt) { %>
          <p class="lead"><%= article.excerpt %></p>
          <% } %>
          <div class="review-header-author">
            <% if (article.author_avatar) { %>
            <img src="/uploads/<%= article.author_avatar %>" class="avatar" alt="<%= article.author_name %>" style="width:36px;height:36px;object-fit:cover;border-radius:50%;">
            <% } else { %>
            <span class="avatar" style="width:36px;height:36px;font-size:13px;">
              <%= (article.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %>
            </span>
            <% } %>
            <div>
              <div style="font-size:14px; font-weight:600;"><%= article.author_name || 'Redakcia' %></div>
              <div style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);">
                <%= article.published_at ? new Date(article.published_at).toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %>
                · <%= readTime %> čítania
              </div>
            </div>
          </div>
          <div style="display:flex; gap:8px; margin-top:24px; justify-content: flex-start;">
            <div class="article-authorbar-actions">
              <button class="btn btn-sm" data-bookmark data-article-id="<%= article.id %>">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z" />
                </svg>
                Uložiť
              </button>
              <button class="btn btn-sm" data-share>
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="18" cy="5" r="3" />
                  <circle cx="6" cy="12" r="3" />
                  <circle cx="18" cy="19" r="3" />
                  <path d="M8.6 13.5l6.8 4M15.4 6.5L8.6 10.5" />
                </svg>
                Zdieľať
              </button>
            </div>
          </div>
        </div>
        <div class="review-header-img">
          <% if (coverImage) { %>
          <img src="/uploads/<%= coverImage %>" alt="<%= article.title %>">
          <% } else { %>
          <div class="ph ph-<%= (article.id % 9) + 1 %>" style="aspect-ratio:auto; position:absolute; inset:0;"></div>
          <% } %>
        </div>
      </header>

      <!-- Article body -->
      <div class="article-content">
        <%- contentHtml %>
      </div>

      <!-- Tags -->
      <% if (tags.length > 0) { %>
      <div class="review-tags">
        <% tags.forEach(t => { %>
        <a href="/tag/<%= t.slug %>" class="tag">#<%= t.name %></a>
        <% }) %>
      </div>
      <% } %>

      <!-- Related reviews -->
      <% if (relatedArticles.length > 0) { %>
      <div class="sec-head" style="margin-top:var(--s-section)">
        <div class="sec-head-l">
          <span class="eyebrow">Súvisiace recenzie</span>
          <h2>Prečítaj si aj tieto</h2>
        </div>
      </div>
      <div class="rvx-related">
        <% relatedArticles.forEach(r => { %>
        <a href="/clanok/<%= r.slug %>" class="rvx-rel-card" style="text-decoration:none;color:inherit;">
          <div class="ph ph-<%= (r.id % 9) + 1 %> rvx-rel-img">
            <% if (r.cover_medium || r.cover_thumb) { %>
            <img src="/uploads/<%= r.cover_medium || r.cover_thumb %>" alt="<%= r.title %>" loading="lazy" style="width:100%;height:100%;object-fit:cover;">
            <% } %>
            <span class="rvx-rel-cat"><%= r.published_at ? new Date(r.published_at).toLocaleDateString('sk-SK') : 'Recenzia' %></span>
          </div>
          <div class="rvx-rel-body">
            <h4><%= r.title %></h4>
            <% if (r.reviewScore) { %>
            <span class="rvx-rel-score"><%= r.reviewScore.toFixed(1) %></span>
            <% } %>
          </div>
        </a>
        <% }) %>
      </div>
      <% } %>

    </div>
  </main>

  <% if (article.allow_comments) { %>
  <%- include('../partials/comments') %>
  <% } %>
  <%- include('../partials/footer') %>
  <script src="/js/comments.js" defer></script>
</body>

</html>
