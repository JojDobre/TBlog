  <body>
    <!-- Verdict -->
    <section class="verdict">
      <div class="verdict-score">
        <span class="verdict-score-label">Celkové skóre</span>
        <span class="verdict-score-num"
          ><%= reviewData.score ? reviewData.score.toFixed(1) : '—' %></span
        >
        <div class="verdict-stars">
          <% var fullStars = Math.round((reviewData.score || 0) / 2); %> <% for (var si = 0; si < 5;
          si++) { %>
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="<%= si < fullStars ? 'currentColor' : 'none' %>"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 3l2.5 5.5L20 9l-4 4 1 6-5-3-5 3 1-6-4-4 5.5-.5L12 3z" />
          </svg>
          <% } %>
        </div>
        <% if (reviewData.badge) { %>
        <span class="verdict-badge"><%= reviewData.badge %></span>
        <% } %>
      </div>
      <div class="verdict-text">
        <% if (reviewData.verdict_title) { %>
        <h3 class="h-3" style="margin: 0 0 12px"><%= reviewData.verdict_title %></h3>
        <% } %> <% if (reviewData.verdict_text) { %>
        <p style="color: var(--text-muted); font-size: 16px; line-height: 1.6; margin: 0">
          <%= reviewData.verdict_text %>
        </p>
        <% } %>
      </div>
    </section>

    <!-- Breakdown + Specs -->
    <div class="review-details">
      <% if (reviewData.breakdown && reviewData.breakdown.length > 0) { %>
      <div>
        <h3 class="h-4" style="margin-bottom: 24px">Hodnotenie podľa kategórií</h3>
        <div class="score-bd">
          <% reviewData.breakdown.forEach(b => { %>
          <div class="score-bd-row">
            <span class="score-bd-label"><%= b.label %></span>
            <div class="score-bar"><i style="width: <%= b.val * 10 %>%"></i></div>
            <span class="score-bd-val"><%= b.val.toFixed(1) %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %> <% if (reviewData.specs && reviewData.specs.length > 0) { %>
      <div>
        <h3 class="h-4" style="margin-bottom: 24px">Špecifikácie</h3>
        <table class="spec-table">
          <tbody>
            <% reviewData.specs.forEach(s => { %>
            <tr>
              <th><%= s.label %></th>
              <td><%= s.value %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

    <!-- Pros / Cons -->
    <% if ((reviewData.pros && reviewData.pros.length > 0) || (reviewData.cons &&
    reviewData.cons.length > 0)) { %>
    <div class="proscons">
      <% if (reviewData.pros && reviewData.pros.length > 0) { %>
      <div class="proscons-col proscons-col--pros">
        <h6 class="proscons-title proscons-title--pros">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12l5 5L20 7" />
          </svg>
          Páči sa nám
        </h6>
        <ul>
          <% reviewData.pros.forEach(p => { %>
          <li><%= p %></li>
          <% }) %>
        </ul>
      </div>
      <% } %> <% if (reviewData.cons && reviewData.cons.length > 0) { %>
      <div class="proscons-col proscons-col--cons">
        <h6 class="proscons-title proscons-title--cons">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M6 6l12 12M18 6L6 18" />
          </svg>
          Zamyslíme sa
        </h6>
        <ul>
          <% reviewData.cons.forEach(c => { %>
          <li><%= c %></li>
          <% }) %>
        </ul>
      </div>
      <% } %>
    </div>
    <% } %>

