<!doctype html>
<html lang="sk" data-theme="dark" data-density="comfortable" data-cardstyle="bordered">
<head>
  <%- include('../partials/head', { title: title, description: 'Newsletter odhlásenie' }) %>
</head>
<body>
  <%- include('../partials/header', { currentPath: currentPath }) %>

  <main class="page">
    <div class="container" style="max-width:560px; padding:80px 20px; text-align:center">
      <% if (success) { %>
        <div style="width:64px; height:64px; border-radius:50%; background:oklch(0.3 0.08 155); display:flex; align-items:center; justify-content:center; margin:0 auto 24px">
          <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.17 155)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
        </div>
      <% } else { %>
        <div style="width:64px; height:64px; border-radius:50%; background:oklch(0.3 0.08 25); display:flex; align-items:center; justify-content:center; margin:0 auto 24px">
          <svg aria-hidden="true" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="oklch(0.72 0.17 25)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" />
          </svg>
        </div>
      <% } %>
      <h1 class="h-2" style="margin:0 0 12px"><%= success ? 'Odhlásenie úspešné' : 'Ups' %></h1>
      <p class="lead" style="color:var(--text-muted)"><%= message %></p>
      <a href="/" class="btn btn-accent" style="margin-top:32px">Späť na hlavnú stránku</a>
    </div>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
