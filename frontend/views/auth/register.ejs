<!doctype html>
<html lang="sk">
<head>
  <%- include('../partials/head', { title: 'Registrácia' }) %>
  <link rel="stylesheet" href="/css/auth.css" />
</head>
<body class="auth-page">
  <%- include('../partials/header') %>

  <div class="auth-bg">
    <div class="auth-bg-orb auth-bg-orb-1"></div>
    <div class="auth-bg-orb auth-bg-orb-2"></div>
    <div class="auth-bg-grid"></div>
  </div>

  <main class="auth-wrap">
    <aside class="auth-side">
      <%- include('../partials/auth-side') %>
    </aside>

    <div class="auth-main">
      <div class="auth-card">
        <div class="auth-card-head">
          <span class="eyebrow">Pridaj sa</span>
          <h1 class="h-2" style="margin:10px 0 8px; letter-spacing:-0.03em">Vytvoriť účet</h1>
          <p style="margin:0; color:var(--text-muted); font-size:14px">
            Už máš účet? <a class="auth-link" href="/login">Prihlás sa</a>
          </p>
        </div>

        <% if (error) { %>
          <div class="auth-alert auth-alert--error" role="alert"><%= error %></div>
        <% } %>

        <%# === Social login — zakomentované, backend nepodporuje === %>
        <!--
        <div class="auth-providers">
          <button class="btn auth-provider" type="button">
            <span class="auth-provider-icon">G</span> Pokračovať s Google
          </button>
          <button class="btn auth-provider" type="button">
            <span class="auth-provider-icon"></span> Pokračovať s Apple
          </button>
        </div>
        <div class="auth-divider"><span>alebo</span></div>
        -->

        <form method="POST" action="/register" novalidate class="auth-form">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <label class="auth-field">
            <span class="auth-field-label">Nickname</span>
            <div class="auth-input-wrap">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
              <input type="text" id="nickname" name="nickname"
                     placeholder="tvoj_nick"
                     value="<%= values.nickname %>"
                     required autocomplete="username"
                     minlength="3" maxlength="64"
                     pattern="[a-zA-Z0-9_-]+" />
            </div>
            <small class="auth-field-hint">3–64 znakov: písmená, čísla, _ a -</small>
          </label>

          <label class="auth-field">
            <span class="auth-field-label">Email</span>
            <div class="auth-input-wrap">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>
              <input type="email" id="email" name="email"
                     placeholder="ty@example.sk"
                     value="<%= values.email %>"
                     required autocomplete="email" maxlength="255" />
            </div>
            <small class="auth-field-hint">Použijeme len na rozlíšenie účtov.</small>
          </label>

          <label class="auth-field">
            <span class="auth-field-label">Heslo</span>
            <div class="auth-input-wrap">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
              <input type="password" id="password" name="password"
                     placeholder="Min. <%= minPasswordLength %> znakov"
                     required autocomplete="new-password"
                     minlength="<%= minPasswordLength %>" maxlength="200"
                     data-strength />
              <button type="button" class="auth-input-action" data-toggle-pw="password">Zobraziť</button>
            </div>
            <div class="auth-strength" id="pw-strength" hidden>
              <div class="auth-strength-bar">
                <span></span><span></span><span></span><span></span>
              </div>
              <span class="auth-strength-label"></span>
            </div>
          </label>

          <label class="auth-field">
            <span class="auth-field-label">Heslo (znova)</span>
            <div class="auth-input-wrap">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
              <input type="password" id="password2" name="password2"
                     placeholder="Zopakuj heslo"
                     required autocomplete="new-password"
                     minlength="<%= minPasswordLength %>" maxlength="200" />
            </div>
          </label>

          <div class="auth-divider"><span>bezpečnostná otázka</span></div>

          <label class="auth-field">
            <span class="auth-field-label">Vyber otázku</span>
            <div class="auth-input-wrap auth-input-wrap--select">
              <select id="question_id" name="question_id">
                <option value="">— Vyber zo zoznamu —</option>
                <% questions.forEach((q) => { %>
                  <option value="<%= q.id %>"
                    <%= values.question_id && String(values.question_id) === String(q.id) ? 'selected' : '' %>
                  ><%= q.text %></option>
                <% }) %>
              </select>
            </div>
            <small class="auth-field-hint">Slúži na obnovu hesla. Môžeš zadať aj vlastnú otázku nižšie.</small>
          </label>

          <label class="auth-field">
            <span class="auth-field-label">…alebo vlastná otázka</span>
            <div class="auth-input-wrap">
              <input type="text" id="custom_question" name="custom_question"
                     placeholder="Napr. Ako sa volal môj prvý počítač?"
                     value="<%= values.custom_question %>"
                     maxlength="255" />
            </div>
          </label>

          <label class="auth-field">
            <span class="auth-field-label">Odpoveď</span>
            <div class="auth-input-wrap">
              <input type="text" id="answer" name="answer"
                     placeholder="Tvoja odpoveď"
                     required autocomplete="off" minlength="3" />
            </div>
            <small class="auth-field-hint">Nie je citlivé na veľkosť písmen ani medzery.</small>
          </label>

          <div class="auth-divider"><span>súhlas</span></div>

          <div class="auth-checks">
            <label class="auth-check">
              <input type="checkbox" name="gdpr" value="on" required />
              <span class="auth-check-box">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l5 5L20 7"/></svg>
              </span>
              <span>Súhlasím so <a class="auth-link" href="/gdpr" target="_blank">spracovaním osobných údajov</a></span>
            </label>
          </div>

          <button type="submit" class="btn btn-accent btn-lg auth-submit">
            Vytvoriť účet
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
        </form>

        <p class="auth-fineprint">
          Bezpečnosť: heslo si nikdy neukladáme v čistej forme.
        </p>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <script src="/js/auth.js" defer></script>
</body>
</html>
