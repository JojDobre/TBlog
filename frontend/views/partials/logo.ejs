<%
size = typeof size !== 'undefined' ? size : 'md';
subtitle = typeof subtitle !== 'undefined' ? subtitle : '';
mono = typeof mono !== 'undefined' ? mono : false;
%>
<div class="logo logo-<%= size || 'md' %>">
  <svg class="logo-mark" viewBox="0 0 32 32" aria-hidden="true">
    <circle cx="16" cy="16" r="14" fill="none" stroke="<%= mono ? 'currentColor' : 'var(--accent)' %>" stroke-width="3" opacity="<%= mono ? '0.4' : '0.3' %>" />
    <circle cx="16" cy="16" r="7" fill="<%= mono ? 'currentColor' : 'var(--accent)' %>" />
    <circle cx="16" cy="16" r="3" fill="var(--bg, #0f1117)" />
    <circle cx="14" cy="14" r="1.5" fill="<%= mono ? 'currentColor' : 'oklch(1 0 0 / 0.7)' %>" />
  </svg>

  <span class="logo-word">
    <span class="logo-word-main">Kukni <span class="logo-word-dot"> . </span>Tech</span>

    <% if (subtitle) { %>
    <span class="logo-word-sub"><%= subtitle %></span>
    <% } %>
  </span>
</div>
