<%
  const navLinks = [
    { href: '/',          label: 'Domov' },
    { href: '/recenzie',  label: 'Recenzie' },
    { href: '/rebricky',  label: 'Rebríčky' },
    { href: '/navody',    label: 'Návody' },
    { href: '/kategorie', label: 'Kategórie' },
  ];
  const cur = typeof currentPath !== 'undefined' ? currentPath : '';
%>
<header class="topnav">
  <div class="container topnav-inner">
    <a href="/" class="topnav-brand">
        <%- include('logo', {  size: 'md'}) %>
    </a>


    <nav class="topnav-pill">
      <% navLinks.forEach(link => {
        const active = (cur === link.href) || (link.href !== '/' && cur.startsWith(link.href));
      %>
        <a href="<%= link.href %>"
           class="topnav-tab <%= active ? 'active' : '' %>"><%= link.label %></a>
      <% }) %>
    </nav>

    <div class="topnav-actions">
      <a href="/hladaj" class="icon-btn" title="Hľadať">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/>
        </svg>
      </a>

      <button id="theme-toggle" class="icon-btn" title="Prepnúť tému">
        <svg id="theme-icon-dark" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="theme-icon-light" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>


      <% if (typeof user !== 'undefined' && user) { %>
        <div class="notif-wrap">
          <button class="notif-bell icon-btn" data-notif-bell title="Notifikácie">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span class="notif-badge" data-notif-badge></span>
          </button>
          <div class="notif-dropdown" data-notif-dropdown>
            <div class="notif-dropdown-header">Notifikácie</div>
            <div class="notif-dropdown-body" data-notif-list></div>
          </div>
        </div>
      <% } %>

      <% if (typeof user !== 'undefined' && user) { %>
        <div class="nav-dropdown">
          <button class="btn btn-sm btn-primary nav-dropdown-toggle" id="user-menu-btn" aria-expanded="false" aria-haspopup="true">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
            </svg>
            <%= user.nickname %>
          </button>
          <div class="nav-dropdown-menu" id="user-menu" role="menu">
            <a href="/u/<%= user.nickname %>" class="nav-dropdown-item" role="menuitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
              </svg>
              Profil
            </a>
            <a href="/profil" class="nav-dropdown-item" role="menuitem">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
              </svg>
              Upraviť profil
            </a>
            <div class="nav-dropdown-divider"></div>
            <form method="POST" action="/logout">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="nav-dropdown-item nav-dropdown-item--danger" role="menuitem">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                Odhlásiť
              </button>
            </form>
          </div>
        </div>
      <% } else { %>
        <a href="/login" class="btn btn-sm btn-primary">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
          </svg>
          Prihlásiť
        </a>
      <% } %>
    </div>
  </div>

  <% if (typeof user !== 'undefined' && user) { %>
    <script src="/js/notifications.js" defer></script>
  <% } %>
</header>
