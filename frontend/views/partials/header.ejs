<%
  const navLinks = [
    { href: '/',          label: 'Domov' },
    { href: '/recenzie',  label: 'Recenzie' },
    { href: '/rebricky',  label: 'Rebríčky' },
    { href: '/navody',    label: 'Návody' },
    { href: '/kategorie', label: 'Kategórie' },
  ];
  const cur = typeof currentPath !== 'undefined' ? currentPath : '';
%>
<header class="topnav">
  <div class="container topnav-inner">
    <a href="/" class="topnav-brand">
      <div class="bz-logo">BZ</div>
      <div class="bz-brand-name"><%= appName %></div>
    </a>

    <nav class="topnav-pill">
      <% navLinks.forEach(link => {
        const active = (cur === link.href) || (link.href !== '/' && cur.startsWith(link.href));
      %>
        <a href="<%= link.href %>"
           class="topnav-tab <%= active ? 'active' : '' %>"><%= link.label %></a>
      <% }) %>
    </nav>

    <div class="topnav-actions">
      <a href="/hladaj" class="icon-btn" title="Hľadať">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="7"/><path d="M20 20l-3.5-3.5"/>
        </svg>
      </a>
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="/profil" class="btn btn-sm btn-primary">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
          </svg>
          <%= user.nickname %>
        </a>
      <% } else { %>
        <a href="/admin/login" class="btn btn-sm btn-primary">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/>
          </svg>
          Prihlásiť
        </a>
      <% } %>
    </div>
  </div>
</header>