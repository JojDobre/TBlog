  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= (typeof title !== 'undefined' && title) ? title + ' · ' + appName : appName %></title>
  <% if (typeof description !== 'undefined' && description) { %>
  <meta name="description" content="<%= description %>">
  <% } %>

  <%# === OG Meta Tags === %>
  <meta property="og:title" content="<%= (typeof ogTitle !== 'undefined' && ogTitle) ? ogTitle : ((typeof title !== 'undefined' && title) ? title : appName) %>">
  <meta property="og:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) ? ogDescription : ((typeof description !== 'undefined' && description) ? description : '') %>">
  <meta property="og:type" content="<%= (typeof ogType !== 'undefined' && ogType) ? ogType : 'website' %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta property="og:image" content="<%= ogImage %>">
  <% } %>
  <% if (typeof canonicalUrl !== 'undefined' && canonicalUrl) { %>
  <meta property="og:url" content="<%= canonicalUrl %>">
  <link rel="canonical" href="<%= canonicalUrl %>">
  <% } %>
  <meta property="og:site_name" content="<%= appName %>">

  <%# === Twitter Card === %>
  <meta name="twitter:card" content="<%= (typeof ogImage !== 'undefined' && ogImage) ? 'summary_large_image' : 'summary' %>">
  <meta name="twitter:title" content="<%= (typeof ogTitle !== 'undefined' && ogTitle) ? ogTitle : ((typeof title !== 'undefined' && title) ? title : appName) %>">
  <meta name="twitter:description" content="<%= (typeof ogDescription !== 'undefined' && ogDescription) ? ogDescription : ((typeof description !== 'undefined' && description) ? description : '') %>">
  <% if (typeof ogImage !== 'undefined' && ogImage) { %>
  <meta name="twitter:image" content="<%= ogImage %>">
  <% } %>

  <%# === JSON-LD Structured Data === %>
  <% if (typeof jsonLd !== 'undefined' && jsonLd) { %>
  <script type="application/ld+json">
    <%- JSON.stringify(jsonLd) %>
  </script>
  <% } %>

  <script src="/js/theme.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/site.css">
  <link rel="stylesheet" href="/css/rvx-blocks.css">
  <link rel="stylesheet" href="/css/rvx-galleries.css">
  <link rel="stylesheet" href="/css/responsive.css">

  <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
  <meta name="csrf-token" content="<%= csrfToken %>">
  <% } %>

  <%# === Favicon === %>
  <link rel="icon" href="/img/favicon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/img/favicon.svg">

  <%# === Google Consent Mode + Analytics === %>
  <script src="/js/consent-mode.js"></script>
  <% if (typeof siteSettings !== 'undefined' && siteSettings.analytics_html) { %>
  <%- siteSettings.analytics_html %>
  <% } %>

  <meta name="google-adsense-account" content="ca-pub-2155254098042019">
