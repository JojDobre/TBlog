<%# Cookie consent banner — GDPR %>
<div id="cookie-consent" class="cookie-banner" style="display:none;">
  <div class="cookie-banner-inner">
    <div class="cookie-banner-text">
      <strong>Cookies</strong>
      <span>Používame len nevyhnutné cookies na fungovanie webu a anonymnú analytiku. Žiadne reklamné cookies.</span>
    </div>
    <div class="cookie-banner-actions">
      <button class="btn btn-sm btn-ghost" onclick="cookieConsent('necessary')">Len nutné</button>
      <button class="btn btn-sm btn-accent" onclick="cookieConsent('all')">Súhlasím</button>
    </div>
  </div>
</div>
<script>
(function(){
  var KEY='bz_consent';
  if(localStorage.getItem(KEY)) return;
  var el=document.getElementById('cookie-consent');
  if(el) el.style.display='';
  window.cookieConsent=function(v){
    localStorage.setItem(KEY,v);
    document.cookie=KEY+'='+v+';path=/;max-age=31536000;SameSite=Lax';
    if(el) el.style.display='none';
  };
})();
</script>
