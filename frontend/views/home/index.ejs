<!doctype html>
<html lang="sk" data-theme="dark" data-density="comfortable" data-cardstyle="bordered">
<head>
  <%- include('../partials/head', { title: null, description: 'Nezávislý tech magazín. Recenzie, rebríčky a návody.' }) %>
</head>
<body>
  <div class="page-home-bg"></div>

  <%- include('../partials/header', { currentPath: currentPath }) %>

  <main class="page">
    <div class="container">

      <!-- ============================================================
           1. HERO SLIDER — posledné 4 featured články
           ============================================================ -->
      <% if (featured.length > 0) { %>
        <section class="hero-banner" data-hero-slider>
          <div class="hero-banner-bg">
            <div class="hero-banner-glow"></div>
            <div class="hero-banner-grid"></div>
          </div>

          <% featured.forEach((a, idx) => { %>
            <div class="hero-banner-inner hero-slide <%= idx === 0 ? 'hero-slide--active' : '' %>"
                 data-slide-index="<%= idx %>">
              <div class="hero-banner-text">
                <div class="hero-tags">
                  <span class="tag tag-accent">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s4 4 4 8a4 4 0 0 1-8 0c0-2 1-3 1-3s-3 2-3 6a6 6 0 0 0 12 0c0-6-6-11-6-11z"/></svg>
                    Hlavný príbeh
                  </span>
                  <% if (a.type === 'review') { %><span class="tag">Recenzia</span><% } %>
                  <% if (a.category) { %><span class="tag"><%= a.category.name %></span><% } %>
                </div>
                <h1 class="h-1 hero-banner-title"><%= a.title %></h1>
                <p class="lead hero-banner-lead"><%= a.excerpt %></p>
                <div class="hero-banner-meta">
                  <a href="/clanok/<%= a.slug %>" class="btn btn-accent btn-lg">
                    Čítať článok
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                  </a>
                  <div class="hero-author-info">
                    <span class="avatar"><%= (a.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %></span>
                    <div class="hero-author-text">
                      <span class="hero-author-name"><%= a.author_name || 'Redakcia' %></span>
                      <span class="hero-author-date">
                        <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %>
                        · <%= a.readTime %> čítania
                      </span>
                    </div>
                  </div>
                </div>
              </div>
              <div class="hero-banner-visual">
                <div class="hero-banner-shadow"></div>
                <div class="hero-banner-img">
                  <% if (a.cover_full) { %>
                    <img src="/uploads/<%= a.cover_full %>" alt="<%= a.title %>" loading="<%= idx === 0 ? 'eager' : 'lazy' %>">
                  <% } else { %>
                    <div class="ph ph-<%= (a.id % 9) + 1 %>"></div>
                  <% } %>
                  <div class="hero-banner-shine"></div>
                </div>
                <div class="hero-banner-floater hero-banner-floater-1">
                  <span class="eyebrow">Pozretia</span>
                  <span class="hero-floater-val"><%= a.viewsFormatted %></span>
                </div>
                <div class="hero-banner-floater hero-banner-floater-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 7l-8 8-4-4-7 7M16 7h6v6"/></svg>
                  <span class="hero-floater-stat"><%= a.viewsFormatted %></span>
                </div>
              </div>
            </div>
          <% }) %>

          <div class="hero-banner-controls">
            <div class="hero-banner-dots">
              <% featured.forEach((_, i) => { %>
                <button class="hero-banner-dot <%= i === 0 ? 'active' : '' %>"
                        data-slide-dot="<%= i %>" aria-label="Slide <%= i + 1 %>"></button>
              <% }) %>
            </div>
            <div class="hero-banner-arrows">
              <button class="icon-btn" data-slide-prev aria-label="Predošlý">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg)"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </button>
              <button class="icon-btn" data-slide-next aria-label="Ďalší">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </button>
            </div>
          </div>
        </section>
      <% } %>


      <!-- ============================================================
           2. NOVINKY — bento mosaic
           ============================================================ -->
      <% if (latest.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Najaktualnejšie · Články</span>
            <h2>Novinky</h2>
          </div>
        </div>

        <div class="bento">
          <% if (latest[0]) { %>
            <article class="card card-link bento-a">
              <a href="/clanok/<%= latest[0].slug %>">
                <% if (latest[0].cover_full) { %>
                  <div class="ph" style="background-image: url('/uploads/<%= latest[0].cover_full %>'); background-size: cover; background-position: center;"></div>
                <% } else { %>
                  <div class="ph ph-<%= (latest[0].id % 9) + 1 %>"></div>
                <% } %>
                <div class="bento-overlay">
                  <% if (latest[0].tags[0]) { %><span class="tag tag-accent" style="align-self:flex-start;"><%= latest[0].tags[0].name %></span><% } %>
                  <h3 class="bento-main-title"><%= latest[0].title %></h3>
                  <span class="bento-meta-line"><%= latest[0].author_name %> · <%= latest[0].readTime %></span>
                </div>
              </a>
            </article>
          <% } %>

          <% if (latest[1]) { %>
            <article class="card card-link bento-b">
              <a href="/clanok/<%= latest[1].slug %>">
                <% if (latest[1].cover_full) { %>
                  <div class="ph" style="background-image: url('/uploads/<%= latest[1].cover_full %>'); background-size: cover; background-position: center;"></div>
                <% } else { %>
                  <div class="ph ph-<%= (latest[1].id % 9) + 1 %>"></div>
                <% } %>
                <div class="bento-overlay">
                  <% if (latest[1].category) { %><span class="tag bento-tag-dark"><%= latest[1].category.name %></span><% } %>
                  <h3 class="bento-sub-title"><%= latest[1].title %></h3>
                  <span class="bento-meta-line"><%= latest[1].author_name %> · <%= latest[1].readTime %></span>
                </div>
              </a>
            </article>
          <% } %>

          <% if (latest[2]) { %>
            <article class="card card-link bento-c">
              <a href="/clanok/<%= latest[2].slug %>" class="bento-text-card">
                <span class="eyebrow" style="color:var(--accent);"><%= latest[2].type === 'review' ? 'Recenzia' : (latest[2].tags[0] ? latest[2].tags[0].name : 'Článok') %></span>
                <h3 class="bento-text-title"><%= latest[2].title %></h3>
                <p class="bento-text-excerpt"><%= latest[2].excerpt %></p>
              </a>
            </article>
          <% } %>

          <% if (latest[3]) { %>
            <article class="card card-link bento-d">
              <a href="/clanok/<%= latest[3].slug %>">
                <% if (latest[3].cover_full) { %>
                  <div class="ph" style="background-image: url('/uploads/<%= latest[3].cover_full %>'); background-size: cover; background-position: center;"></div>
                <% } else { %>
                  <div class="ph ph-<%= (latest[3].id % 9) + 1 %>"></div>
                <% } %>
                <div class="bento-overlay">
                  <h3 class="bento-sm-title"><%= latest[3].title %></h3>
                  <span class="bento-meta-line"><%= latest[3].author_name %> · <%= latest[3].readTime %></span>
                </div>
              </a>
            </article>
          <% } %>

          <% if (latest[4]) { %>
            <article class="card card-link bento-c">
              <a href="/clanok/<%= latest[4].slug %>" class="bento-text-card">
                <span class="eyebrow" style="color:var(--accent);"><%= latest[4].type === 'review' ? 'Recenzia' : (latest[4].tags[0] ? latest[4].tags[0].name : 'Článok') %></span>
                <h3 class="bento-text-title"><%= latest[4].title %></h3>
                <p class="bento-text-excerpt"><%= latest[4].excerpt %></p>
              </a>
            </article>
          <% } %>

          <% if (latest[5]) { %>
            <article class="card card-link bento-b">
              <a href="/clanok/<%= latest[5].slug %>">
                <% if (latest[5].cover_full) { %>
                  <div class="ph" style="background-image: url('/uploads/<%= latest[5].cover_full %>'); background-size: cover; background-position: center;"></div>
                <% } else { %>
                  <div class="ph ph-<%= (latest[5].id % 9) + 1 %>"></div>
                <% } %>
                <div class="bento-overlay">
                  <% if (latest[5].category) { %><span class="tag bento-tag-dark"><%= latest[5].category.name %></span><% } %>
                  <h3 class="bento-sub-title"><%= latest[5].title %></h3>
                  <span class="bento-meta-line"><%= latest[5].author_name %> · <%= latest[5].readTime %></span>
                </div>
              </a>
            </article>
          <% } %>

          <% if (latest[6]) { %>
              <article class="card card-link bento-c">
                <a href="/clanok/<%= latest[6].slug %>" class="bento-text-card">
                  <span class="eyebrow" style="color:var(--accent);"><%= latest[6].type === 'review' ? 'Recenzia' : (latest[6].tags[0] ? latest[6].tags[0].name : 'Článok') %></span>
                  <h3 class="bento-text-title"><%= latest[6].title %></h3>
                  <p class="bento-text-excerpt"><%= latest[6].excerpt %></p>
                </a>
              </article>
            <% } %>
          </div>
        <% } %>


      <!-- ============================================================
           3. TRENDY — TOP 6 najčítanejších
           ============================================================ -->
      <% if (trending.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Trendy · Posledných 7 dní</span>
            <h2>TOP<%= trending.length %>, ktoré najviac hýbu redakciou</h2>
          </div>
          <a class="sec-head-link" href="/kategorie">
            Všetko
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <div class="trending-list">
          <% trending.forEach((a, i) => { %>
            <a href="/clanok/<%= a.slug %>" class="trending-item">
              <span class="trending-num"><%= String(i + 1).padStart(2, '0') %></span>
              <div class="trending-body">
                <div class="trending-meta">
                  <span class="tag tag-accent" style="padding:2px 8px; font-size:10px;">
                    <%= a.type === 'review' ? 'Recenzia' : (a.tags[0] ? a.tags[0].name : 'Článok') %>
                  </span>
                  <span class="trending-meta-text">
                    <%= a.category ? a.category.name : '' %>
                    · <%= a.readTime %>
                  </span>
                </div>
                <h3 class="trending-title"><%= a.title %></h3>
              </div>
              <div class="trending-stats">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 7l-8 8-4-4-7 7M16 7h6v6"/></svg>
                <span class="trending-views"><%= a.viewsFormatted %></span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>


      <!-- ============================================================
           5. "RECENZIE V SKRATKE" — vlep ZA sekciu "Recenzie grid"
           ============================================================ -->

<!-- Minimal reviews -->
      <% if (reviews.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Skóre & nič viac</span>
            <h2>Recenzie v skratke</h2>
          </div>
          <a class="sec-head-link" href="/recenzie">Všetky
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid-4">
          <% reviews.slice(0, 4).forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="card card-link minimal-review">
              <div class="ph" style="aspect-ratio:1; position:relative;">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="<%= a.title %>" loading="lazy">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="position:absolute;inset:0;aspect-ratio:auto;"></div>
                <% } %>
                <div class="minimal-review-score">
                  <span class="minimal-review-label">Skóre</span>
                  <span class="minimal-review-num"><%= a.viewsFormatted %></span>
                </div>
              </div>
              <h4 class="minimal-review-title"><%= a.title %></h4>
            </a>
          <% }) %>
        </div>
      <% } %>




      <!-- ============================================================
           4. EDITOR'S PICK — magazine split
           ============================================================ -->
      <% if (editorsPick) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Výber redakcie</span>
            <h2>Článok, ktorý si nechceš nechať ujsť</h2>
          </div>
        </div>
        <a href="/clanok/<%= editorsPick.slug %>" class="editorial-split card card-link">
          <div class="editorial-split-img">
            <% if (editorsPick.cover_full) { %>
              <img src="/uploads/<%= editorsPick.cover_full %>" alt="<%= editorsPick.title %>" loading="lazy">
            <% } else { %>
              <div class="ph ph-<%= (editorsPick.id % 9) + 1 %>"></div>
            <% } %>
          </div>
          <div class="editorial-split-body">
            <span class="eyebrow" style="color:var(--accent);"><%= editorsPick.type === 'review' ? 'Recenzia' : 'Článok' %> · Editor's Pick</span>
            <h3 class="h-2" style="margin:16px 0; letter-spacing:-0.03em;"><%= editorsPick.title %></h3>
            <p class="lead" style="margin:0;"><%= editorsPick.excerpt %></p>
            <div style="margin:32px 0; height:1px; background:var(--border);"></div>
            <div class="editorial-split-footer">
              <div class="editorial-author">
                <span class="avatar"><%= (editorsPick.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %></span>
                <div>
                  <div class="editorial-author-name"><%= editorsPick.author_name || 'Redakcia' %></div>
                  <div class="editorial-author-date">
                    <%= editorsPick.published_at ? new Date(editorsPick.published_at).toLocaleDateString('sk-SK', { day: 'numeric', month: 'long', year: 'numeric' }) : '' %>
                    · <%= editorsPick.readTime %>
                  </div>
                </div>
              </div>
              <span class="btn btn-sm">Čítať
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </span>
            </div>
          </div>
        </a>
      <% } %>

      <!-- ============================================================
           10. PROMO BANNER 3 — App download (placeholder)
           ============================================================ -->
      <section class="promo-banner promo-app">
        <div class="promo-app-grid"></div>
        <div class="promo-app-content">
          <div>
            <span class="eyebrow" style="color:oklch(0.85 0.1 155);">Mobilná aplikácia · iOS & Android</span>
            <h2 class="h-2" style="margin:12px 0; max-width:540px; color:oklch(1 0 0);">ByteZone ti zmestíme do vrecka.</h2>
            <p class="lead" style="max-width:480px; margin:0; color:oklch(1 0 0/0.8);">Offline čítanie, push notifikácie len na to dôležité a tmavý režim, ktorý sa neoslepí.</p>
            <div style="display:flex; gap:12px; margin-top:28px; flex-wrap:wrap;">
              <span class="btn btn-lg btn-accent">App Store</span>
              <span class="btn btn-lg" style="background:oklch(1 0 0/0.15); color:oklch(1 0 0); border-color:oklch(1 0 0/0.2);">Google Play</span>
            </div>
          </div>
          <div class="promo-app-stats">
            <div class="promo-stat">
              <span class="promo-stat-num">4.8</span>
              <span class="promo-stat-label">App Store rating</span>
            </div>
            <div class="promo-stat">
              <span class="promo-stat-num">52k</span>
              <span class="promo-stat-label">aktívnych čitateľov</span>
            </div>
            <div class="promo-stat">
              <span class="promo-stat-num">2.1k</span>
              <span class="promo-stat-label">recenzií</span>
            </div>
          </div>
        </div>
      </section>


      <!-- ============================================================
           "BEZ OBRÁZKOV"
           ============================================================ -->

      <!-- Minimal text feed -->
      <% if (latest.length > 4) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Z archívu · Týždeň späť</span>
            <h2>Bez obrázkov, len slová</h2>
          </div>
        </div>
        <div class="minimal-feed">
          <% latest.slice(3, 8).forEach((a, i) => { %>
            <a href="/clanok/<%= a.slug %>" class="minimal-item">
              <span class="minimal-num"><%= String(i + 1).padStart(2, '0') %></span>
              <div class="minimal-body">
                <div class="minimal-item-meta">
                  <span class="minimal-tag"><%= a.type === 'review' ? 'Recenzia' : (a.tags[0] ? a.tags[0].name : 'Článok') %></span>
                  <span class="minimal-dot"></span>
                  <span class="minimal-date"><%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %></span>
                </div>
                <h3 class="minimal-title"><%= a.title %></h3>
                <p class="minimal-excerpt"><%= a.excerpt %></p>
              </div>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M8 7h9v9"/></svg>
            </a>
          <% }) %>
        </div>
      <% } %>


      <!-- ============================================================
           7. PROMO BANNER — sponzorovaný produkt (placeholder)
           ============================================================ -->
      <section class="promo-banner promo-brand">
        <div class="promo-banner-bg promo-bg-mesh"></div>
        <div style="position:relative; z-index:1;">
          <span class="eyebrow" style="color:oklch(1 0 0/0.7);">Partner · Apple</span>
          <h2 class="h-2" style="margin:12px 0; color:oklch(1 0 0);">MacBook Pro M5. Tichý. Rýchly. Tvoj.</h2>
          <p class="lead" style="max-width:520px; color:oklch(1 0 0/0.85);">Konfigurovaný presne pre tvoj workflow. So študentskou zľavou ušetríš až 280 €.</p>
          <span style="font-family:var(--font-mono); font-size:11px; color:oklch(1 0 0/0.5); margin-top:16px; display:block;">Sponzorované · Apple Slovakia</span>
        </div>
        <div class="promo-banner-cta">
          <div class="promo-banner-product ph ph-mesh"></div>
          <span class="btn btn-lg" style="background:oklch(1 0 0); color:oklch(0.18 0.01 240);">
            Pozri ponuky
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M8 7h9v9"/></svg>
          </span>
        </div>
      </section>


      <!-- ============================================================
           9. COMPACT LIST — mini správy
           ============================================================ -->
      <% if (latest.length > 2) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Krátko a rýchlo</span>
            <h2>Mini správy</h2>
          </div>
        </div>
        <div class="compact-list">
          <% latest.slice(0, 6).forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="compact-item">
              <div class="compact-thumb">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;border-radius:var(--r-sm);">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="aspect-ratio:1;border-radius:var(--r-sm);"></div>
                <% } %>
              </div>
              <div class="compact-body">
                <span class="eyebrow" style="font-size:10px;"><%= a.category ? a.category.name : 'Článok' %></span>
                <h4 class="compact-title"><%= a.title %></h4>
                <span class="compact-date">
                  <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %>
                  · <%= a.readTime %>
                </span>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>



      <!-- ============================================================
           4. PROMO BANNER — placeholder
           ============================================================ -->
      <section class="promo-banner promo-cross">
        <div class="promo-cross-pattern"></div>
        <div style="position:relative; z-index:1; display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
          <span class="promo-badge">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7M8 7h9v9"/></svg>
            Externý odkaz
          </span>
          <span class="promo-meta-text">bytezone.sk/podcast</span>
        </div>
        <h2 class="h-2" style="margin:16px 0; max-width:680px; position:relative; z-index:1;">Náš podcast: Týždeň v techu, každú nedeľu o 19:00.</h2>
        <p class="lead" style="max-width:540px; position:relative; z-index:1;">45 minút diskusie o tom, čo sa stalo a čo z toho ostane. Dostupné na Spotify, Apple a YouTube.</p>
        <div style="display:flex; gap:10px; margin-top:24px; position:relative; z-index:1; flex-wrap:wrap;">
          <a href="#" class="btn btn-accent">Spotify</a>
          <a href="#" class="btn">Apple Podcasts</a>
          <a href="#" class="btn">YouTube</a>
        </div>
      </section>


      <!-- ============================================================
           5. NEWSLETTER CTA — placeholder
           ============================================================ -->
      <section class="newsletter-section">
        <div class="newsletter-mesh"></div>
        <div class="newsletter-content">
          <span class="eyebrow">Newsletter · Každý piatok</span>
          <h2 class="h-2" style="margin:12px 0;">Šum sme odfiltrovali za teba.</h2>
          <p class="lead" style="max-width:520px;">5 noviniek, 1 hĺbková analýza a žiadne tlačové správy.</p>
        </div>
        <div class="newsletter-form">
          <div class="search" style="min-width:0; height:52px; border-radius:var(--r-lg);">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
            <input type="email" placeholder="tvoj@email.sk" style="font-size:15px;">
          </div>
          <button class="btn btn-accent btn-lg" style="justify-content:center; width:100%;">
            Prihlásiť sa
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>
          <span class="newsletter-note">Žiadny spam. Odhlásiť sa môžeš jedným klikom.</span>
        </div>
      </section>


<!--

           ============================================================
           5. RÝCHLY POHĽAD" Title-only grid
           ============================================================

      <% if (latest.length > 1) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Rýchly pohľad</span>
            <h2>Bez zbytočných slov</h2>
          </div>
          <a class="sec-head-link" href="/kategorie">Viac
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid-3">
          <% latest.slice(0, 6).forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="card card-link title-only">
              <div class="ph" style="aspect-ratio:4/3; position:relative;">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="<%= a.title %>" loading="lazy">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="position:absolute;inset:0;aspect-ratio:auto;"></div>
                <% } %>
              </div>
              <div class="title-only-body">
                <div class="title-only-meta">
                  <span class="tag <%= a.type === 'review' ? 'tag-accent' : '' %>" style="padding:2px 8px; font-size:10px;">
                    <%= a.type === 'review' ? 'Recenzia' : (a.tags[0] ? a.tags[0].name : 'Článok') %>
                  </span>
                  <span class="dot"></span>
                  <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);">
                    <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %>
                  </span>
                </div>
                <h4 class="title-only-title"><%= a.title %></h4>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>


      <!-- ============================================================
           5. NAJNOVŠIE — standard card grid
           ============================================================
      <% if (latest.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Najnovšie</span>
            <h2>Čo sa stalo tento týždeň</h2>
          </div>
        </div>
        <div class="grid-3">
          <% latest.slice(0, 6).forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="card card-link acard">
              <div class="ph">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="<%= a.title %>" loading="lazy">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="position:absolute;inset:0;aspect-ratio:auto;"></div>
                <% } %>
              </div>
              <div class="acard-body">
                <div class="acard-meta">
                  <span class="tag tag-accent" style="padding:2px 8px; font-size:11px;">
                    <%= a.type === 'review' ? 'Recenzia' : (a.tags[0] ? a.tags[0].name : 'Článok') %>
                  </span>
                  <span class="dot"></span>
                  <span><%= a.readTime %></span>
                  <span class="dot"></span>
                  <span><%= a.viewsFormatted %> pozretí</span>
                </div>
                <h3 class="acard-title"><%= a.title %></h3>
                <p class="acard-excerpt"><%= a.excerpt %></p>
                <div class="acard-foot">
                  <div class="acard-author">
                    <span class="avatar"><%= (a.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %></span>
                    <span><%= a.author_name || 'Redakcia' %></span>
                    <span class="dot"></span>
                    <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);">
                      <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %>
                    </span>
                  </div>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>


      <!-- ============================================================
           6. RECENZIE — score overlay grid
           ============================================================
      <% if (reviews.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Recenzie</span>
            <h2>Otestované, skóre udelené</h2>
          </div>
          <a class="sec-head-link" href="/recenzie">
            Všetky recenzie
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="grid-3">
          <% reviews.forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="card card-link review-card">
              <div class="ph" style="aspect-ratio:16/10; position:relative;">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="<%= a.title %>" loading="lazy">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="position:absolute;inset:0;aspect-ratio:auto;"></div>
                <% } %>
                <div class="review-card-score">
                  <span class="review-card-score-label">Skóre</span>
                  <span class="review-card-score-num"><%= a.viewsFormatted %></span>
                </div>
              </div>
              <div class="acard-body">
                <div class="acard-meta">
                  <span class="tag tag-accent" style="padding:2px 8px; font-size:11px;">Recenzia</span>
                  <span class="dot"></span>
                  <span><%= a.readTime %></span>
                </div>
                <h3 class="acard-title"><%= a.title %></h3>
                <p class="acard-excerpt"><%= a.excerpt %></p>
                <div class="acard-foot">
                  <div class="acard-author">
                    <span class="avatar"><%= (a.author_name || 'BZ').split(' ').map(s => s[0]).slice(0,2).join('') %></span>
                    <span><%= a.author_name %></span>
                  </div>
                  <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);">
                    <%= a.published_at ? new Date(a.published_at).toLocaleDateString('sk-SK') : '' %>
                  </span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>

      <!-- ============================================================
           8. CAROUSEL — mohlo by ťa zaujímať
           ============================================================
      <% if (latest.length > 0) { %>
        <div class="sec-head">
          <div class="sec-head-l">
            <span class="eyebrow">Pre teba · Personalizované</span>
            <h2>Mohlo by ťa zaujímať</h2>
          </div>
          <div style="display:flex; gap:6px;">
            <button class="icon-btn" data-carousel-prev>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" style="transform:rotate(180deg)"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>
            <button class="icon-btn" data-carousel-next>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>
        <div class="carousel-track" data-carousel-track>
          <% latest.forEach(a => { %>
            <a href="/clanok/<%= a.slug %>" class="carousel-card card card-link">
              <div class="ph" style="aspect-ratio:4/5;">
                <% if (a.cover_thumb) { %>
                  <img src="/uploads/<%= a.cover_thumb %>" alt="<%= a.title %>" loading="lazy">
                <% } else { %>
                  <div class="ph ph-<%= (a.id % 9) + 1 %>" style="position:absolute;inset:0;aspect-ratio:auto;"></div>
                <% } %>
              </div>
              <div style="padding:var(--s-card-pad); display:flex; flex-direction:column; gap:8px;">
                <span class="eyebrow" style="font-size:10px;">
                  <%= a.type === 'review' ? 'Recenzia' : (a.tags[0] ? a.tags[0].name : 'Článok') %>
                </span>
                <h4 class="carousel-card-title"><%= a.title %></h4>
                <div style="display:flex; align-items:center; justify-content:space-between; margin-top:6px;">
                  <span style="font-family:var(--font-mono); font-size:11px; color:var(--text-subtle);"><%= a.readTime %></span>
                </div>
              </div>
            </a>
          <% }) %>
        </div>
      <% } %>


-->

    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/site.js" defer></script>
</body>
</html>
