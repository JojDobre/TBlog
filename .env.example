# =============================================================================
# Bytezone — environment variables
# =============================================================================
# 1. Skopírovať: cp .env.example .env
# 2. Vygenerovať silný SESSION_SECRET:
#      node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 3. Skutočný .env je v .gitignore — NIKDY ho necommitovať.
# =============================================================================

# --- Aplikácia ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- Databáza (zhoduje sa s docker-compose.yml) ------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=bytezone_app
DB_PASSWORD=applocaldev
DB_NAME=bytezone_dev

# --- Session -----------------------------------------------------------------
# DÔLEŽITÉ: vygeneruj náhodný 64-znakový hex string, NEPOUŽÍVAJ tento default.
SESSION_SECRET=zmen-toto-na-nahodny-string-aspon-64-znakov-z-crypto-randomBytes

# --- Production-only nastavenia (zatiaľ ignorovať) ---------------------------
# DB_SSL=false
# TRUST_PROXY=false
